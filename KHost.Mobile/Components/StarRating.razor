@* 0-5 rating. 0 = unsung (shows an "unsung" overlay). Tap the current top star again to clear back to 0.
   ReadOnly renders inert <span>s (not disabled <button>s) so a tap on the stars passes through to whatever
   sits under them — e.g. the song card's tap-to-open handler. *@
<div class="stars @ToneClass @(ReadOnly ? "stars--readonly" : "") @(Value <= 0 && !Sung ? "stars--unrated" : "")"
     role="@(ReadOnly ? "img" : "radiogroup")" aria-label="@(ReadOnly ? $"Rating: {Value} of 5" : "Rating")">
    @for (var i = 1; i <= 5; i++)
    {
        var star = i;
        if (ReadOnly)
        {
            <span class="stars__star @(star <= Value ? "is-filled" : "")" aria-hidden="true">★</span>
        }
        else
        {
            <button type="button"
                    class="stars__star @(star <= Value ? "is-filled" : "")"
                    @onclick="() => SetAsync(star)"
                    aria-label="@($"{star} of 5 — {Label(star)}")"
                    title="@Label(star)">★</button>
        }
    }
    @if (Value <= 0 && !Sung)
    {
        <span class="stars__unsung" aria-hidden="true">unsung</span>
    }
</div>

@code {
    [Parameter] public int Value { get; set; }
    [Parameter] public EventCallback<int> ValueChanged { get; set; }
    [Parameter] public bool ReadOnly { get; set; }

    /// <summary>When true, a 0 rating is "sung but unrated" — suppresses the "unsung" overlay.</summary>
    [Parameter] public bool Sung { get; set; }

    /// <summary>Colour of the filled stars: "hot" (red — how it went), "cool" (blue — enjoyment), or null (gold).</summary>
    [Parameter] public string? Tone { get; set; }

    private string ToneClass => Tone switch { "hot" => "stars--hot", "cool" => "stars--cool", _ => "" };

    // Tapping the already-selected rank clears the rating back to 0 (unsung).
    private async Task SetAsync(int value)
    {
        if (ReadOnly)
            return;

        var next = value == Value ? 0 : value;
        Value = next;
        await ValueChanged.InvokeAsync(next);
    }

    private static string Label(int value) => value switch
    {
        1 => "Not confident",
        2 => "Shaky",
        3 => "Okay",
        4 => "Confident",
        5 => "Nailed it",
        _ => "Unsung",
    };
}

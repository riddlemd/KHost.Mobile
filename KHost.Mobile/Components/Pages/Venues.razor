@page "/venues"
@layout MainLayout
@inject IVenueStore Store
@inject ISongListStore Songs
@inject IAppSession Session
@inject ILinkLauncher Links
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IBackButtonService BackButton
@inject IHaptics Haptics
@implements IDisposable

@* The Venues page — manage saved karaoke venues and see your history at each. Reached from the header ⋮ menu and
   the active-venue chip. The active venue (a session pointer, not persisted here) is pinned + badged; performances
   logged while a venue is active are tagged with it, which is what powers the per-venue history below.
   Row gestures come from swipe.js: tap opens the detail sheet, press-and-hold sets the venue active (the detail
   sheet's Active toggle is the equivalent that a screen reader can reach), swipe-left removes. *@
<section class="venues">
    <div class="page-head">
        <NavLink class="page-back" href="" aria-label="Back to my songs">←</NavLink>
        <h1 class="page-title">Venues</h1>
        <button type="button" class="btn btn-secondary venues__add" data-tut="venue-add" @onclick="OpenAdd">＋ Add</button>
    </div>

    @if (_venues.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-state__icon">📍</div>
            <div class="empty-state__title">No venues yet</div>
            <div>Add the places you sing — then the active one tags your sings and opens its KaraFun catalog. You can scan a venue's KaraFun QR code while adding.</div>
            <button class="btn btn-primary venues__cta" @onclick="OpenAdd">Add your first venue</button>
        </div>
    }
    else
    {
        <input class="input venues__search" type="search" placeholder="Search venues" aria-label="Search venues"
               @bind="_search" @bind:event="oninput" />
        @if (!Ordered().Any())
        {
            <div class="venues__nomatch">No venues match “@_search”.</div>
        }
        else
        {
        <div class="list-hint">Press and hold a venue to make it active.</div>
        <div class="venue-list" @ref="_swipeRoot">
            @foreach (var v in Ordered())
            {
                @* data-tut is on every row; the tour's querySelector spotlights the first one. *@
                <div class="venue-row @(IsActive(v) ? "is-active" : "")" @key="v.Id" data-venue-id="@v.Id" data-tut="venue-hold">
                    <span class="venue-row__pin">@v.Glyph</span>
                    <div class="venue-row__main">
                        <div class="venue-row__name">
                            @v.Name
                            @if (v.IsFavorite)
                            {
                                <span class="venue-row__star">★</span>
                            }
                            @if (!v.ShowInSwitcher)
                            {
                                <span class="venue-row__badge venue-row__badge--muted">Hidden</span>
                            }
                        </div>
                        @if (SubLine(v) is { Length: > 0 } sub)
                        {
                            <div class="venue-row__sub">@sub</div>
                        }
                    </div>
                    @if (IsActive(v))
                    {
                        <span class="venue-row__active" aria-label="Active venue">Active</span>
                    }
                </div>
            }
        </div>
        }
    }
</section>

@* ---- Detail sheet ---- *@
@if (_detail is { } d)
{
    <div class="sheet-backdrop" @onclick="CloseDetail"></div>
    <div class="sheet venue-detail" role="dialog" aria-modal="true" @ref="_detailSheet">
        <button type="button" class="sheet__close" @onclick="CloseDetail" aria-label="Close">✕</button>

        <div class="venue-detail__hero">
            <span class="venue-detail__glyph">@d.Glyph</span>
            <div class="venue-detail__heading">
                <div class="venue-detail__name">@d.Name</div>
            </div>
        </div>

        <div class="venue-detail__actions">
            @if (!string.IsNullOrWhiteSpace(d.KaraFunVenueId))
            {
                <button class="btn btn-primary" data-tut="venue-karafun" @onclick="() => OpenCatalogAsync(d)">Open KaraFun Catalog</button>
            }
            @* Flipping Active off clears the active venue (not-at-a-venue), same as picking "Not at a venue" elsewhere. *@
            <label class="setting venue-detail__toggle">
                <span class="setting__text"><span class="setting__title">Active</span></span>
                <span class="switch">
                    <input class="switch__input" type="checkbox" checked="@IsActive(d)" @onchange="() => ToggleActive(d)" />
                    <span class="switch__track"><span class="switch__thumb"></span></span>
                </span>
            </label>
            <label class="setting venue-detail__toggle" data-tut="venue-favorite">
                <span class="setting__text"><span class="setting__title">Favorite</span></span>
                <span class="switch">
                    <input class="switch__input" type="checkbox" checked="@d.IsFavorite" @onchange="() => ToggleFavoriteAsync(d)" />
                    <span class="switch__track"><span class="switch__thumb"></span></span>
                </span>
            </label>
        </div>

        <div class="venue-detail__info">
            <div class="venue-detail__info-row">
                <span class="venue-detail__info-label">KaraFun Id</span>
                <span class="venue-detail__info-value">@(string.IsNullOrWhiteSpace(d.KaraFunVenueId) ? "Not set" : d.KaraFunVenueId)</span>
            </div>
            @if (!string.IsNullOrWhiteSpace(d.Notes))
            {
                <div class="venue-detail__info-row">
                    <span class="venue-detail__info-label">Notes</span>
                    <span class="venue-detail__info-value">@d.Notes</span>
                </div>
            }
        </div>

        @{ var h = History(d); }
        <div class="venue-detail__history" data-tut="venue-history">
            <div class="venue-detail__history-title">Your history here</div>
            @if (h.Sings == 0)
            {
                <div class="venue-detail__empty">You haven't logged a sing here yet.</div>
            }
            else
            {
                <div class="venue-stats">
                    <div class="venue-stat"><span class="venue-stat__num">@h.Sings</span><span class="venue-stat__lbl">sing@(h.Sings == 1 ? "" : "s")</span></div>
                    <div class="venue-stat"><span class="venue-stat__num">@(h.Average?.ToString("0.0") ?? "—")</span><span class="venue-stat__lbl">avg here</span></div>
                    <div class="venue-stat"><span class="venue-stat__num">@(h.LastSung?.LocalDateTime.ToString("MMM d") ?? "—")</span><span class="venue-stat__lbl">last sung</span></div>
                </div>

                @if (h.GoTo.Count > 0)
                {
                    <div class="venue-detail__subhead">Go-to songs here</div>
                    <ul class="venue-songlist">
                        @foreach (var g in h.GoTo)
                        {
                            <li><span class="venue-songlist__title">@g.Title</span><span class="venue-songlist__meta">@g.Average.ToString("0.0")★ · @g.Count sing@(g.Count == 1 ? "" : "s")</span></li>
                        }
                    </ul>
                }

                <div class="venue-detail__subhead">Recent sings here</div>
                <ul class="venue-songlist">
                    @foreach (var r in h.Recent)
                    {
                        <li><span class="venue-songlist__title">@r.Title</span><span class="venue-songlist__meta">@(r.Rating >= 1 ? $"{r.Rating}★ · " : "")@r.Date.LocalDateTime.ToString("MMM d")</span></li>
                    }
                </ul>
            }
        </div>

        <button type="button" class="btn btn-secondary venue-detail__edit" @onclick="() => OpenEdit(d)">Edit</button>
        <button type="button" class="btn btn-danger venue-detail__delete" @onclick="() => AskDelete(d)">Delete venue</button>
    </div>
}

@* ---- Undo toast after a swipe-remove ---- *@
@if (_undoVenue is not null)
{
    <div class="snackbar" role="status">
        <span class="snackbar__text">Removed &ldquo;@_undoVenue.Name&rdquo;</span>
        <button class="snackbar__action" @onclick="UndoRemoveAsync">Undo</button>
    </div>
}

@* ---- Add / edit sheet ---- *@
<VenueEditSheet Editing="_editing" IsNew="_editingIsNew" OnSave="SaveVenueAsync" OnClose="CloseEdit" />

@* ---- Delete confirm ---- *@
@if (_confirmDelete is { } del)
{
    <div class="sheet-backdrop sheet-backdrop--confirm" @onclick="CancelDelete"></div>
    <div class="confirm-pop" role="alertdialog" aria-modal="true">
        <div class="confirm-pop__title">Delete “@del.Name”?</div>
        <div class="confirm-pop__date">This removes the venue. Your sung history stays — those sings just lose the venue tag.</div>
        <div class="confirm-pop__actions">
            <button class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
            <button class="btn confirm-pop__delete" @onclick="() => ConfirmDeleteAsync(del)">Delete</button>
        </div>
    </div>
}

@code {
    private IReadOnlyList<Venue> _venues = [];
    private IReadOnlyList<SongListItem> _songs = [];
    private Venue? _detail;
    private Venue? _editing;
    private bool _editingIsNew;
    private Venue? _confirmDelete;
    private string _search = string.Empty;
    private BackButtonOverlayGuard? _backGuard;

    private ElementReference _detailSheet;
    private DotNetObjectReference<Venues>? _selfRef;
    private bool _detailBound;

    private ElementReference _swipeRoot;   // the .venue-list container swipe.js is delegated on
    private bool _swipeBound;

    // Undo-after-swipe-remove: the last removed venue (+ whether it was active, to restore that too) and a timer.
    private const int UndoWindowMs = 5000;
    private Venue? _undoVenue;
    private bool _undoWasActive;
    private CancellationTokenSource? _undoCts;

    protected override async Task OnInitializedAsync()
    {
        _backGuard = new BackButtonOverlayGuard(BackButton,
            closeTopMost: TryCloseTopOverlay,
            notifyStateChanged: StateHasChanged);
        Store.Changed += OnChanged;
        Songs.Changed += OnChanged;
        Session.ActiveVenueChanged += OnChanged;
        Session.TutorialVenueDetailChanged += OnTutorialVenueDetail;
        await ReloadAsync();

        // Deep-link from the switcher's "＋ Add venue" opens the add sheet straight away.
        if (new Uri(Nav.Uri).Query.Contains("add=1", StringComparison.Ordinal))
            OpenAdd();

        // The tour may have asked for a venue's detail before this page mounted — reflect it now.
        ApplyTutorialVenueDetail();
    }

    // The first-run tour drives the detail sheet (to spotlight its KaraFun / toggles / history) via a session signal.
    private void OnTutorialVenueDetail(object? sender, EventArgs e) => _ = InvokeAsync(() =>
    {
        ApplyTutorialVenueDetail();
        StateHasChanged();
    });

    private void ApplyTutorialVenueDetail()
    {
        if (Session.TutorialVenueDetailId is { } id)
            _detail = _venues.FirstOrDefault(v => v.Id == id) ?? _detail;
        else if (_detail is not null)
            _detail = null;   // tour cleared the signal → close the detail it opened
    }

    private bool IsActive(Venue v) => Session.ActiveVenueId == v.Id;

    // Always plain A→Z by name (not favorites-first, not active-pinned): the Active badge marks the active venue and
    // the star marks favorites, so nothing needs to float — a fixed order keeps rows from jumping as you activate/favorite.
    private IEnumerable<Venue> Ordered()
    {
        IEnumerable<Venue> matches = string.IsNullOrWhiteSpace(_search)
            ? _venues
            : _venues.Where(v => v.Name.Contains(_search.Trim(), StringComparison.OrdinalIgnoreCase));

        return matches.OrderBy(v => v.Name, StringComparer.CurrentCultureIgnoreCase);
    }

    // Just the sung count here (KaraFun status dropped from the row); empty when nothing's been sung, so the row
    // shows only the name.
    private string SubLine(Venue v)
    {
        var count = _songs.SelectMany(s => s.Performances).Count(p => p.VenueId == v.Id);
        return count == 0 ? "" : $"Sang {count} song{(count == 1 ? "" : "s")} here";
    }

    private void OnChanged(object? sender, EventArgs e) => _ = ReloadOnUiAsync();

    private async Task ReloadOnUiAsync()
    {
        try { await InvokeAsync(ReloadAsync); }
        catch { /* best-effort refresh */ }
    }

    private async Task ReloadAsync()
    {
        _venues = await Store.GetAllAsync();
        _songs = await Songs.GetAllAsync();
        // Keep the open detail pointing at the fresh instance (e.g. after an edit), or close it if it's gone.
        if (_detail is not null)
            _detail = _venues.FirstOrDefault(v => v.Id == _detail.Id);
        StateHasChanged();
    }

    private void OpenDetail(Venue v) => _detail = v;
    private void CloseDetail() => _detail = null;

    // Tap (a stationary pointerup) from swipe.js opens the row's detail sheet; called from JS, so render explicitly.
    [JSInvokable]
    public Task OpenDetailById(string id)
    {
        if (Guid.TryParse(id, out var guid))
        {
            var v = _venues.FirstOrDefault(x => x.Id == guid);
            if (v is not null)
            {
                OpenDetail(v);
                StateHasChanged();
            }
        }
        return Task.CompletedTask;
    }

    // Press-and-hold from swipe.js sets the row's venue active — the gesture replaces the old radio dot, so the
    // haptic tick is the only signal the hold registered before the row re-renders. Called from JS, so render
    // explicitly.
    [JSInvokable]
    public Task SetActiveById(string id)
    {
        if (Guid.TryParse(id, out var guid))
        {
            var v = _venues.FirstOrDefault(x => x.Id == guid);
            if (v is not null && !IsActive(v))
            {
                SetActive(v);
                Haptics.LongPress();
                StateHasChanged();
            }
        }
        return Task.CompletedTask;
    }

    // A commit-swipe from swipe.js removes the venue immediately and offers a few-second undo (mirrors My Songs).
    [JSInvokable]
    public async Task RemoveById(string id)
    {
        if (!Guid.TryParse(id, out var guid))
            return;

        var removed = _venues.FirstOrDefault(v => v.Id == guid);
        if (removed is null)
            return;

        var wasActive = Session.ActiveVenueId == guid;
        if (wasActive)
            Session.SetActiveVenue(null);   // don't leave the active pointer on a deleted venue

        await Store.RemoveAsync(guid);
        ShowUndo(removed, wasActive);
    }

    private void ShowUndo(Venue venue, bool wasActive)
    {
        _undoCts?.Cancel();
        _undoCts = new CancellationTokenSource();
        _undoVenue = venue;
        _undoWasActive = wasActive;
        _ = DismissUndoAfterDelay(_undoCts.Token);
    }

    private async Task DismissUndoAfterDelay(CancellationToken token)
    {
        try { await Task.Delay(UndoWindowMs, token); }
        catch (TaskCanceledException) { return; }   // superseded by a newer removal or an Undo

        _undoVenue = null;
        await InvokeAsync(StateHasChanged);
    }

    private async Task UndoRemoveAsync()
    {
        _undoCts?.Cancel();
        var venue = _undoVenue;
        var wasActive = _undoWasActive;
        _undoVenue = null;
        if (venue is null)
            return;

        // Id is preserved, so it re-lands in its alphabetical slot; restore the active pointer if it held it.
        await Store.AddAsync(venue);
        if (wasActive)
            Session.SetActiveVenue(venue.Id, pinned: true);
    }

    // Bind pull-down-to-dismiss on the detail sheet (same interop as the song detail / rating sheets). The element
    // remounts each open, so re-bind then and reset the flag when it's hidden.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Swipe-left-to-remove on the venue rows (same interop as My Songs). The .venue-list container unmounts when
        // a search matches nothing, so re-bind against the fresh element on the next mount.
        var listShown = _venues.Count > 0 && Ordered().Any();
        if (listShown && !_swipeBound)
        {
            _selfRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("khSwipe.register", _swipeRoot, _selfRef,
                new { idAttr = "data-venue-id", swipingClass = "venue-row--swiping", tapMethod = "OpenDetailById", removeMethod = "RemoveById", holdMethod = "SetActiveById" });
            _swipeBound = true;
        }
        else if (!listShown)
        {
            _swipeBound = false;
        }

        if (_detail is not null && !_detailBound)
        {
            _selfRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("khSheet.register", _detailSheet, _selfRef, new { closeMethod = "CloseDetailFromSwipe" });
            _detailBound = true;
        }
        else if (_detail is null)
        {
            _detailBound = false;
        }
    }

    // Pull-down-to-dismiss from khSheet (the sheet already animated off-screen): just clear the detail.
    [JSInvokable]
    public void CloseDetailFromSwipe()
    {
        _detail = null;
        StateHasChanged();
    }

    // A manual pick pins the venue so the periodic geo re-check won't override it.
    private void SetActive(Venue v) => Session.SetActiveVenue(v.Id, pinned: true);

    // Pinned either way (a manual pick), same as a press-and-hold on the list row.
    private void ToggleActive(Venue v) => Session.SetActiveVenue(IsActive(v) ? null : v.Id, pinned: true);

    private Task OpenCatalogAsync(Venue v) =>
        string.IsNullOrWhiteSpace(v.KaraFunVenueId)
            ? Task.CompletedTask
            : Links.OpenAsync(KaraFunSearch.CatalogUrlFor(v.KaraFunVenueId));

    private async Task ToggleFavoriteAsync(Venue v)
    {
        v.IsFavorite = !v.IsFavorite;
        await Store.UpdateAsync(v);
    }

    // ---- Add / edit ----
    private void OpenAdd()
    {
        _editing = new Venue();
        _editingIsNew = true;
    }

    // Edit a COPY so Cancel leaves the stored venue untouched; the store replaces by id on save.
    private void OpenEdit(Venue v)
    {
        _editing = Clone(v);
        _editingIsNew = false;
    }

    private void CloseEdit()
    {
        _editing = null;
    }

    private async Task SaveVenueAsync(Venue v)
    {
        if (_editingIsNew)
            await Store.AddAsync(v);
        else
            await Store.UpdateAsync(v);
        _editing = null;
    }

    private static Venue Clone(Venue v) => new()
    {
        Id = v.Id,
        Name = v.Name,
        Glyph = v.Glyph,
        KaraFunVenueId = v.KaraFunVenueId,
        Latitude = v.Latitude,
        Longitude = v.Longitude,
        IsFavorite = v.IsFavorite,
        ShowInSwitcher = v.ShowInSwitcher,
        Notes = v.Notes,
        AddedAt = v.AddedAt,
    };

    // ---- Delete ----
    private void AskDelete(Venue v) => _confirmDelete = v;
    private void CancelDelete() => _confirmDelete = null;

    private async Task ConfirmDeleteAsync(Venue v)
    {
        _confirmDelete = null;
        _detail = null;
        // Clear the active pointer if this was the active venue, so nothing stamps a now-deleted id.
        if (Session.ActiveVenueId == v.Id)
            Session.SetActiveVenue(null);
        await Store.RemoveAsync(v.Id);
    }

    // Closes the single top-most overlay, matching the CSS stacking (confirm > edit sheet > detail sheet).
    private bool TryCloseTopOverlay()
    {
        if (_confirmDelete is not null) { CancelDelete(); return true; }
        if (_editing is not null) { CloseEdit(); return true; }
        if (_detail is not null) { CloseDetail(); return true; }
        return false;
    }

    // Per-venue history is a pure derivation over venue-tagged performances — see Models/VenueHistory.
    private VenueHistory History(Venue v) => VenueHistory.ForVenue(_songs, v.Id);

    public void Dispose()
    {
        _backGuard?.Dispose();
        _selfRef?.Dispose();
        _undoCts?.Cancel();
        _undoCts?.Dispose();
        Store.Changed -= OnChanged;
        Songs.Changed -= OnChanged;
        Session.ActiveVenueChanged -= OnChanged;
        Session.TutorialVenueDetailChanged -= OnTutorialVenueDetail;
    }
}

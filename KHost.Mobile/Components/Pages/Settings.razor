@page "/settings"
@layout MainLayout
@inject IAppSettings Prefs
@inject ISongListStore Store
@inject ILyricsCache LyricsCache
@inject IAlbumArtCache AlbumArt
@inject IAppSession Session
@inject NavigationManager Nav
@implements IDisposable

<section class="settings">
    <div class="page-head">
        <NavLink class="page-back" href="" aria-label="Back to my songs">←</NavLink>
        <h1 class="page-title">Settings</h1>
    </div>

    <div class="card">
        <button type="button" class="filters-toggle settings-section" @onclick='() => Toggle("tabs")' aria-expanded="@IsOpen("tabs")">
            <span class="filters-toggle__label">Tabs</span>
            <span class="filters-toggle__chevron @(IsOpen("tabs") ? "is-open" : "")">▾</span>
        </button>
        @if (IsOpen("tabs"))
        {
        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">“Tonight” tab</span>
                <span class="setting__desc">
                    Show the Tonight tab in the bottom bar — an on-deck set you build from your list, reorder, and
                    check off as you sing. Turn off to hide the tab; with only My List left there's nothing to tab
                    between, so the whole bottom bar goes too. Your saved set is kept and comes back when you
                    re-enable it.
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.TonightEnabled" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>
        }
    </div>

    <div class="card" data-tut="settings-features">
        <button type="button" class="filters-toggle settings-section" @onclick='() => Toggle("mylist")' aria-expanded="@IsOpen("mylist")">
            <span class="filters-toggle__label">My List</span>
            <span class="filters-toggle__chevron @(IsOpen("mylist") ? "is-open" : "")">▾</span>
        </button>
        @if (IsOpen("mylist"))
        {
        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">Auto-fill year &amp; genre</span>
                <span class="setting__desc">
                    Look up a song's year and genre from iTunes and fill any blanks — when you add or open a
                    song, and after importing a list. Turn off to skip all iTunes lookups.
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.AutoFillMetadata" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>

        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">“Surprise me” button</span>
                <span class="setting__desc">
                    Show the 🎲 button that picks a random song from your list for you.
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.SurpriseEnabled" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>

        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">“Surprise me” skips today's songs</span>
                <span class="setting__desc">
                    The 🎲 random picker won't suggest a song you've already sung today (unless you've sung
                    everything on the list today).
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.SurpriseSkipSungToday" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>

        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">Scroll to song when favorited</span>
                <span class="setting__desc">
                    Tapping a song's star scrolls the list to reveal its new position (favorites move to the top).
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.ScrollToFavorited" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>

        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">Show album art on cards</span>
                <span class="setting__desc">
                    Use each song's cover (looked up from iTunes) as its card background, with a dark fade behind
                    the text. Covers are downloaded once and cached on this device — clear them from the Danger
                    zone below. Songs get a cover as you add or open them.
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.AlbumArtEnabled" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>
        }
    </div>

    <div class="card">
        <button type="button" class="filters-toggle settings-section" @onclick='() => Toggle("song")' aria-expanded="@IsOpen("song")">
            <span class="filters-toggle__label">On a song</span>
            <span class="filters-toggle__chevron @(IsOpen("song") ? "is-open" : "")">▾</span>
        </button>
        @if (IsOpen("song"))
        {
        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">“Find on YouTube” button</span>
                <span class="setting__desc">
                    Show a button on a song's detail sheet that opens a YouTube search in your browser or the YouTube app.
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.YouTubeSearchEnabled" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>

        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">“Find on Spotify” button</span>
                <span class="setting__desc">
                    Show a button on a song's detail sheet that opens a Spotify search in your browser or the Spotify app.
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.SpotifySearchEnabled" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>

        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">“Lyrics” button</span>
                <span class="setting__desc">
                    Show a button on a song's detail sheet that looks up its lyrics from LRCLIB and shows them in the app.
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.LyricsEnabled" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>

        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">Cache lyrics on this device</span>
                <span class="setting__desc">
                    Save looked-up lyrics so re-opening a song shows them instantly, without going back online.
                    Turn off to always fetch fresh. Clear the saved copies from the Danger zone below.
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.LyricsCacheEnabled" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>
        }
    </div>

    <div class="card">
        <button type="button" class="filters-toggle settings-section" @onclick='() => Toggle("singing")' aria-expanded="@IsOpen("singing")">
            <span class="filters-toggle__label">Singing &amp; ratings</span>
            <span class="filters-toggle__chevron @(IsOpen("singing") ? "is-open" : "")">▾</span>
        </button>
        @if (IsOpen("singing"))
        {
        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">Rate each performance</span>
                <span class="setting__desc">
                    Ask “how did it go?” with a star rating whenever you mark a song sung — from My List (“Mark sung”)
                    and from the Tonight tab (checking a song off). Turn off if you'd rather just log it (and jot a
                    note) without judging the performance.
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.RatePerformances" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>
        }
    </div>

    <div class="card">
        <button type="button" class="filters-toggle settings-section" @onclick='() => Toggle("app")' aria-expanded="@IsOpen("app")">
            <span class="filters-toggle__label">App</span>
            <span class="filters-toggle__chevron @(IsOpen("app") ? "is-open" : "")">▾</span>
        </button>
        @if (IsOpen("app"))
        {
        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">Notify me about new versions</span>
                <span class="setting__desc">
                    Check GitHub once at startup and show a banner when a newer version of KHost Cue is
                    available, with a link to download it. Turn off to never check.
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.UpdateCheckEnabled" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>
        }
    </div>

    <div class="card">
        <button type="button" class="filters-toggle settings-section" @onclick='() => Toggle("help")' aria-expanded="@IsOpen("help")">
            <span class="filters-toggle__label">Help</span>
            <span class="filters-toggle__chevron @(IsOpen("help") ? "is-open" : "")">▾</span>
        </button>
        @if (IsOpen("help"))
        {
        <div class="setting" data-tut="settings-replay">
            <span class="setting__text">
                <span class="setting__title">Replay the tutorial</span>
                <span class="setting__desc">
                    Show the first-run walkthrough again — the guided tour of adding songs, tonight's set,
                    importing a playlist, and these settings.
                </span>
            </span>
            <button type="button" class="btn btn-secondary" @onclick="ReplayTutorial">Replay</button>
        </div>
        }
    </div>

    <div class="card">
        <button type="button" class="filters-toggle settings-section" @onclick='() => Toggle("danger")' aria-expanded="@IsOpen("danger")">
            <span class="filters-toggle__label">Danger zone</span>
            <span class="filters-toggle__chevron @(IsOpen("danger") ? "is-open" : "")">▾</span>
        </button>
        @if (IsOpen("danger"))
        {
        <p class="setting__desc" style="margin:0.6rem 0 0.85rem">
            Empty the saved lyrics. They'll be looked up again next time you open them — nothing is lost for good.
        </p>
        <button type="button" class="btn btn-danger settings__clear" @onclick="ClearLyricsCacheAsync" disabled="@(_lyricsCacheCount == 0)">
            @(_lyricsCacheCount == 0 ? "Lyrics cache is empty" : $"Clear lyrics cache ({_lyricsCacheCount})")
        </button>

        <p class="setting__desc" style="margin:1.1rem 0 0.85rem">
            Delete the cached album-art images. They'll re-download next time you view those songs — nothing is lost.
        </p>
        <button type="button" class="btn btn-danger settings__clear" @onclick="ClearAlbumArtCacheAsync" disabled="@(_albumArtCount == 0)">
            @(_albumArtCount == 0 ? "Album art cache is empty" : $"Clear album art cache ({_albumArtCount})")
        </button>

        <p class="setting__desc" style="margin:1.1rem 0 0.85rem">
            Remove every song from your list. This can't be undone.
        </p>
        <button type="button" class="btn btn-danger settings__clear" @onclick="AskClear" disabled="@(_songCount == 0)">
            @(_songCount == 0 ? "Song list is empty" : $"Clear song list ({_songCount})")
        </button>
        }
    </div>
</section>

@if (_confirmClear)
{
    <div class="sheet-backdrop sheet-backdrop--confirm" @onclick="CancelClear"></div>
    <div class="confirm-pop" role="alertdialog" aria-modal="true">
        <div class="confirm-pop__title">Clear your whole song list?</div>
        <div class="confirm-pop__date">This removes all @_songCount song@(_songCount == 1 ? "" : "s") and can't be undone.</div>
        <div class="confirm-pop__actions">
            <button class="btn btn-secondary" @onclick="CancelClear">Cancel</button>
            <button class="btn confirm-pop__delete" @onclick="ConfirmClearAsync">Clear all</button>
        </div>
    </div>
}

@code {
    // The clear buttons are gated on / labeled with their live counts, so track both and refresh on any change.
    private int _songCount;
    private int _lyricsCacheCount;
    private int _albumArtCount;
    private bool _confirmClear;

    // Collapsible sections. Track the collapsed ones by a short id (default: all expanded, so nothing is hidden
    // on first visit); the header chevron toggles membership.
    private readonly HashSet<string> _collapsed = [];
    private bool IsOpen(string id) => !_collapsed.Contains(id);
    private void Toggle(string id) { if (!_collapsed.Add(id)) _collapsed.Remove(id); }

    protected override async Task OnInitializedAsync()
    {
        Store.Changed += OnStoreChanged;
        LyricsCache.Changed += OnStoreChanged;
        AlbumArt.Changed += OnStoreChanged;
        await RefreshCountAsync();
    }

    // Same non-async-void bridge the other pages use: marshal the reload onto the render thread and swallow failures.
    private void OnStoreChanged(object? sender, EventArgs e) => _ = RefreshFromStoreAsync();

    private async Task RefreshFromStoreAsync()
    {
        try { await InvokeAsync(RefreshCountAsync); }
        catch { /* best-effort: a failed count refresh just leaves the last-known value */ }
    }

    private async Task RefreshCountAsync()
    {
        _songCount = (await Store.GetAllAsync()).Count;
        _lyricsCacheCount = await LyricsCache.CountAsync();
        _albumArtCount = await AlbumArt.CountAsync();
        StateHasChanged();
    }

    // Cached lyrics are recoverable (they re-fetch on next open), so this clears straight away — no confirm sheet.
    private async Task ClearLyricsCacheAsync()
    {
        await LyricsCache.ClearAsync();   // LyricsCache.Changed → RefreshCountAsync updates the count + button
    }

    // Cached covers re-download on next view, so this also clears straight away — no confirm sheet.
    private async Task ClearAlbumArtCacheAsync()
    {
        await AlbumArt.ClearAsync();   // AlbumArt.Changed → RefreshCountAsync updates the count + button
    }

    private void AskClear()
    {
        if (_songCount > 0)
            _confirmClear = true;
    }

    private void CancelClear() => _confirmClear = false;

    // Re-arm the first-run tour: clear the durable "done" flag and the per-launch guard, then land on My List
    // where the tour starts (TutorialOverlay picks the navigation up via LocationChanged and kicks off).
    private void ReplayTutorial()
    {
        Prefs.TutorialCompleted = false;
        Session.TutorialResolved = false;
        Nav.NavigateTo("/");
    }

    private async Task ConfirmClearAsync()
    {
        _confirmClear = false;
        await Store.ClearAsync();   // Store.Changed → RefreshCountAsync updates the count + button
    }

    public void Dispose()
    {
        Store.Changed -= OnStoreChanged;
        LyricsCache.Changed -= OnStoreChanged;
        AlbumArt.Changed -= OnStoreChanged;
    }
}

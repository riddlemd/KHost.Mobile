@page "/settings"
@layout MainLayout
@inject IAppSettings Prefs
@inject ISongListStore Store
@inject ILyricsCache LyricsCache
@implements IDisposable

<section class="settings">
    <div class="page-head">
        <NavLink class="page-back" href="" aria-label="Back to my songs">←</NavLink>
        <h1 class="page-title">Settings</h1>
    </div>

    <div class="card">
        <div class="section-title">Song details</div>

        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">Auto-fill year &amp; genre</span>
                <span class="setting__desc">
                    Look up a song's year and genre from iTunes and fill any blanks — when you add or open a
                    song, and after importing a list. Turn off to skip all iTunes lookups.
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.AutoFillMetadata" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>

        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">“Find on YouTube” button</span>
                <span class="setting__desc">
                    Show a button on each song that opens a YouTube search in your browser or the YouTube app.
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.YouTubeSearchEnabled" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>

        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">“Find on Spotify” button</span>
                <span class="setting__desc">
                    Show a button on each song that opens a Spotify search in your browser or the Spotify app.
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.SpotifySearchEnabled" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>

        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">“Lyrics” button</span>
                <span class="setting__desc">
                    Show a button on each song that looks up its lyrics from LRCLIB and shows them in the app.
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.LyricsEnabled" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>

        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">Cache lyrics on this device</span>
                <span class="setting__desc">
                    Save looked-up lyrics so re-opening a song shows them instantly, without going back online.
                    Turn off to always fetch fresh. Clear the saved copies from the Danger zone below.
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.LyricsCacheEnabled" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>
    </div>

    <div class="card">
        <div class="section-title">Song list</div>

        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">“Tonight” set list</span>
                <span class="setting__desc">
                    Pin an on-deck set to the top of My Songs — add songs, reorder them, and check each off as you
                    sing it. Turn off to hide it; your saved set is kept and comes back when you re-enable it.
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.TonightEnabled" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>

        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">Scroll to song when favorited</span>
                <span class="setting__desc">
                    Tapping a song's star scrolls the list to reveal its new position (favorites move to the top).
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.ScrollToFavorited" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>

        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">“Surprise me” button</span>
                <span class="setting__desc">
                    Show the 🎲 button that picks a random song from your list for you.
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.SurpriseEnabled" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>

        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">“Surprise me” skips today's songs</span>
                <span class="setting__desc">
                    The 🎲 random picker won't suggest a song you've already sung today (unless you've sung
                    everything on the list today).
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.SurpriseSkipSungToday" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>

        <label class="setting">
            <span class="setting__text">
                <span class="setting__title">Rate each performance</span>
                <span class="setting__desc">
                    Ask “how did it go?” with a star rating when you mark a song sung. Turn off if you'd rather just
                    log it (and jot a note) without judging the performance.
                </span>
            </span>
            <span class="switch">
                <input class="switch__input" type="checkbox" @bind="Prefs.RatePerformances" />
                <span class="switch__track"><span class="switch__thumb"></span></span>
            </span>
        </label>
    </div>

    <div class="card">
        <div class="section-title">Danger zone</div>
        <p class="setting__desc" style="margin:0 0 0.85rem">
            Empty the saved lyrics. They'll be looked up again next time you open them — nothing is lost for good.
        </p>
        <button type="button" class="btn btn-danger settings__clear" @onclick="ClearLyricsCacheAsync" disabled="@(_lyricsCacheCount == 0)">
            @(_lyricsCacheCount == 0 ? "Lyrics cache is empty" : $"Clear lyrics cache ({_lyricsCacheCount})")
        </button>

        <p class="setting__desc" style="margin:1.1rem 0 0.85rem">
            Remove every song from your list. This can't be undone.
        </p>
        <button type="button" class="btn btn-danger settings__clear" @onclick="AskClear" disabled="@(_songCount == 0)">
            @(_songCount == 0 ? "Song list is empty" : $"Clear song list ({_songCount})")
        </button>
    </div>
</section>

@if (_confirmClear)
{
    <div class="sheet-backdrop sheet-backdrop--confirm" @onclick="CancelClear"></div>
    <div class="confirm-pop" role="alertdialog" aria-modal="true">
        <div class="confirm-pop__title">Clear your whole song list?</div>
        <div class="confirm-pop__date">This removes all @_songCount song@(_songCount == 1 ? "" : "s") and can't be undone.</div>
        <div class="confirm-pop__actions">
            <button class="btn btn-secondary" @onclick="CancelClear">Cancel</button>
            <button class="btn confirm-pop__delete" @onclick="ConfirmClearAsync">Clear all</button>
        </div>
    </div>
}

@code {
    // The clear buttons are gated on / labeled with their live counts, so track both and refresh on any change.
    private int _songCount;
    private int _lyricsCacheCount;
    private bool _confirmClear;

    protected override async Task OnInitializedAsync()
    {
        Store.Changed += OnStoreChanged;
        LyricsCache.Changed += OnStoreChanged;
        await RefreshCountAsync();
    }

    // Same non-async-void bridge the other pages use: marshal the reload onto the render thread and swallow failures.
    private void OnStoreChanged(object? sender, EventArgs e) => _ = RefreshFromStoreAsync();

    private async Task RefreshFromStoreAsync()
    {
        try { await InvokeAsync(RefreshCountAsync); }
        catch { /* best-effort: a failed count refresh just leaves the last-known value */ }
    }

    private async Task RefreshCountAsync()
    {
        _songCount = (await Store.GetAllAsync()).Count;
        _lyricsCacheCount = await LyricsCache.CountAsync();
        StateHasChanged();
    }

    // Cached lyrics are recoverable (they re-fetch on next open), so this clears straight away — no confirm sheet.
    private async Task ClearLyricsCacheAsync()
    {
        await LyricsCache.ClearAsync();   // LyricsCache.Changed → RefreshCountAsync updates the count + button
    }

    private void AskClear()
    {
        if (_songCount > 0)
            _confirmClear = true;
    }

    private void CancelClear() => _confirmClear = false;

    private async Task ConfirmClearAsync()
    {
        _confirmClear = false;
        await Store.ClearAsync();   // Store.Changed → RefreshCountAsync updates the count + button
    }

    public void Dispose()
    {
        Store.Changed -= OnStoreChanged;
        LyricsCache.Changed -= OnStoreChanged;
    }
}

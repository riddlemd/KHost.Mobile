    private void ArmRemoveSungDate(int index) => _historyConfirmIndex = index;

    private void CancelRemoveSungDate() => _historyConfirmIndex = null;

    private async Task RemoveSungDateAsync(int index)
    {
        if (_historyItem is null || index < 0 || index >= _historyItem.Performances.Count)
            return;

        _historyItem.Performances.RemoveAt(index);
        _historyConfirmIndex = null;

        if (_historyItem.Performances.Count == 0)
        {
            // Last performance gone — the song reverts to unsung: back on the wishlist.
            _historyItem.Status = SongListItemStatus.WantToSing;
            await Store.UpdateAsync(_historyItem);
            CloseHistory();
            return;
        }

        await Store.UpdateAsync(_historyItem);
    }

    // Edit one performance's "how it went" rating from the history sheet; the song's average recomputes from it.
    private async Task UpdatePerformanceRatingAsync(int index, int rating)
    {
        if (_historyItem is null || index < 0 || index >= _historyItem.Performances.Count)
            return;

        _historyItem.Performances[index].HowItWent = Math.Clamp(rating, 0, 5);
        await Store.UpdateAsync(_historyItem);
    }

    // Edit one performance's note from the history sheet (saved on blur/change).
    private async Task UpdatePerformanceNoteAsync(int index, string? note)
    {
        if (_historyItem is null || index < 0 || index >= _historyItem.Performances.Count)
            return;

        _historyItem.Performances[index].Note = string.IsNullOrWhiteSpace(note) ? null : note.Trim();
        await Store.UpdateAsync(_historyItem);
    }


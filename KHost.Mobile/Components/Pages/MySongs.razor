    private string RatingPromptHint => _ratingPromptValue switch
    {
        1 => "Not confident",
        2 => "Shaky",
        3 => "Okay",
        4 => "Confident",
        5 => "Nailed it",
        _ => "Tap a star to rate — or skip below",
    };

    private void OpenRatingPrompt()
    {

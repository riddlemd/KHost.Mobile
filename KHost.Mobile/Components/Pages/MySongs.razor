        _ratingPromptValue = 0;
        _ratingPromptNote = string.Empty;
    }

    private void CloseRatingPrompt() => _ratingPromptItem = null;

    private Task SaveRatingPromptAsync() => LogPerformanceAsync(_ratingPromptValue);

    private Task SkipRatingPromptAsync() => LogPerformanceAsync(0);

    // Pull-down-to-dismiss from khSheet: log the sing without a rating (the sheet already animated off-screen).
    [JSInvokable]
    public async Task SkipRatingPromptFromSwipe()
    {
        await LogPerformanceAsync(0);
        StateHasChanged();
    }

    // Append a performance (its how-it-went rating — or 0 when skipped — plus an optional note) and mark the song sung.
    private async Task LogPerformanceAsync(int howItWent)
    {
        if (_ratingPromptItem is null)
            return;

        _ratingPromptItem.Performances.Add(new Performance
        {
            Date = DateTimeOffset.Now,
            HowItWent = Math.Clamp(howItWent, 0, 5),
            Note = string.IsNullOrWhiteSpace(_ratingPromptNote) ? null : _ratingPromptNote.Trim(),
        });
        _ratingPromptItem.Status = SongListItemStatus.Sang;
        await Store.UpdateAsync(_ratingPromptItem);
        _ratingPromptItem = null;
    }


    // Search the active venue's KaraFun catalog. The button only renders when _activeVenueKaraFunId is set, so it's
    // always present here.
    private Task OpenKaraFunAsync() =>
        _detailItem is null || string.IsNullOrWhiteSpace(_activeVenueKaraFunId)
            ? Task.CompletedTask
            : Links.OpenAsync(KaraFunSearch.UrlFor(_activeVenueKaraFunId, _detailItem.Title, _detailItem.Artist));

    // Split-button variant of the KaraFun action: queue the song for tonight (unless it's already there), then open
    // KaraFun — the common "I'm about to sing this" move in one tap.
    private async Task AddToTonightAndOpenKaraFunAsync()
    {
        if (_detailItem is null)
            return;
        if (!IsInTonight(_detailItem))
            await Tonight.AddAsync(_detailItem.Id);
        await OpenKaraFunAsync();
    }

    // The active venue's KaraFun ID (null when there's no active venue or it has none). Tracked reactively so the
    // "Find on KaraFun" button appears/disappears as the venue is switched or its KaraFun ID is edited.
    private string? _activeVenueKaraFunId;
    private void OnVenueContextChanged(object? sender, EventArgs e) => _ = RefreshActiveVenueKaraFunAsync();

    private async Task RefreshActiveVenueKaraFunAsync()
    {
        var venue = Session.ActiveVenueId is { } id ? await Venues.GetAsync(id) : null;
        var kf = string.IsNullOrWhiteSpace(venue?.KaraFunVenueId) ? null : venue!.KaraFunVenueId;
        if (kf == _activeVenueKaraFunId)
            return;
        _activeVenueKaraFunId = kf;
        await InvokeAsync(StateHasChanged);
    }

    // ---- Lyrics sheet (LRCLIB) ---------------------------------------------------------------
    // Opens the lyrics sheet for the current song and fetches its plain lyrics fresh. State is cleared to the
    // loading view first so a re-open never flashes the previous song's lyrics; the fetch is cancellable so a
    // quick close (or reopening on another song) abandons an in-flight lookup without touching stale state.
    private async Task OpenLyricsAsync()
    {
        if (_detailItem is null)
            return;

        _lyricsItem = _detailItem;
        _lyricsText = _lyricsError = null;
        _lyricsInstrumental = false;
        _lyricsLoading = true;

        _lyricsCts?.Cancel();
        _lyricsCts?.Dispose();
        _lyricsCts = new CancellationTokenSource();
        var token = _lyricsCts.Token;

        var title = _lyricsItem.Title;
        var artist = _lyricsItem.Artist;

        try
        {
            LyricsResult? result;
            var useCache = Settings.LyricsCacheEnabled;

            // Read-through cache: a hit (including a cached "no match") skips the network; a miss fetches and
            // writes back. When caching is off, always fetch fresh and store nothing.
            if (useCache && await LyricsCache.GetAsync(title, artist) is { } hit)
            {
                result = hit.Result;
            }
            else
            {
                result = await Lyrics.FetchAsync(title, artist, token);
                if (useCache && !token.IsCancellationRequested)
                    await LyricsCache.SetAsync(title, artist, result);
            }

            if (token.IsCancellationRequested)
                return;

            if (result is null)
                _lyricsText = null;             // no match → "No lyrics found" view
            else if (result.Instrumental)
                _lyricsInstrumental = true;     // matched, but the track has no lyrics
            else
                _lyricsText = result.PlainLyrics;
        }
        catch (OperationCanceledException) { return; }   // superseded / closed — leave state to the newer open
        catch (LyricsLookupException ex) { _lyricsError = ex.Message; }
        catch { _lyricsError = "Couldn't load lyrics. Try again."; }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                _lyricsLoading = false;
                StateHasChanged();
            }
        }
    }

    private void CloseLyrics()
    {
        _lyricsCts?.Cancel();
        _lyricsItem = null;
        // Page-scroll lock is reconciled from state in OnAfterRenderAsync; detail sheet stays open behind this.
    }

    // Pull-down-to-dismiss from khSheet (the lyrics sheet already animated off-screen).
    [JSInvokable]
    public void CloseLyricsFromSwipe()
    {
        CloseLyrics();
        StateHasChanged();
    }

    private async Task AddAsync()
    {
        if (!CanAdd)
            return;

        if (IsDuplicate && !_confirmedDuplicate)
        {
            _confirmedDuplicate = true;   // arm: the next click adds it anyway
            return;
        }

        // New songs start on the wishlist (unsung). Sung-state + rating are set later from the detail sheet.
        var added = await Store.AddAsync(_title, _artist, _notes, _genre, _year);
        // AddAsync has no tags parameter — persist any in a follow-up write so the store stays simple.
        var tags = SongTags.Normalize(_tags);
        if (tags.Count > 0)
        {
            added.Tags = tags;
            await Store.UpdateAsync(added);
        }
        // Switch to newest-first so the song they just added is right at the top (favorites still float above it).
        _sort = SortColumn.Added;
        _sortDescending = true;

        _title = _artist = _notes = _genre = string.Empty;    // Store.Changed triggers the list refresh.
        _tags = [];
        _year = null;
        _confirmedDuplicate = false;
        _addOpen = false;   // collapse the form on a successful add; the new song is now visible at the top

        // Fill the new song's blank year/genre in the background so the card populates shortly after it
        // appears — the add returns immediately and doesn't block on the network. Same one-shot lookup the
        // detail sheet uses; when it lands, Store.UpdateAsync fires Changed → the list re-renders with it.
        _ = AutoFillAddedAsync(added);
    }

    // Fire-and-forget from AddAsync: swallows its own failures (a lookup must never crash the app) and is
    // cancelled if the page is disposed mid-flight. The gate lives in TryAutoFillMetadataAsync, so this is a
    // no-op when auto-fill is off or the song has no blanks to fill.
    private async Task AutoFillAddedAsync(SongListItem item)
    {
        try
        {
            await TryAutoFillMetadataAsync(item, _bgFillCts.Token);
            // If album art is on but autofill didn't capture a cover (autofill off, or nothing was blank to look
            // up), fetch it now so a newly added song gets its card background without waiting to be opened. A
            // no-op when autofill already grabbed the URL (ShouldFetchArtwork is then false — no duplicate call).
            await TryFetchArtworkUrlAsync(item, _bgFillCts.Token);
        }
        catch (OperationCanceledException) { }
        catch { /* best-effort background enrichment */ }
    }

    private async Task ToggleFavoriteAsync(SongListItem item)
    {
        item.IsFavorite = !item.IsFavorite;
        // Set before the await so the render triggered by the store change carries the pending scroll.
        if (Settings.ScrollToFavorited)
        {
            _scrollToSongId = item.Id.ToString();
            // Un-favoriting drops the song to its sorted position, which may be past the paged window; grow the
            // window to include it so the card exists in the DOM for khScroll.toSong to reach.
            var idx = Sorted().ToList().FindIndex(i => i.Id == item.Id);
            if (idx >= _renderCount)
                _renderCount = idx + 1;
        }
        await Store.UpdateAsync(item);
    }

    // The confidence-weighted "how it went" star (Bayesian shrinkage toward the whole list's average), rebuilt
    // whenever the list reloads. This is what the card star, the sort, and the rating filter buckets all read — so a
    // song with one lucky 5 doesn't outrank one with a solid ten-sing record. Null until the song's first rated sing.
    private RatingContext _ratingContext = new(null, RatingConfig.Default, default);
    private double? BayesStar(SongListItem item) => RatingScore.StarFor(item, _ratingContext);

    // Whole-star value for the red "how it went" display: the rounded Bayesian star (0 when the song has no rating).
    private int RoundedAvg(SongListItem item) =>
        BayesStar(item) is { } score ? (int)Math.Round(score, MidpointRounding.AwayFromZero) : 0;

    // Sort key for "how it went": the Bayesian star; unrated/unsung songs sort below every rated one.
    private double AvgSortKey(SongListItem item) => BayesStar(item) ?? -1;

    // A card shows its cover only when the feature is on AND the image has finished caching (in _artUris). Until
    // then the card renders normally, so nothing pops or shifts — the cover just fades in when ready.
    private bool HasArt(SongListItem item) => Settings.AlbumArtEnabled && _artUris.ContainsKey(item.Id);

    // Feed the cover's blob: URL to the card via a CSS custom property the stylesheet's ::before reads. Single-quoted
    // url() is safe: a blob: URL has no single quotes. Null (no inline style) whenever there's no cover to show.
    private string? ArtStyle(SongListItem item) =>
        HasArt(item) ? $"--kh-card-art: url('{_artUris[item.Id]}');" : null;

    // Edit the per-song enjoyment rating (blue). Independent of sung-state.
    private async Task UpdateEnjoymentAsync(SongListItem item, int rating)
    {
        item.Enjoyment = Math.Clamp(rating, 0, 5);
        await Store.UpdateAsync(item);
    }

    // Bridge the store's synchronous Changed event to async work without `async void`: a void handler hands
    // the reload to InvokeAsync, which marshals it onto the render thread (Changed can fire from a background
    // thread) and owns the continuation. Fire-and-forget by necessity — an event has nothing to await it — but
    // the task swallows its own failures so nothing is unobserved, matching the store's "don't crash" approach.
    private void OnStoreChanged(object? sender, EventArgs e) => _ = RefreshFromStoreAsync();

    private async Task RefreshFromStoreAsync()
    {
        try
        {
            await InvokeAsync(RefreshAsync);
        }
        catch
        {
            // Best-effort refresh: keep the current list on screen if a reload fails.
        }
    }

    private async Task RefreshAsync()
    {
        // A singer switch keeps this page mounted but fires the store's Changed (its file changed under it). Detect
        // it here: stash the outgoing singer's view state + stop tracking its scroll (its last position is already
        // committed under its own key), then load the incoming singer's — defaults overlaid with their saved state —
        // and re-arm the scroll restore so OnAfterRender lands their position once the new list paints.
        var current = Session.ActiveSingerId;
        if (current != _viewSinger)
        {
            SaveViewState(_viewSinger);
            _ = JS.InvokeVoidAsync("khScroll.untrack", ScrollKeyFor(_viewSinger));
            _viewSinger = current;
            ResetViewBuffers();
            RestoreViewState();
            _scrollRestored = false;
        }

        _items = await Store.GetAllAsync();
        // Rebuild the shared rating context (the list-wide prior) once per load; the recency toggle picks the config.
        _ratingContext = RatingScore.BuildContext(_items,
            RatingConfig.Default with { RecencyEnabled = Settings.RecencyWeightedRatings },
            DateTimeOffset.Now);
        RecomputeYearBounds();
        await Tonight.PruneAsync(_items.Select(i => i.Id).ToList());
        _tonight = await Tonight.GetAllAsync();
        await InvokeAsync(StateHasChanged);

        // Kick off (or refresh) the album-art load for any songs that now have a cover but no cached image yet.
        _ = LoadArtAsync();
    }

    // Serializes the background art passes: each call cancels the previous run's token, then the new run waits for
    // that run to fully unwind before starting — so only ONE loop ever mutates _artUris / the blob map at a time.
    // (Two runs overlapping could have a cancelled one revoke a blob the live one just installed, leaving a card
    // pointing at a dead blob: URL.) Fire-and-forget callers reassign this from the UI thread, so no locking is needed.
    private Task _artRun = Task.CompletedTask;

    private Task LoadArtAsync()
    {
        if (!Settings.AlbumArtEnabled)
            return Task.CompletedTask;

        _artCts?.Cancel();
        var previous = _artRun;
        _artCts = new CancellationTokenSource();
        return _artRun = LoadArtCoreAsync(previous, _artCts.Token);
    }

    // Best-effort background pass: for every PAGED song that has a cover URL but whose image isn't shown yet, fetch +
    // cache it (from the artwork CDN, not the rate-limited Search API), hand it to the WebView as a blob URL, and fade
    // it in. A no-op when album art is off or every visible cover is already loaded. Only songs that already carry an
    // ArtworkUrl are touched — discovering new URLs stays on the throttled add / detail-open paths.
    private async Task LoadArtCoreAsync(Task previous, CancellationToken token)
    {
        try { await previous; } catch { /* the prior run's own failure is its concern; we just needed it to finish */ }
        if (token.IsCancellationRequested)
            return;

        // Only the cards currently paged in — art memory is bounded by the visible page, not the whole library.
        var pending = Sorted().Take(_renderCount).Where(i => i.ArtworkUrl is not null && !_artUris.ContainsKey(i.Id)).ToList();
        foreach (var item in pending)
        {
            if (token.IsCancellationRequested)
                return;

            Stream? stream;
            try { stream = await AlbumArt.OpenArtStreamAsync(item.ArtworkUrl, token); }
            catch (OperationCanceledException) { return; }
            if (stream is null)
                continue;
            if (token.IsCancellationRequested)
            {
                stream.Dispose();
                return;
            }

            try
            {
                // Hand the bytes to JS as a stream (a byte[] arg would base64 in transit — the hop we're removing);
                // JS makes a blob: object URL. DotNetStreamReference disposes the stream once the WebView has read it.
                var objectUrl = await JS.InvokeAsync<string>("khAlbumArt.set", item.Id.ToString(), new DotNetStreamReference(stream));

                // If the list moved on while this transferred, DON'T revoke here: a superseding run may already own
                // this id, and its set() has revoked our now-stale blob. Just stop — the next run reconciles the id.
                if (token.IsCancellationRequested)
                    return;

                _artUris[item.Id] = objectUrl;
                await InvokeAsync(StateHasChanged);   // fade this one cover in without waiting for the rest
            }
            catch (OperationCanceledException) { stream.Dispose(); return; }
            catch { stream.Dispose(); /* skip a cover that won't transfer; the FileStream handle isn't leaked */ }
        }
    }

    // Tonight store changed (add/remove/reorder/complete/clear) — reload just the set and re-render.
    private void OnTonightChanged(object? sender, EventArgs e) => _ = RefreshTonightAsync();

    private async Task RefreshTonightAsync()
    {
        try
        {
            await InvokeAsync(async () =>
            {
                _tonight = await Tonight.GetAllAsync();
                StateHasChanged();
            });
        }
        catch { /* best-effort: keep the last-known set on screen if a reload fails */ }
    }

    // ---- Tonight quick-add (from the wishlist) -----------------------------------------------
    // The set itself lives on the Tonight tab; here each card / the detail sheet just toggle a song in or out.

    private bool IsInTonight(SongListItem? item) => item is not null && _tonight.Any(e => e.SongId == item.Id);

    // Card quick-add: a direct toggle (like the favorite star) — no confirm, since it's a one-tap action and
    // re-adding is just as quick. Deliberate removals-with-confirm live on the Tonight tab's set-list ✕.
    private Task QuickToggleTonightAsync(SongListItem item) =>
        IsInTonight(item) ? Tonight.RemoveAsync(item.Id) : Tonight.AddAsync(item.Id);

    private async Task ToggleDetailTonightAsync()
    {
        if (_detailItem is null)
            return;
        // The detail-sheet toggle is an explicit on/off, so no remove-confirm here.
        if (IsInTonight(_detailItem))
            await Tonight.RemoveAsync(_detailItem.Id);
        else
            await Tonight.AddAsync(_detailItem.Id);
    }

    public void Dispose()
    {
        SaveViewState(_viewSinger);
        _ = JS.InvokeVoidAsync("khScroll.untrack", ScrollKey);
        _ = JS.InvokeVoidAsync("khInfinite.disconnect");
        Store.Changed -= OnStoreChanged;
        Tonight.Changed -= OnTonightChanged;
        Session.ActiveVenueChanged -= OnVenueContextChanged;
        Venues.Changed -= OnVenueContextChanged;
        _backGuard?.Dispose();
        // Safety net: never leave the page-scroll lock on if this page is torn down with a sheet open.
        if (_pageLocked)
            _ = JS.InvokeVoidAsync("khSheet.setLock", false);
        _swipeRef?.Dispose();
        _undoCts?.Cancel();
        _undoCts?.Dispose();
        _suggestCts?.Cancel();
        _suggestCts?.Dispose();
        _lyricsCts?.Cancel();
        _lyricsCts?.Dispose();
        _bgFillCts.Cancel();
        _bgFillCts.Dispose();
        _artCts?.Cancel();
        _artCts?.Dispose();
        _ = JS.InvokeVoidAsync("khAlbumArt.revokeAll");   // free every cover's blob URL as the page tears down
    }
}

@page "/"
@using KHost.Mobile.Client.Enrichment
@using KHost.Mobile.Client.Spotify
@using KHost.Mobile.Client.YouTubeMusic
@inject ISongListStore Store
@inject ILinkLauncher Links
@inject ISpotifyImportService Spotify
@inject IYouTubeMusicImportService YtMusic
@inject ITrackMetadataLookup Metadata
@inject IJSRuntime JS
@implements IDisposable

<div class="card">
    <div class="add-head">
        <div class="section-title" style="margin:0">Add a song you'd like to sing</div>
        <div class="import-group">
            <span class="import-label">Import from</span>
            <div class="import-icons">
                <button type="button" class="import-icon-btn" @onclick="() => OpenImport(ImportSource.Spotify)"
                        title="Import from Spotify" aria-label="Import from Spotify">
                    <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true">
                        <path fill="#1ed760" d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.84-.18-.96-.6-.122-.42.18-.84.6-.96 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.302 1.141zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.481.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.42 1.56-.299.421-1.02.599-1.559.3z" />
                    </svg>
                </button>
                <button type="button" class="import-icon-btn" @onclick="() => OpenImport(ImportSource.YouTubeMusic)"
                        title="Import from YouTube Music" aria-label="Import from YouTube Music">
                    <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true">
                        <circle cx="12" cy="12" r="11" fill="#ff0000" />
                        <circle cx="12" cy="12" r="6.1" fill="#fff" />
                        <path d="M10.4 9.1 15.2 12 10.4 14.9z" fill="#ff0000" />
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <div class="field">
        <label class="field__label" for="title">Song title</label>
        <input id="title" class="input" placeholder="e.g. Bohemian Rhapsody"
               @bind="_title" @bind:event="oninput" @bind:after="OnAddFieldChanged" />
    </div>
    <div class="field">
        <label class="field__label" for="artist">Artist</label>
        <input id="artist" class="input" placeholder="e.g. Queen"
               @bind="_artist" @bind:event="oninput" @bind:after="OnAddFieldChanged" />
    </div>
    <div class="field">
        <label class="field__label" for="genre">Genre</label>
        <select id="genre" class="input" @bind="_genre">
            <option value="">Pick a genre (optional)</option>
            @foreach (var g in Genres.All)
            {
                <option value="@g">@g</option>
            }
        </select>
    </div>
    <div class="field">
        <label class="field__label" for="year">Release year <span class="field__hint">— optional</span></label>
        <input id="year" class="input num-year" type="text" inputmode="numeric" maxlength="4"
               placeholder="e.g. 1975" @bind="_year" @bind:event="oninput" />
        @if (_year.HasValue && !YearValid)
        {
            <div class="field__error">Enter a year between 1 and @CurrentYear.</div>
        }
    </div>
    <p class="autofill-note">✨ Leave Genre or Release year blank and we'll auto-fill them when you open the song.</p>

    @if (IsDuplicate)
    {
        <div class="field__warn">⚠ @DuplicateMessage</div>
    }

    <button class="btn btn-primary" @onclick="AddAsync" disabled="@(!CanAdd)">
        @(IsDuplicate && _confirmedDuplicate ? "Add anyway" : "Add to my list")
    </button>
</div>

@if (_items.Count > 0)
{
    <div class="card">
        <button type="button" class="filters-toggle" @onclick="() => _filtersOpen = !_filtersOpen" aria-expanded="@_filtersOpen">
            <span class="filters-toggle__label">
                Filter
                @if (AnyFilterActive)
                {
                    <span class="filters-badge">active</span>
                }
            </span>
            <span class="filters-toggle__chevron @(_filtersOpen ? "is-open" : "")">▾</span>
        </button>
        @if (_filtersOpen)
        {
        <div class="filters__grid" style="margin-top:0.85rem">
            <div class="field filters__field">
                <label class="field__label" for="f-name">Name</label>
                <input id="f-name" class="input input--sm" placeholder="Any title"
                       @bind="_filterName" @bind:event="oninput" />
            </div>
            <div class="field filters__field">
                <label class="field__label" for="f-artist">Artist</label>
                <input id="f-artist" class="input input--sm" placeholder="Any artist"
                       @bind="_filterArtist" @bind:event="oninput" />
            </div>
            <div class="field filters__field">
                <label class="field__label" for="f-genre">Genre</label>
                <select id="f-genre" class="input input--sm" @bind="_filterGenre">
                    <option value="">Any genre</option>
                    @foreach (var g in Genres.All)
                    {
                        <option value="@g">@g</option>
                    }
                </select>
            </div>
            <div class="field filters__field">
                <label class="field__label" for="f-rating">How it went</label>
                <select id="f-rating" class="input input--sm" @bind="_filterRating">
                    <option value="-1">Any</option>
                    <option value="0">Not rated</option>
                    <option value="1">★</option>
                    <option value="2">★★</option>
                    <option value="3">★★★</option>
                    <option value="4">★★★★</option>
                    <option value="5">★★★★★</option>
                </select>
            </div>
            @if (ShowYearFilter)
            {
                <div class="field filters__field filters__field--wide">
                    <label class="field__label">Release year</label>
                    <div class="range-row">
                        <input type="text" inputmode="numeric" maxlength="4" class="input input--sm range-num num-year"
                               value="@YearLo" @onchange="OnYearLoInput" aria-label="Earliest year" />
                        <span class="range-row__dash">–</span>
                        <input type="text" inputmode="numeric" maxlength="4" class="input input--sm range-num num-year"
                               value="@YearHi" @onchange="OnYearHiInput" aria-label="Latest year" />
                    </div>
                    <div class="range">
                        <div class="range__fill" style="left:@Pct(YearLo)%;right:@PctFromRight(YearHi)%"></div>
                        <input type="range" id="f-year-lo" class="range__input" min="@_yearMin" max="@_yearMax" step="1"
                               value="@YearLo" @oninput="OnYearLoInput" aria-label="Earliest year slider" />
                        <input type="range" id="f-year-hi" class="range__input" min="@_yearMin" max="@_yearMax" step="1"
                               value="@YearHi" @oninput="OnYearHiInput" aria-label="Latest year slider" />
                    </div>
                </div>
            }
        </div>
        @if (AnyFilterActive)
        {
            <button class="btn-link filters__clear" @onclick="ClearFilters">Clear filters</button>
        }
        }
    </div>
}

@{
    var visible = Sorted().ToList();
    _tableRendered = visible.Count > 0;
}

<div class="section-title section-title--row">
    <span>My songs (@(AnyFilterActive ? $"{visible.Count} of {_items.Count}" : $"{_items.Count}"))</span>
    @if (visible.Count > 0)
    {
        <span class="table-hint">Tap a row to open · swipe left to remove</span>
    }
</div>

@if (_items.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state__icon">🎤</div>
        <div class="empty-state__title">No songs yet</div>
        <div>Add songs you'd love to sing and they'll wait here for you.</div>
    </div>
}
else if (visible.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state__icon">🔍</div>
        <div class="empty-state__title">No matches</div>
        <div>No songs match your filters.</div>
        <button class="btn-link" style="margin-top:0.6rem" @onclick="ClearFilters">Clear filters</button>
    </div>
}
else
{
    <div class="table-scroll">
        <table class="song-table">
            <thead>
                <tr>
                    <th aria-label="Favorite"></th>
                    <th>
                        <span class="song-table__sortable" @onclick="() => SortBy(SortColumn.Title)">Song <span class="song-table__arrow">@Arrow(SortColumn.Title)</span></span>
                        <span class="song-table__sep">/</span>
                        <span class="song-table__sortable" @onclick="() => SortBy(SortColumn.Artist)">Artist <span class="song-table__arrow">@Arrow(SortColumn.Artist)</span></span>
                    </th>
                    <th class="song-table__sortable" @onclick="() => SortBy(SortColumn.Confidence)">
                        How it went <span class="song-table__arrow">@Arrow(SortColumn.Confidence)</span>
                    </th>
                </tr>
            </thead>
            <tbody @ref="_swipeRoot">
                @foreach (var item in visible)
                {
                    <tr @key="item.Id" data-song-id="@item.Id">
                        <td class="song-table__center">
                            <button type="button" class="fav-btn @(item.IsFavorite ? "is-fav" : "")"
                                    title="@(item.IsFavorite ? "Remove from favorites" : "Add to favorites")"
                                    aria-pressed="@item.IsFavorite"
                                    @onclick="() => ToggleFavoriteAsync(item)">★</button>
                        </td>
                        <td>
                            <div class="song-table__title">@item.Title</div>
                            @if (!string.IsNullOrWhiteSpace(item.Artist))
                            {
                                <div class="song-table__artist">@item.Artist</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.Genre))
                            {
                                <span class="song-table__genre">@item.Genre</span>
                            }
                            @if (item.Year.HasValue)
                            {
                                <span class="song-table__year">@item.Year</span>
                            }
                        </td>
                        <td>
                            <StarRating Value="DisplayConfidence(item)" ValueChanged="v => UpdateRatingAsync(item, v)" Sung="@item.LastSungAt.HasValue" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (_undoItem is not null)
{
    <div class="snackbar" role="status">
        <span class="snackbar__text">Removed &ldquo;@_undoItem.Title&rdquo;</span>
        <button class="snackbar__action" @onclick="UndoRemoveAsync">Undo</button>
    </div>
}

@if (_flash is not null)
{
    <div class="snackbar" role="status">
        <span class="snackbar__text">@_flash</span>
    </div>
}

@if (_importOpen)
{
    <div class="sheet-backdrop" @onclick="CloseImport"></div>
    <div class="sheet" role="dialog" aria-modal="true">
        <button type="button" class="sheet__close" @onclick="CloseImport" aria-label="Close">✕</button>
        @if (_reviewRows is not null)
        {
            <div class="sheet__title">Fill in details</div>
            <div class="sheet__subtitle">
                @(_reviewEnriching
                    ? $"Looking up {_reviewDoneCount} of {_reviewRows.Count}…"
                    : $"Found details for {_reviewRows.Count(HasApplyable)} of {_reviewRows.Count}. Review, then apply.")
            </div>
            <ul class="import-list review-list">
                @foreach (var row in _reviewRows)
                {
                    <li class="import-row">
                        <label class="import-row__label">
                            @if (row.Done && HasApplyable(row))
                            {
                                <input type="checkbox" @bind="row.Selected" />
                            }
                            else
                            {
                                <span class="review-spacer"></span>
                            }
                            <span class="import-row__text">
                                <span class="import-row__title">@row.Item.Title</span>
                                <span class="import-row__artist">@row.Item.Artist</span>
                            </span>
                            <span class="review-result">
                                @if (!row.Done)
                                {
                                    <span class="sheet__muted">…</span>
                                }
                                else if (HasApplyable(row))
                                {
                                    @ReviewSummary(row)
                                }
                                else
                                {
                                    <span class="sheet__muted">no match</span>
                                }
                            </span>
                        </label>
                    </li>
                }
            </ul>
            <div class="sheet__actions">
                <button class="btn btn-secondary" @onclick="SkipReview">Skip</button>
                <button class="btn btn-primary" @onclick="ApplyReviewAsync" disabled="@(_reviewSelectedCount == 0)">
                    Apply @_reviewSelectedCount
                </button>
            </div>
        }
        else
        {
        <div class="sheet__title">Import from @SourceName</div>
        <div class="sheet__subtitle">Paste a public playlist link — we'll pull in the song titles &amp; artists.</div>

        <div class="field" style="margin-top:0.85rem">
            <label class="field__label" for="imp-url">Playlist link</label>
            <input id="imp-url" class="input" placeholder="@SourcePlaceholder"
                   @bind="_importUrl" @bind:event="oninput" />
        </div>

        @if (_importError is not null)
        {
            <div class="field__error">@_importError</div>
        }

        @if (_importRows is null)
        {
            <button class="btn btn-primary" @onclick="FetchImportAsync"
                    disabled="@(_importBusy || string.IsNullOrWhiteSpace(_importUrl))">
                @(_importBusy ? "Fetching…" : "Fetch playlist")
            </button>
        }
        else
        {
            <div class="import-head">
                <span class="import-head__name">@_importName</span>
                <span class="import-head__actions">
                    <button class="btn-link" @onclick="SelectAllImport">All</button>
                    <button class="btn-link" @onclick="SelectNoneImport">None</button>
                </span>
            </div>
            @if (_importTruncated)
            {
                <div class="field__hint">Showing the first 100 tracks — longer playlists are trimmed.</div>
            }
            <ul class="import-list">
                @foreach (var row in _importRows)
                {
                    <li class="import-row @(row.AlreadyInList ? "is-dupe" : "")">
                        <label class="import-row__label">
                            <input type="checkbox" @bind="row.Selected" />
                            <span class="import-row__text">
                                <span class="import-row__title">@row.Title</span>
                                <span class="import-row__artist">@row.Artist</span>
                            </span>
                            @if (row.AlreadyInList)
                            {
                                <span class="import-row__badge">already added</span>
                            }
                        </label>
                    </li>
                }
            </ul>
            <div class="sheet__actions">
                <button class="btn btn-secondary" @onclick="CloseImport">Cancel</button>
                <button class="btn btn-primary" @onclick="ImportSelectedAsync"
                        disabled="@(_importBusy || _selectedImportCount == 0)">
                    @(_importBusy ? "Importing…" : $"Import {_selectedImportCount} song{(_selectedImportCount == 1 ? "" : "s")}")
                </button>
            </div>
        }
        }
    </div>
}

@if (_detailItem is not null)
{
    <div class="sheet-backdrop" @onclick="CloseDetail"></div>
    <div class="sheet" role="dialog" aria-modal="true">
        <button type="button" class="sheet__close" @onclick="CloseDetail" aria-label="Close">✕</button>

        @if (!_editing)
        {
            <div class="sheet__title">@_detailItem.Title</div>
            @if (!string.IsNullOrWhiteSpace(_detailItem.Artist))
            {
                <div class="sheet__subtitle">@_detailItem.Artist</div>
            }
            <div class="sheet__rows">
                <div class="sheet__row">
                    <span class="sheet__key">Genre</span>
                    <span class="sheet__val">
                        @if (!string.IsNullOrWhiteSpace(_detailItem.Genre))
                        {
                            @_detailItem.Genre
                        }
                        else
                        {
                            <span class="sheet__muted">@(_suggestionLoading ? "…" : "—")</span>
                        }
                    </span>
                </div>
                <div class="sheet__row">
                    <span class="sheet__key">Year</span>
                    <span class="sheet__val">
                        @if (_detailItem.Year.HasValue)
                        {
                            @_detailItem.Year
                        }
                        else
                        {
                            <span class="sheet__muted">@(_suggestionLoading ? "…" : "—")</span>
                        }
                    </span>
                </div>
                <div class="sheet__row">
                    <span class="sheet__key">Rating</span>
                    <span class="sheet__val">
                        <StarRating Value="DisplayConfidence(_detailItem)" ValueChanged="v => UpdateRatingAsync(_detailItem, v)" Sung="@_detailItem.LastSungAt.HasValue" />
                    </span>
                </div>
                <div class="sheet__row">
                    <span class="sheet__key">Notes</span>
                    <span class="sheet__val">@(string.IsNullOrWhiteSpace(_detailItem.Notes) ? "—" : _detailItem.Notes)</span>
                </div>
                <div class="sheet__row">
                    <span class="sheet__key">Last sung</span>
                    <span class="sheet__val">
                        @if (_detailItem.LastSungAt.HasValue)
                        {
                            <button class="btn-link sheet__history-link" @onclick="OpenHistory">
                                @_detailItem.LastSungAt.Value.ToString("MMM d, yyyy · h:mm tt")
                                <span class="sheet__history-count">(@_detailItem.SungDates.Count)</span>
                            </button>
                        }
                        else
                        {
                            <span class="sheet__muted">never</span>
                        }
                    </span>
                    <button class="btn btn-secondary sheet__sang-btn" @onclick="MarkSungTodayAsync">
                        @(_detailItem.LastSungAt.HasValue ? "Sang today" : "Mark sung")
                    </button>
                </div>
                <div class="sheet__row">
                    <span class="sheet__key">Added</span>
                    <span class="sheet__val">@_detailItem.AddedAt.ToString("MMM d, yyyy")</span>
                </div>
            </div>
            @if (_autoFilledNote is not null)
            {
                <div class="suggest-match">@_autoFilledNote</div>
            }
            <button class="btn sheet__youtube" @onclick="OpenYouTubeAsync">▶ Find on YouTube</button>
            <div class="sheet__actions">
                <button class="btn btn-primary" @onclick="StartEdit">Edit</button>
            </div>
        }
        else
        {
            <div class="sheet__title">Edit song</div>
            <div class="field">
                <label class="field__label" for="e-title">Song title</label>
                <input id="e-title" class="input" @bind="_editTitle" @bind:event="oninput" />
            </div>
            <div class="field">
                <label class="field__label" for="e-artist">Artist</label>
                <input id="e-artist" class="input" @bind="_editArtist" @bind:event="oninput" />
            </div>
            <div class="field">
                <label class="field__label" for="e-genre">Genre</label>
                <select id="e-genre" class="input" @bind="_editGenre">
                    <option value="">Pick a genre (optional)</option>
                    @foreach (var g in Genres.All)
                    {
                        <option value="@g">@g</option>
                    }
                </select>
            </div>
            <div class="field">
                <label class="field__label" for="e-year">Release year <span class="field__hint">— optional</span></label>
                <input id="e-year" class="input num-year" type="text" inputmode="numeric" maxlength="4"
                       @bind="_editYear" @bind:event="oninput" />
                @if (_editYear.HasValue && !EditYearValid)
                {
                    <div class="field__error">Enter a year between 1 and @CurrentYear.</div>
                }
            </div>
            <div class="field">
                <label class="field__label" for="e-notes">Notes</label>
                <textarea id="e-notes" class="input sheet__notes" rows="3"
                          placeholder="e.g. start slow, key of G" @bind="_editNotes" @bind:event="oninput"></textarea>
            </div>
            <div class="sheet__actions">
                <button class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
                <button class="btn btn-primary" @onclick="SaveEditAsync" disabled="@(!CanSaveEdit)">Save</button>
            </div>
        }
    </div>
}

@if (_historyItem is not null)
{
    <div class="sheet-backdrop sheet-backdrop--history" @onclick="CloseHistory"></div>
    <div class="sheet sheet--history" role="dialog" aria-modal="true">
        <button type="button" class="sheet__close" @onclick="CloseHistory" aria-label="Close">✕</button>
        <div class="sheet__title">Sung history</div>
        <div class="sheet__subtitle">@_historyItem.Title</div>

        <div class="history">
            <table class="history__table">
                <tbody>
                    @foreach (var (date, index) in _historyItem.SungDates
                        .Select((d, i) => (d, i))
                        .OrderByDescending(x => x.d))
                    {
                        <tr class="history__row">
                            <td class="history__date">@date.ToString("MMM d, yyyy · h:mm tt")</td>
                            <td class="history__action">
                                <button class="history__remove" @onclick="() => ArmRemoveSungDate(index)" aria-label="Remove this date">✕</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_historyItem is not null && _historyConfirmIndex is { } confirmIndex && confirmIndex < _historyItem.SungDates.Count)
{
    <div class="sheet-backdrop sheet-backdrop--confirm" @onclick="CancelRemoveSungDate"></div>
    <div class="confirm-pop" role="alertdialog" aria-modal="true">
        <div class="confirm-pop__title">Remove this date?</div>
        <div class="confirm-pop__date">@_historyItem.SungDates[confirmIndex].ToString("MMM d, yyyy · h:mm tt")</div>
        <div class="confirm-pop__actions">
            <button class="btn btn-secondary" @onclick="CancelRemoveSungDate">Cancel</button>
            <button class="btn confirm-pop__delete" @onclick="() => RemoveSungDateAsync(confirmIndex)">Remove</button>
        </div>
    </div>
}

@code {
    private IReadOnlyList<SongListItem> _items = [];
    private string _title = string.Empty;
    private string _artist = string.Empty;
    private string _notes = string.Empty;
    private string _genre = string.Empty;
    private int? _year;        // release year; null = unset

    // Filters (empty text / -1 rating = no filter). Rating: -1 Any, 0 Unsung, 1-5 stars.
    private string _filterName = string.Empty;
    private string _filterArtist = string.Empty;
    private string _filterGenre = string.Empty;
    private int _filterRating = -1;
    private bool _filtersOpen;   // collapsed by default so the filter bar stays compact

    // Year range slider. Handles are null until the user drags them, then they follow the selection;
    // the effective bounds are the min/max release year present across dated songs (recomputed on refresh).
    private int? _filterYearLo;
    private int? _filterYearHi;
    private int _yearMin;
    private int _yearMax;
    private int _yearDistinctCount;

    private enum SortColumn { Added, Title, Artist, Confidence }
    private SortColumn _sort = SortColumn.Added;
    private bool _sortDescending = true;   // default: newest added first

    // Swipe-to-remove wiring: the JS module is delegated on the stable <tbody> element.
    private ElementReference _swipeRoot;
    private DotNetObjectReference<MySongs>? _swipeRef;
    private bool _tableRendered;
    private bool _swipeBound;

    // Undo-after-swipe-remove: the last removed item + a timer to expire the offer.
    private const int UndoWindowMs = 5000;
    private SongListItem? _undoItem;
    private CancellationTokenSource? _undoCts;
    private bool _rangeBound;   // anti-cross clamp bound to the current year-slider inputs

    // Song detail / edit sheet (opened by tapping a row).
    private SongListItem? _detailItem;
    private bool _editing;
    private bool _editFieldsBound;   // khNumeric bound to the edit-form year input
    private string _editTitle = string.Empty;
    private string _editArtist = string.Empty;
    private string _editGenre = string.Empty;
    private string _editNotes = string.Empty;
    private int? _editYear;

    // Detail-view metadata auto-fill: when the sheet opens on a not-yet-looked-up song with a blank
    // year/genre, we look it up, fill the blank(s) straight from the match, and note what we filled.
    private bool _suggestionLoading;
    private string? _autoFilledNote;
    private CancellationTokenSource? _suggestCts;

    // Playlist import sheet (Spotify or YouTube Music). _importRows is null until a fetch succeeds.
    private enum ImportSource { Spotify, YouTubeMusic }
    private ImportSource _importSource;
    private bool _importOpen;
    private string _importUrl = string.Empty;
    private bool _importBusy;
    private string? _importError;
    private string? _importName;
    private bool _importTruncated;
    private List<ImportRow>? _importRows;
    private int _selectedImportCount => _importRows?.Count(r => r.Selected) ?? 0;

    // Post-import review: after songs are added, enrich them in the background (throttled to respect the
    // lookup rate limit) and let the user apply the found year/genre in bulk. Null = no review in progress.
    private List<ReviewRow>? _reviewRows;
    private bool _reviewEnriching;
    private int _reviewDoneCount;
    private CancellationTokenSource? _reviewCts;
    private int _reviewSelectedCount => _reviewRows?.Count(r => r.Done && HasApplyable(r) && r.Selected) ?? 0;

    // One reviewed song: the persisted item + its suggestion once looked up.
    private sealed class ReviewRow
    {
        public required SongListItem Item { get; init; }
        public TrackMetadata? Suggestion { get; set; }
        public bool Done { get; set; }        // lookup finished (hit or miss)
        public bool Selected { get; set; } = true;
    }

    // A review row is applyable when its lookup produced a year or a mappable genre to fill.
    private bool HasApplyable(ReviewRow row) =>
        row.Suggestion is not null &&
        (row.Suggestion.Year.HasValue || MapGenre(row.Suggestion.Genre) is not null);

    private string ReviewSummary(ReviewRow row)
    {
        var parts = new List<string>();
        if (row.Suggestion?.Year is int y) parts.Add(y.ToString());
        if (MapGenre(row.Suggestion?.Genre) is string g) parts.Add(g);
        return string.Join(" · ", parts);
    }

    private string SourceName => _importSource == ImportSource.Spotify ? "Spotify" : "YouTube Music";
    private string SourcePlaceholder => _importSource == ImportSource.Spotify
        ? "https://open.spotify.com/playlist/…"
        : "https://music.youtube.com/playlist?list=…";

    // Transient toast (import result), shown in the snackbar slot; auto-dismisses.
    private string? _flash;
    private CancellationTokenSource? _flashCts;

    // Source-agnostic preview row: both Spotify and YT Music fetches are projected to title + artist.
    private sealed class ImportRow
    {
        public required string Title { get; init; }
        public required string Artist { get; init; }
        public bool Selected { get; set; }
        public bool AlreadyInList { get; init; }
    }

    // A release year is optional, but when supplied it must be a real year: 1..this year.
    private static int CurrentYear => DateTime.Now.Year;
    private bool YearValid => !_year.HasValue || (_year.Value >= 1 && _year.Value <= CurrentYear);

    private bool CanAdd => !string.IsNullOrWhiteSpace(_title) && YearValid;

    // Duplicate guard: an existing song with the same title + artist (trimmed, case-insensitive).
    // Non-blocking — the first Add on a match arms an "Add anyway" confirm; editing a field disarms it.
    private bool _confirmedDuplicate;

    private bool IsDuplicate =>
        !string.IsNullOrWhiteSpace(_title) &&
        _items.Any(i =>
            string.Equals(i.Title.Trim(), _title.Trim(), StringComparison.OrdinalIgnoreCase) &&
            string.Equals(i.Artist.Trim(), _artist.Trim(), StringComparison.OrdinalIgnoreCase));

    private string DuplicateMessage =>
        string.IsNullOrWhiteSpace(_artist)
            ? $"You already have \"{_title.Trim()}\" in your list."
            : $"You already have \"{_title.Trim()}\" by {_artist.Trim()} in your list.";

    private void OnAddFieldChanged() => _confirmedDuplicate = false;

    // Same year rule for the edit sheet; Save needs a title and a valid year.
    private bool EditYearValid => !_editYear.HasValue || (_editYear.Value >= 1 && _editYear.Value <= CurrentYear);
    private bool CanSaveEdit => !string.IsNullOrWhiteSpace(_editTitle) && EditYearValid;

    private void SortBy(SortColumn column)
    {
        if (_sort == column)
        {
            _sortDescending = !_sortDescending;
        }
        else
        {
            _sort = column;
            // Sensible default direction: dates/rating high-first, text A-Z.
            _sortDescending = column is SortColumn.Added or SortColumn.Confidence;
        }
    }

    private string Arrow(SortColumn column) => _sort == column ? (_sortDescending ? "▼" : "▲") : "";

    // Year filter: only offered when there are 2+ distinct release years to span. The effective handle
    // positions clamp to [min, max]; a null handle sits at the corresponding bound (i.e. not narrowed).
    private bool ShowYearFilter => _yearDistinctCount >= 2;
    private int YearLo => Math.Clamp(_filterYearLo ?? _yearMin, _yearMin, _yearMax);
    private int YearHi => Math.Clamp(_filterYearHi ?? _yearMax, _yearMin, _yearMax);
    private bool YearFilterActive => ShowYearFilter && (YearLo > _yearMin || YearHi < _yearMax);

    private void OnYearLoInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
            _filterYearLo = Math.Min(Math.Clamp(v, _yearMin, _yearMax), YearHi);   // never cross the high handle
    }

    private void OnYearHiInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
            _filterYearHi = Math.Max(Math.Clamp(v, _yearMin, _yearMax), YearLo);   // never cross the low handle
    }

    // Handle position as a % of the track, for the selected-range fill. Invariant culture so CSS never gets a comma.
    private string Pct(int value) =>
        (_yearMax > _yearMin ? (value - _yearMin) * 100.0 / (_yearMax - _yearMin) : 0)
            .ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
    private string PctFromRight(int value) =>
        (_yearMax > _yearMin ? (_yearMax - value) * 100.0 / (_yearMax - _yearMin) : 0)
            .ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    // Recompute the year bounds from the current list; keep any active selection inside the new range.
    private void RecomputeYearBounds()
    {
        var years = _items.Where(i => i.Year.HasValue).Select(i => i.Year!.Value).ToList();
        _yearDistinctCount = years.Distinct().Count();
        if (years.Count > 0)
        {
            _yearMin = years.Min();
            _yearMax = years.Max();
            if (_filterYearLo.HasValue) _filterYearLo = Math.Clamp(_filterYearLo.Value, _yearMin, _yearMax);
            if (_filterYearHi.HasValue) _filterYearHi = Math.Clamp(_filterYearHi.Value, _yearMin, _yearMax);
        }
    }

    private bool AnyFilterActive =>
        !string.IsNullOrWhiteSpace(_filterName) ||
        !string.IsNullOrWhiteSpace(_filterArtist) ||
        !string.IsNullOrWhiteSpace(_filterGenre) ||
        _filterRating >= 0 ||
        YearFilterActive;

    private void ClearFilters()
    {
        _filterName = _filterArtist = _filterGenre = string.Empty;
        _filterRating = -1;
        _filterYearLo = _filterYearHi = null;
    }

    private IEnumerable<SongListItem> Filtered()
    {
        IEnumerable<SongListItem> q = _items;

        if (!string.IsNullOrWhiteSpace(_filterName))
            q = q.Where(i => i.Title.Contains(_filterName.Trim(), StringComparison.OrdinalIgnoreCase));
        if (!string.IsNullOrWhiteSpace(_filterArtist))
            q = q.Where(i => i.Artist.Contains(_filterArtist.Trim(), StringComparison.OrdinalIgnoreCase));
        if (!string.IsNullOrWhiteSpace(_filterGenre))
            q = q.Where(i => (i.Genre ?? string.Empty).Contains(_filterGenre.Trim(), StringComparison.OrdinalIgnoreCase));
        if (_filterRating >= 0)
            q = q.Where(i => DisplayConfidence(i) == _filterRating);
        if (YearFilterActive)
            q = q.Where(i => i.Year.HasValue && i.Year.Value >= YearLo && i.Year.Value <= YearHi);

        return q;
    }

    private IEnumerable<SongListItem> Sorted()
    {
        var filtered = Filtered();
        IEnumerable<SongListItem> ascending = _sort switch
        {
            SortColumn.Title => filtered.OrderBy(i => i.Title, StringComparer.OrdinalIgnoreCase),
            SortColumn.Artist => filtered.OrderBy(i => i.Artist, StringComparer.OrdinalIgnoreCase),
            SortColumn.Confidence => filtered.OrderBy(DisplayConfidence),
            _ => filtered.OrderBy(i => i.AddedAt),
        };
        var ordered = _sortDescending ? ascending.Reverse() : ascending;
        // Favorites always float to the top, whatever the active sort/direction is.
        // OrderBy is a stable sort, so the chosen order is preserved within each group.
        return ordered.OrderBy(i => i.IsFavorite ? 0 : 1);
    }

    protected override async Task OnInitializedAsync()
    {
        Store.Changed += OnStoreChanged;
        await RefreshAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("khNumeric.register");   // add-form year input

        if (_tableRendered && !_swipeBound)
        {
            _swipeRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("khSwipe.register", _swipeRoot, _swipeRef);
            _swipeBound = true;
        }
        else if (!_tableRendered)
        {
            // Table unmounted (list emptied) — the next mount is a fresh <tbody> that needs rebinding.
            _swipeBound = false;
        }

        // Bind the anti-cross clamp whenever the year slider is on screen. It unmounts when the
        // filter is collapsed or drops below 2 distinct years, so re-bind the fresh inputs on return.
        var sliderPresent = _items.Count > 0 && _filtersOpen && ShowYearFilter;
        if (sliderPresent && !_rangeBound)
        {
            await JS.InvokeVoidAsync("khRange.register");
            await JS.InvokeVoidAsync("khNumeric.register");   // filter From/To year inputs
            _rangeBound = true;
        }
        else if (!sliderPresent)
        {
            _rangeBound = false;
        }

        // The edit sheet's year input needs the digit-only guard once it's rendered.
        if (_editing && !_editFieldsBound)
        {
            await JS.InvokeVoidAsync("khNumeric.register");
            _editFieldsBound = true;
        }
        else if (!_editing)
        {
            _editFieldsBound = false;
        }
    }

    [JSInvokable]
    public async Task RemoveById(string id)
    {
        if (!Guid.TryParse(id, out var guid))
            return;

        var removed = _items.FirstOrDefault(i => i.Id == guid);
        await Store.RemoveAsync(guid);
        if (removed is not null)
            ShowUndo(removed);
    }

    // Undo: keep the just-removed item around for a few seconds so a swipe can be taken back.
    private void ShowUndo(SongListItem item)
    {
        _undoCts?.Cancel();
        _undoCts = new CancellationTokenSource();
        _undoItem = item;
        _ = DismissUndoAfterDelay(_undoCts.Token);
        StateHasChanged();
    }

    private async Task DismissUndoAfterDelay(CancellationToken token)
    {
        try { await Task.Delay(UndoWindowMs, token); }
        catch (TaskCanceledException) { return; }   // superseded by a newer removal or an Undo

        _undoItem = null;
        await InvokeAsync(StateHasChanged);
    }

    private async Task UndoRemoveAsync()
    {
        _undoCts?.Cancel();
        var item = _undoItem;
        _undoItem = null;
        if (item is not null)
            await Store.RestoreAsync(item);   // Store.Changed → refresh puts the row back
    }

    // A tap on a row (routed from swipe.js) opens that song's detail sheet.
    [JSInvokable]
    public Task OpenDetail(string id)
    {
        if (Guid.TryParse(id, out var guid))
        {
            _detailItem = _items.FirstOrDefault(i => i.Id == guid);
            _editing = false;
            _ = LoadDetailSuggestionAsync(_detailItem);
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    // Look up a year/genre for the open song and fill any blank field straight from the match — no chip, no
    // confirmation. Runs at most once per song: gated on MetadataLookedUp, and skipped entirely when there's
    // nothing blank to fill. A transient failure returns without setting the flag, so a later open can retry.
    private async Task LoadDetailSuggestionAsync(SongListItem? item)
    {
        _suggestCts?.Cancel();
        _autoFilledNote = null;
        _suggestionLoading = false;

        if (item is null ||
            item.MetadataLookedUp ||
            string.IsNullOrWhiteSpace(item.Title) ||
            (!string.IsNullOrWhiteSpace(item.Genre) && item.Year.HasValue))
            return;

        _suggestCts = new CancellationTokenSource();
        var token = _suggestCts.Token;
        _suggestionLoading = true;
        try
        {
            TrackMetadata? meta;
            try
            {
                meta = await Metadata.LookupAsync(item.Title, item.Artist, token);
            }
            catch (MetadataLookupException)
            {
                return;   // network/rate-limit failure — leave the flag unset to retry on a later open
            }

            if (token.IsCancellationRequested || _detailItem?.Id != item.Id)
                return;

            var filled = new List<string>();
            if (string.IsNullOrWhiteSpace(item.Genre) && MapGenre(meta?.Genre) is string g)
            {
                item.Genre = g;
                filled.Add("Genre");
            }
            if (!item.Year.HasValue && meta?.Year is int y)
            {
                item.Year = y;
                filled.Add("Year");
            }

            if (filled.Count > 0)
                _autoFilledNote = $"✨ Auto-filled {JoinFields(filled)} from “{meta!.MatchedTitle} — {meta.MatchedArtist}”.";

            item.MetadataLookedUp = true;   // record the attempt (hit or miss) so we never look up again
            await Store.UpdateAsync(item);   // persist flag + any fills; Store.Changed → RefreshAsync
        }
        catch (OperationCanceledException) { return; }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                _suggestionLoading = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private void CloseDetail()
    {
        _suggestCts?.Cancel();
        _autoFilledNote = null;
        _suggestionLoading = false;
        _detailItem = null;
        _editing = false;
    }

    private void StartEdit()
    {
        if (_detailItem is null)
            return;
        _editTitle = _detailItem.Title;
        _editArtist = _detailItem.Artist;
        _editGenre = _detailItem.Genre ?? string.Empty;
        _editNotes = _detailItem.Notes ?? string.Empty;
        _editYear = _detailItem.Year;
        _editing = true;
    }

    private void CancelEdit() => _editing = false;   // discard the edit buffers, back to view mode

    // Human list: "Genre", "Genre & Year", or (3+) "A, B, & C" — Oxford comma, ampersand before the last.
    private static string JoinFields(IReadOnlyList<string> parts) => parts.Count switch
    {
        0 => string.Empty,
        1 => parts[0],
        2 => $"{parts[0]} & {parts[1]}",
        _ => $"{string.Join(", ", parts.Take(parts.Count - 1))}, & {parts[^1]}",
    };

    // Map an iTunes genre onto the app's fixed genre list (the edit field is a <select> of Genres.All,
    // so an unmapped value couldn't stick). Exact match, then a few aliases, then a contains fallback.
    private static readonly Dictionary<string, string> GenreAliases = new(StringComparer.OrdinalIgnoreCase)
    {
        ["Hip-Hop/Rap"] = "Hip Hop",
        ["Singer/Songwriter"] = "Singer-Songwriter",
        ["Holiday"] = "Christmas / Holiday",
        ["Worldwide"] = "World",
    };

    private static string? MapGenre(string? itunesGenre)
    {
        if (string.IsNullOrWhiteSpace(itunesGenre))
            return null;

        var genre = itunesGenre.Trim();

        var exact = Genres.All.FirstOrDefault(g => string.Equals(g, genre, StringComparison.OrdinalIgnoreCase));
        if (exact is not null)
            return exact;

        if (GenreAliases.TryGetValue(genre, out var alias))
            return alias;

        // e.g. "R&B/Soul" contains "R&B"; "Hip-Hop/Rap" contains "Rap".
        return Genres.All.FirstOrDefault(g => genre.Contains(g, StringComparison.OrdinalIgnoreCase));
    }

    private async Task SaveEditAsync()
    {
        if (_detailItem is null || !CanSaveEdit)
            return;

        _detailItem.Title = _editTitle.Trim();
        _detailItem.Artist = _editArtist.Trim();
        _detailItem.Genre = string.IsNullOrWhiteSpace(_editGenre) ? null : _editGenre.Trim();
        _detailItem.Notes = string.IsNullOrWhiteSpace(_editNotes) ? null : _editNotes.Trim();
        _detailItem.Year = _editYear;
        await Store.UpdateAsync(_detailItem);
        _editing = false;
    }

    private async Task MarkSungTodayAsync()
    {
        if (_detailItem is null)
            return;
        _detailItem.SungDates.Add(DateTimeOffset.Now);
        _detailItem.Status = SongListItemStatus.Sang;
        await Store.UpdateAsync(_detailItem);
    }

    // ---- Sung history sheet ------------------------------------------------------------------

    private SongListItem? _historyItem;
    private int? _historyConfirmIndex;   // index (into SungDates) whose X is armed for confirm; null = none

    private void OpenHistory()
    {
        _historyItem = _detailItem;
        _historyConfirmIndex = null;
    }

    private void CloseHistory()
    {
        _historyItem = null;
        _historyConfirmIndex = null;
    }

    private void ArmRemoveSungDate(int index) => _historyConfirmIndex = index;

    private void CancelRemoveSungDate() => _historyConfirmIndex = null;

    private async Task RemoveSungDateAsync(int index)
    {
        if (_historyItem is null || index < 0 || index >= _historyItem.SungDates.Count)
            return;

        _historyItem.SungDates.RemoveAt(index);
        _historyConfirmIndex = null;

        if (_historyItem.SungDates.Count == 0)
        {
            // Last date gone — the song reverts to unsung: back on the wishlist, rating no longer applies.
            _historyItem.Status = SongListItemStatus.WantToSing;
            _historyItem.Confidence = 0;
            await Store.UpdateAsync(_historyItem);
            CloseHistory();
            return;
        }

        await Store.UpdateAsync(_historyItem);
    }

    // Opens a YouTube search for the song in the OS browser / YouTube app (not the in-app WebView).
    private Task OpenYouTubeAsync() =>
        _detailItem is null
            ? Task.CompletedTask
            : Links.OpenAsync(YouTubeSearch.UrlFor(_detailItem.Title, _detailItem.Artist));

    // ---- Playlist import (Spotify / YouTube Music) --------------------------------------------

    private void OpenImport(ImportSource source)
    {
        _importSource = source;
        _importOpen = true;
        _importUrl = string.Empty;
        _importRows = null;
        _importError = null;
        _importName = null;
        _importTruncated = false;
        _reviewCts?.Cancel();
        _reviewRows = null;
        _reviewEnriching = false;
    }

    private void CloseImport()
    {
        _importOpen = false;
        _importBusy = false;
        _reviewCts?.Cancel();
        _reviewRows = null;
        _reviewEnriching = false;
    }

    private async Task FetchImportAsync()
    {
        if (string.IsNullOrWhiteSpace(_importUrl) || _importBusy)
            return;

        _importBusy = true;
        _importError = null;
        try
        {
            // Each source's fetch is projected to a common (name, tracks, truncated) shape.
            string? name;
            bool truncated;
            List<(string Title, string Artist)> tracks;

            if (_importSource == ImportSource.Spotify)
            {
                var result = await Spotify.FetchPlaylistAsync(_importUrl.Trim());
                name = result.Name;
                truncated = result.LikelyTruncated;
                tracks = result.Tracks.Select(t => (t.Title, t.Artist)).ToList();
            }
            else
            {
                var result = await YtMusic.FetchPlaylistAsync(_importUrl.Trim());
                name = result.Name;
                truncated = result.LikelyTruncated;
                tracks = result.Tracks.Select(t => (t.Title, t.Artist)).ToList();
            }

            _importName = string.IsNullOrWhiteSpace(name) ? "Playlist" : name;
            _importTruncated = truncated;
            _importRows = tracks.Select(t => new ImportRow
            {
                Title = t.Title,
                Artist = t.Artist,
                AlreadyInList = _items.Any(i =>
                    string.Equals(i.Title.Trim(), t.Title, StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(i.Artist.Trim(), t.Artist, StringComparison.OrdinalIgnoreCase)),
            }).ToList();

            // Pre-select everything not already in the list; leave duplicates unticked.
            foreach (var row in _importRows)
                row.Selected = !row.AlreadyInList;

            if (_importRows.Count == 0)
                _importError = "That playlist has no importable tracks.";
        }
        catch (Exception ex) when (ex is SpotifyImportException or YouTubeMusicImportException)
        {
            _importError = ex.Message;
            _importRows = null;
        }
        finally
        {
            _importBusy = false;
        }
    }

    private void SelectAllImport()
    {
        if (_importRows is null) return;
        foreach (var row in _importRows) row.Selected = true;
    }

    private void SelectNoneImport()
    {
        if (_importRows is null) return;
        foreach (var row in _importRows) row.Selected = false;
    }

    private async Task ImportSelectedAsync()
    {
        if (_importRows is null || _importBusy)
            return;

        var chosen = _importRows.Where(r => r.Selected).ToList();
        if (chosen.Count == 0)
            return;

        _importBusy = true;
        try
        {
            // Imported as unsung wishlist entries: title + artist only (no year/genre from either source).
            var toImport = chosen.Select(r => new SongListItem { Title = r.Title, Artist = r.Artist }).ToList();

            // Selection already excludes duplicates; a force-ticked duplicate is honored (skipDuplicates: false).
            var added = await Store.ImportAsync(toImport, skipDuplicates: false);   // Store.Changed → RefreshAsync
            await FlashAsync($"Imported {added} song{(added == 1 ? "" : "s")} from {SourceName}");

            // Hand off to the review phase: enrich the freshly-added songs in the background, throttled,
            // and let the user apply the found year/genre in bulk. The sheet stays open showing progress.
            _importRows = null;
            _reviewRows = toImport.Select(i => new ReviewRow { Item = i }).ToList();
            _ = StartReviewEnrichmentAsync();
        }
        finally
        {
            _importBusy = false;
        }
    }

    // Look up each freshly-imported song one at a time, spaced out to stay under the lookup rate limit.
    // Fire-and-forget from ImportSelectedAsync; cancelled if the sheet closes or a new import starts.
    private const int ReviewThrottleMs = 3000;   // ~20/min

    private async Task StartReviewEnrichmentAsync()
    {
        _reviewCts?.Cancel();
        _reviewCts = new CancellationTokenSource();
        var token = _reviewCts.Token;

        var rows = _reviewRows;
        if (rows is null)
            return;

        _reviewEnriching = true;
        _reviewDoneCount = 0;
        await InvokeAsync(StateHasChanged);

        try
        {
            for (var i = 0; i < rows.Count; i++)
            {
                token.ThrowIfCancellationRequested();
                var row = rows[i];

                // Every lookup here is a live call (these songs were just imported, so none are looked up
                // yet), so always space them out to stay under the rate limit.
                try
                {
                    row.Suggestion = await Metadata.LookupAsync(row.Item.Title, row.Item.Artist, token);
                }
                catch (MetadataLookupException)
                {
                    row.Suggestion = null;   // treat a transient failure as "no match" for this pass
                }
                row.Done = true;
                row.Selected = HasApplyable(row);
                _reviewDoneCount = i + 1;
                await InvokeAsync(StateHasChanged);

                if (i < rows.Count - 1)
                    await Task.Delay(ReviewThrottleMs, token);
            }
        }
        catch (OperationCanceledException) { return; }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                _reviewEnriching = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    // Apply the checked suggestions (blank fields only), and mark every looked-up song as done so it isn't
    // auto-looked-up again — including rows the user unchecked (their choice to skip sticks). One bulk write.
    private async Task ApplyReviewAsync()
    {
        if (_reviewRows is null)
            return;

        _reviewCts?.Cancel();
        var done = _reviewRows.Where(r => r.Done).ToList();
        var applied = 0;
        foreach (var row in done)
        {
            if (row.Selected && HasApplyable(row))
            {
                var changed = false;
                if (string.IsNullOrWhiteSpace(row.Item.Genre) && MapGenre(row.Suggestion?.Genre) is string g)
                {
                    row.Item.Genre = g;
                    changed = true;
                }
                if (!row.Item.Year.HasValue && row.Suggestion?.Year is int y)
                {
                    row.Item.Year = y;
                    changed = true;
                }
                if (changed)
                    applied++;
            }
            row.Item.MetadataLookedUp = true;   // looked up in this pass — don't auto-look-up again
        }

        await Store.UpdateRangeAsync(done.Select(r => r.Item));   // one write; Store.Changed → RefreshAsync

        _reviewRows = null;
        _reviewEnriching = false;
        _importOpen = false;
        await FlashAsync($"Filled details for {applied} song{(applied == 1 ? "" : "s")}");
    }

    // Skip applying anything. No writes — the flag stays unset, so each song still gets a fresh, per-song
    // auto-fill attempt if/when it's opened in the detail sheet later.
    private void SkipReview()
    {
        _reviewCts?.Cancel();
        _reviewRows = null;
        _reviewEnriching = false;
        _importOpen = false;
    }

    private async Task FlashAsync(string message)
    {
        _flashCts?.Cancel();
        _flashCts = new CancellationTokenSource();
        var token = _flashCts.Token;

        _flash = message;
        await InvokeAsync(StateHasChanged);

        try { await Task.Delay(3500, token); }
        catch (TaskCanceledException) { return; }   // superseded by a newer flash

        _flash = null;
        await InvokeAsync(StateHasChanged);
    }

    private async Task AddAsync()
    {
        if (!CanAdd)
            return;

        if (IsDuplicate && !_confirmedDuplicate)
        {
            _confirmedDuplicate = true;   // arm: the next click adds it anyway
            return;
        }

        // New songs start on the wishlist (unsung). Sung-state + rating are set later from the detail sheet.
        await Store.AddAsync(_title, _artist, _notes, _genre, 0, _year);
        _title = _artist = _notes = _genre = string.Empty;    // Store.Changed triggers the list refresh.
        _year = null;
        _confirmedDuplicate = false;
    }

    private async Task ToggleFavoriteAsync(SongListItem item)
    {
        item.IsFavorite = !item.IsFavorite;
        await Store.UpdateAsync(item);
    }

    // Rating is now independent of sung-state (sung ⟺ SungDates is non-empty). This is just the star value.
    private static int DisplayConfidence(SongListItem item) => item.Confidence;

    private async Task UpdateRatingAsync(SongListItem item, int rating)
    {
        item.Confidence = rating;
        if (rating >= 1)
        {
            // Rating a song also marks it sung, if it wasn't already.
            item.Status = SongListItemStatus.Sang;
            if (item.SungDates.Count == 0)
                item.SungDates.Add(DateTimeOffset.Now);
        }
        // rating == 0 clears only the rating — sung-state (SungDates/Status) is left untouched.

        await Store.UpdateAsync(item);
    }

    private async void OnStoreChanged(object? sender, EventArgs e) => await RefreshAsync();

    private async Task RefreshAsync()
    {
        _items = await Store.GetAllAsync();
        RecomputeYearBounds();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Store.Changed -= OnStoreChanged;
        _swipeRef?.Dispose();
        _undoCts?.Cancel();
        _undoCts?.Dispose();
        _flashCts?.Cancel();
        _flashCts?.Dispose();
        _suggestCts?.Cancel();
        _suggestCts?.Dispose();
        _reviewCts?.Cancel();
        _reviewCts?.Dispose();
    }
}

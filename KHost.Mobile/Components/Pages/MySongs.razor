@page "/"
@using KHost.Mobile.Clients.Deezer
@using KHost.Mobile.Clients.Enrichment
@using KHost.Mobile.Clients.Lyrics
@using Microsoft.Extensions.Logging
@inject ILogger<MySongs> Log
@inject ISongListStore Store
@inject ITonightStore Tonight
@inject ILinkLauncher Links
@inject ITrackMetadataLookup Metadata
@inject ICoverArtLookup ArtFallback
@inject ILyricsClient Lyrics
@inject ILyricsCache LyricsCache
@inject IAlbumArtCache AlbumArt
@inject IAppSettings Settings
@inject IAppSession Session
@inject IVenueStore Venues
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IBackButtonService BackButton
@implements IDisposable

@* The wishlist. "Tonight" lives on its own tab now (Components/Pages/Tonight.razor); each card here still carries
   the 🎤 quick-add so you can line a song up for tonight from the list. *@
@* Adding a song is a floating "+" (bottom-right) that opens the add sheet, so it stays reachable while scrolling
   and doesn't take a card's worth of room at the top. It tucks away whenever any sheet/overlay is open (so it never
   sits under a dim backdrop) and during the undo-toast window. data-tut="add" moved here from the old add card. *@
<button type="button" class="mysongs-fab @(Settings.TonightEnabled ? "" : "mysongs-fab--no-nav") @(AnyOverlayOpen ? "is-hidden" : "")"
        data-tut="add" aria-label="Add a song you'd like to sing" @onclick="OpenAdd">
    <span class="mysongs-fab__plus" aria-hidden="true">＋</span>
</button>

@if (_items.Count > 0)
{
    @* Search floats sticky under the header (see .mysongs-floatbar) so a new search never needs a scroll-to-top;
       active-filter pills ride along in the same sticky bar so they stay visible while scrolling. *@
    <div class="mysongs-floatbar">
        @* One bar searches song OR artist — the common case. The rest of the filters live behind the funnel. *@
        <div class="filter-search" data-tut="search">
            <span class="filter-search__icon" aria-hidden="true">🔍</span>
            <input class="filter-search__input" placeholder="Search songs or artists"
                   aria-label="Search songs or artists"
                   @bind="_filterSearch" @bind:event="oninput" />
            @if (!string.IsNullOrEmpty(_filterSearch))
            {
                <button type="button" class="filter-search__clear" aria-label="Clear search"
                        @onclick="() => _filterSearch = string.Empty">✕</button>
            }
            <button type="button" class="filter-funnel @(AnyHiddenFilterActive ? "is-on" : "")" data-tut="filter"
                    aria-label="More filters" aria-expanded="@_filterSheetOpen" @onclick="OpenFilterSheet">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 5h18l-7 8.5V21l-4-2v-5.5z" /></svg>
                @if (AnyHiddenFilterActive)
                {
                    <span class="filter-funnel__dot" aria-hidden="true"></span>
                }
            </button>
        </div>
        @{ var pills = FilterPills(); }
        @if (pills.Count > 0)
        {
            <div class="filter-pills">
                @foreach (var pill in pills)
                {
                    <button type="button" class="filter-pill" @onclick="pill.Remove"
                            aria-label="@($"Remove {pill.Label} filter")">
                        <span class="filter-pill__label">@pill.Label</span>
                        <span class="filter-pill__x" aria-hidden="true">✕</span>
                    </button>
                }
            </div>
        }
    </div>
}

@* Each active filter also shows as a removable pill above. *@
@if (_filterSheetOpen)
{
    <div class="sheet-backdrop" @onclick="CloseFilterSheet"></div>
    <div class="sheet filter-sheet" role="dialog" aria-modal="true" @ref="_filterSheet">
        <button type="button" class="sheet__close" @onclick="CloseFilterSheet" aria-label="Close">✕</button>
        <div class="sheet__title filter-sheet__title">
            <span>Filters</span>
            @if (AnyHiddenFilterActive)
            {
                <button type="button" class="btn-link filter-sheet__clear" @onclick="ClearAdvancedFilters">Clear all</button>
            }
        </div>
        <div class="filters__grid filter-sheet__grid">
            @* Multi-select filters use a native <details>/<summary> + checkboxes — no custom popover, so mobile
               WebViews render them reliably. Multiple picks within a filter are OR'd; filters still AND together. *@
            <div class="field filters__field filters__field--wide">
                <label class="field__label">Genre</label>
                <details class="msf" name="msf-filter">
                    <summary class="msf__summary">
                        <span class="msf__val @(_filterGenres.Count == 0 ? "msf__val--placeholder" : "")">@GenreSummary</span>
                        @if (_filterGenres.Count > 0)
                        {
                            <span class="msf__count">@_filterGenres.Count</span>
                        }
                        <span class="msf__chev">▾</span>
                    </summary>
                    <div class="msf__panel">
                        @foreach (var g in UsedGenres)
                        {
                            <label class="msf__opt">
                                <input type="checkbox" checked="@_filterGenres.Contains(g)"
                                       @onchange="e => SetGenreFilter(g, (bool)(e.Value ?? false))" />
                                <span>@g</span>
                            </label>
                        }
                        @if (UsedGenres.Count == 0)
                        {
                            <div class="msf__empty">No genres yet</div>
                        }
                    </div>
                </details>
            </div>
            <div class="field filters__field">
                <label class="field__label">How it went</label>
                <details class="msf" name="msf-filter">
                    <summary class="msf__summary">
                        <span class="msf__val @(_filterRatings.Count == 0 ? "msf__val--placeholder" : "")">@RatingSummary(_filterRatings)</span>
                        @if (_filterRatings.Count > 0)
                        {
                            <span class="msf__count">@_filterRatings.Count</span>
                        }
                        <span class="msf__chev">▾</span>
                    </summary>
                    <div class="msf__panel msf__panel--tall">
                        @foreach (var (val, label) in RatingOptions)
                        {
                            <label class="msf__opt">
                                <input type="checkbox" checked="@_filterRatings.Contains(val)"
                                       @onchange="e => SetRatingFilter(val, (bool)(e.Value ?? false))" />
                                <span class="@(val >= 1 ? "msf__stars msf__stars--hot" : "msf__notrated")">@label</span>
                            </label>
                        }
                    </div>
                </details>
            </div>
            <div class="field filters__field">
                <label class="field__label">Enjoyment</label>
                <details class="msf" name="msf-filter">
                    <summary class="msf__summary">
                        <span class="msf__val @(_filterEnjoyments.Count == 0 ? "msf__val--placeholder" : "")">@RatingSummary(_filterEnjoyments)</span>
                        @if (_filterEnjoyments.Count > 0)
                        {
                            <span class="msf__count">@_filterEnjoyments.Count</span>
                        }
                        <span class="msf__chev">▾</span>
                    </summary>
                    <div class="msf__panel msf__panel--tall">
                        @foreach (var (val, label) in RatingOptions)
                        {
                            <label class="msf__opt">
                                <input type="checkbox" checked="@_filterEnjoyments.Contains(val)"
                                       @onchange="e => SetEnjoymentFilter(val, (bool)(e.Value ?? false))" />
                                <span class="@(val >= 1 ? "msf__stars msf__stars--cool" : "msf__notrated")">@label</span>
                            </label>
                        }
                    </div>
                </details>
            </div>
            @if (Settings.TagsEnabled && UsedTags.Count > 0)
            {
                <div class="field filters__field filters__field--wide">
                    <label class="field__label filters__tag-label">
                        <span>Tags</span>
                        <span class="andor" role="group" aria-label="Match any or all of the selected tags">
                            <button type="button" class="andor__btn @(_tagFilterAll ? "" : "is-on")"
                                    @onclick="() => _tagFilterAll = false">Any</button>
                            <button type="button" class="andor__btn @(_tagFilterAll ? "is-on" : "")"
                                    @onclick="() => _tagFilterAll = true">All</button>
                        </span>
                    </label>
                    <details class="msf" name="msf-filter">
                        <summary class="msf__summary">
                            <span class="msf__val @(_filterTags.Count == 0 ? "msf__val--placeholder" : "")">@TagSummary</span>
                            @if (_filterTags.Count > 0)
                            {
                                <span class="msf__count">@_filterTags.Count</span>
                            }
                            <span class="msf__chev">▾</span>
                        </summary>
                        <div class="msf__panel">
                            @foreach (var t in UsedTags)
                            {
                                <label class="msf__opt">
                                    <input type="checkbox" checked="@_filterTags.Contains(t)"
                                           @onchange="e => SetTagFilter(t, (bool)(e.Value ?? false))" />
                                    <span>@t</span>
                                </label>
                            }
                        </div>
                    </details>
                </div>
            }
            @if (ShowYearFilter)
            {
                <div class="field filters__field filters__field--wide">
                    <label class="field__label">Release year</label>
                    <div class="range-row">
                        <input type="text" inputmode="numeric" maxlength="4" class="input input--sm range-num num-year"
                               value="@YearLo" @onchange="OnYearLoInput" aria-label="Earliest year" />
                        <span class="range-row__dash">–</span>
                        <input type="text" inputmode="numeric" maxlength="4" class="input input--sm range-num num-year"
                               value="@YearHi" @onchange="OnYearHiInput" aria-label="Latest year" />
                    </div>
                    <div class="range">
                        <div class="range__fill" style="left:@Pct(YearLo)%;right:@PctFromRight(YearHi)%"></div>
                        <input type="range" id="f-year-lo" class="range__input" min="@_yearMin" max="@_yearMax" step="1"
                               value="@YearLo" @oninput="OnYearLoInput" aria-label="Earliest year slider" />
                        <input type="range" id="f-year-hi" class="range__input" min="@_yearMin" max="@_yearMax" step="1"
                               value="@YearHi" @oninput="OnYearHiInput" aria-label="Latest year slider" />
                    </div>
                </div>
            }
        </div>
    </div>
}

@* Add-a-song sheet — opened by the floating "+". Same bottom-sheet + pull-to-dismiss treatment as the other sheets. *@
@if (_addOpen)
{
    <div class="sheet-backdrop" @onclick="CloseAdd"></div>
    <div class="sheet add-sheet" role="dialog" aria-modal="true" @ref="_addSheet">
        <button type="button" class="sheet__close" @onclick="CloseAdd" aria-label="Close">✕</button>
        <div class="sheet__title">Add a song you'd like to sing</div>
        <div class="field" style="margin-top:0.85rem">
            <label class="field__label" for="title">Song title</label>
            <input id="title" class="input" placeholder="e.g. Bohemian Rhapsody"
                   @bind="_title" @bind:event="oninput" @bind:after="OnAddFieldChanged" />
        </div>
        <div class="field">
            <label class="field__label" for="artist">Artist</label>
            <input id="artist" class="input" placeholder="e.g. Queen"
                   @bind="_artist" @bind:event="oninput" @bind:after="OnAddFieldChanged" />
        </div>
        <div class="field">
            <label class="field__label" for="genre">Genre <span class="autofill-star" title="We'll look this up online if you leave it blank">✨</span> <span class="field__hint">— optional</span></label>
            <select id="genre" class="input" @bind="_genre">
                <option value=""></option>
                @foreach (var g in Genres.All)
                {
                    <option value="@g">@g</option>
                }
            </select>
        </div>
        <div class="field">
            <label class="field__label" for="year">Release year <span class="autofill-star" title="We'll look this up online if you leave it blank">✨</span> <span class="field__hint">— optional</span></label>
            <input id="year" class="input num-year" type="text" inputmode="numeric" maxlength="4"
                   placeholder="e.g. 1975" @bind="_year" @bind:event="oninput" />
            @if (_year.HasValue && !YearValid)
            {
                <div class="field__error">Enter a year between 1 and @CurrentYear.</div>
            }
        </div>
        @if (Settings.TagsEnabled)
        {
            <div class="field">
                <label class="field__label">Tags <span class="field__hint">— your own labels, optional</span></label>
                <TagInput Tags="_tags" TagsChanged="v => _tags = v" Suggestions="UsedTags" />
            </div>
        }
        <p class="autofill-note">✨ Leave a starred field blank and we'll look it up online when you add the song.</p>

        @if (IsDuplicate)
        {
            <div class="field__warn">⚠ @DuplicateMessage</div>
        }

        <button class="btn btn-primary" @onclick="AddAsync" disabled="@(!CanAdd)">
            @(IsDuplicate && _confirmedDuplicate ? "Add anyway" : "Add to my songs")
        </button>
    </div>
}

@{
    var visible = Sorted().ToList();
    _visibleCount = visible.Count;
    // Any filter/sort change (a new signature) rewinds the infinite list to the first page. Favoriting / removing a
    // song doesn't change the signature, so paging holds its place. Done here (not in each handler) so it's automatic.
    var listSig = FilterSortSignature();
    if (listSig != _lastListSig) { _renderCount = PageSize; _lastListSig = listSig; _pagingReset = true; }
    var page = visible.Take(_renderCount).ToList();
    _listRendered = !_loading && visible.Count > 0;
    _artPageSig = $"{listSig}:{_renderCount}";   // OnAfterRender loads art for this page only when the signature changes
}

@if (!_loading)
{
    <div class="section-title section-title--songs">
        <span>My songs (@(AnyFilterActive ? $"{visible.Count} of {_items.Count}" : $"{_items.Count}"))</span>
        @if (Settings.SurpriseEnabled && visible.Count >= 2)
        {
            <button type="button" class="sort-bar__surprise" aria-label="Pick a random song"
                    @onclick="() => SurpriseMe(visible)">🎲 Surprise me</button>
        }
    </div>
}

@if (_loading)
{
    <div class="loading-state" role="status" aria-live="polite">
        <div class="eq" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></div>
        <div class="loading-state__title">Loading your songs…</div>
    </div>
}
else if (_items.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state__icon brand-mark">kH</div>
        <div class="empty-state__title">No songs yet</div>
        <div>Tap the <span class="empty-state__plus" aria-hidden="true">＋</span> button to add songs you'd love to sing — they'll wait here for you.</div>
    </div>
}
else if (visible.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state__icon">🔍</div>
        <div class="empty-state__title">No matches</div>
        <div>No songs match your filters.</div>
        <button class="btn-link" style="margin-top:0.6rem" @onclick="ClearFilters">Clear filters</button>
    </div>
}
else
{
    <div class="sort-bar" data-tut="sort">
        <label class="sort-bar__label" for="song-sort">Sort</label>
        <select id="song-sort" class="sort-bar__select" value="@_sort" @onchange="OnSortFieldChanged" aria-label="Sort by">
            <option value="@SortColumn.Title">Song</option>
            <option value="@SortColumn.Artist">Artist</option>
            <option value="@SortColumn.HowItWent">How it went</option>
            <option value="@SortColumn.Enjoyment">Enjoyment</option>
            <option value="@SortColumn.Added">Added</option>
        </select>
        @* Re-calling SortBy with the current field toggles its direction (same-column branch). *@
        <button type="button" class="sort-bar__dir" @onclick="() => SortBy(_sort)"
                aria-label="Toggle sort direction" title="Toggle sort direction">@(_sortDescending ? "▼" : "▲")</button>
    </div>
    <div class="song-cards" @ref="_swipeRoot">
        @foreach (var item in page)
        {
            <div class="song-card @(HasArt(item) ? "song-card--art" : "")" @key="item.Id" data-song-id="@item.Id"
                 style="@ArtStyle(item)">
                @if (Settings.TonightEnabled)
                {
                    @* data-tut is on every card's button; the tour's querySelector spotlights the first one. *@
                    <button type="button" class="tonight-add-btn song-card__tonight @(IsInTonight(item) ? "is-on" : "")"
                            data-tut="tonight-quick"
                            title="@(IsInTonight(item) ? "In tonight's set — tap to remove" : "Add to tonight")"
                            aria-pressed="@IsInTonight(item)"
                            @onclick="() => QuickToggleTonightAsync(item)">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M3 6h12M3 10h12M3 14h7" />
                            @if (IsInTonight(item))
                            {
                                <path d="M14 17.2l2.2 2.2L20.5 15" />
                            }
                            else
                            {
                                <path d="M17 14v6M14 17h6" />
                            }
                        </svg>
                    </button>
                }
                <button type="button" class="fav-btn song-card__fav @(item.IsFavorite ? "is-fav" : "")"
                        title="@(item.IsFavorite ? "Remove from favorites" : "Add to favorites")"
                        aria-pressed="@item.IsFavorite"
                        @onclick="() => ToggleFavoriteAsync(item)">★</button>
                <div class="song-card__title">@item.Title</div>
                @if (!string.IsNullOrWhiteSpace(item.Artist))
                {
                    <div class="song-card__artist">@item.Artist</div>
                }
                <div class="song-card__meta">
                    <span class="song-card__tags">
                        @if (!string.IsNullOrWhiteSpace(item.Genre))
                        {
                            <span class="song-card__genre">@item.Genre</span>
                        }
                        @if (item.Year.HasValue)
                        {
                            <span class="song-card__year">@item.Year</span>
                        }
                        @if (Settings.TagsEnabled && item.Tags.Count > 0)
                        {
                            @foreach (var tag in item.Tags.Take(CardTagLimit))
                            {
                                <span class="tag-chip">@tag</span>
                            }
                            @if (item.Tags.Count > CardTagLimit)
                            {
                                <span class="tags-more">+@(item.Tags.Count - CardTagLimit)</span>
                            }
                        }
                    </span>
                </div>
                <div class="song-card__ratings-row">
                    <span class="song-card__ratings">
                        <span class="rating-grp">
                            @if (BayesStar(item) is { } score)
                            {
                                <StarRating Value="RoundedAvg(item)" Tone="hot" Sung="true" ReadOnly="true" />
                                <span class="rating-num">@score.ToString("0.0")</span>
                            }
                            else
                            {
                                <span class="rating-num rating-num--muted">—</span>
                            }
                        </span>
                        <span class="rating-sep"></span>
                        <span class="rating-grp">
                            @if (item.Enjoyment >= 1)
                            {
                                <StarRating Value="item.Enjoyment" Tone="cool" Sung="true" ReadOnly="true" />
                            }
                            else
                            {
                                <span class="rating-num rating-num--muted">—</span>
                            }
                        </span>
                    </span>
                </div>
            </div>
        }
    </div>
    @* Infinite-scroll sentinel: while more songs remain, khInfinite watches this and loads the next page as it nears
       the viewport. Rendered only when there's more to show, so reaching it means the whole list is on screen. *@
    @if (_renderCount < _visibleCount)
    {
        <div class="song-cards__more" @ref="_sentinel" role="status" aria-label="Loading more songs">
            <div class="eq" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></div>
        </div>
    }
}

@if (_undoItem is not null)
{
    <div class="snackbar" role="status">
        <span class="snackbar__text">Removed &ldquo;@_undoItem.Title&rdquo;</span>
        <button class="snackbar__action" @onclick="UndoRemoveAsync">Undo</button>
    </div>
}

@if (_detailItem is not null)
{
    <div class="sheet-backdrop" @onclick="CloseDetail"></div>
    <div class="sheet" role="dialog" aria-modal="true" @ref="_detailSheet">
        <button type="button" class="sheet__close" @onclick="CloseDetail" aria-label="Close">✕</button>

        @if (!_editing)
        {
            <div class="sheet__header @(HasArt(_detailItem) ? "sheet__header--art" : "")" style="@ArtStyle(_detailItem)">
                <div class="sheet__title">@_detailItem.Title</div>
                @if (!string.IsNullOrWhiteSpace(_detailItem.Artist))
                {
                    <div class="sheet__subtitle">@_detailItem.Artist</div>
                }
            </div>
            <div class="sheet__rows">
                <div class="sheet__row">
                    <span class="sheet__key">Genre</span>
                    <span class="sheet__val">
                        @if (!string.IsNullOrWhiteSpace(_detailItem.Genre))
                        {
                            @_detailItem.Genre
                        }
                        else
                        {
                            <span class="sheet__muted">@(_suggestionLoading ? "…" : "—")</span>
                        }
                    </span>
                </div>
                <div class="sheet__row">
                    <span class="sheet__key">Year</span>
                    <span class="sheet__val">
                        @if (_detailItem.Year.HasValue)
                        {
                            @_detailItem.Year
                        }
                        else
                        {
                            <span class="sheet__muted">@(_suggestionLoading ? "…" : "—")</span>
                        }
                    </span>
                </div>
                @if (Settings.TagsEnabled)
                {
                    <div class="sheet__row">
                        <span class="sheet__key">Tags</span>
                        <span class="sheet__val">
                            @if (_detailItem.Tags.Count > 0)
                            {
                                <span class="sheet__tags">
                                    @foreach (var tag in _detailItem.Tags)
                                    {
                                        <span class="tag-chip">@tag</span>
                                    }
                                </span>
                            }
                            else
                            {
                                <span class="sheet__muted">—</span>
                            }
                        </span>
                    </div>
                }
                <div class="sheet__row">
                    <span class="sheet__key">How it went</span>
                    <span class="sheet__val">
                        @if (_detailItem.Performances.Count == 0)
                        {
                            <span class="sheet__muted">unsung</span>
                        }
                        else if (BayesStar(_detailItem) is { } score)
                        {
                            <StarRating Value="RoundedAvg(_detailItem)" Tone="hot" Sung="true" ReadOnly="true" />
                            <span class="rating-num">@score.ToString("0.0")</span>
                        }
                        else
                        {
                            <span class="sheet__muted">sung, not rated</span>
                        }
                    </span>
                </div>
                <div class="sheet__row">
                    <span class="sheet__key">Enjoyment</span>
                    <span class="sheet__val">
                        <StarRating Value="_detailItem.Enjoyment" Tone="cool" Sung="true" ValueChanged="v => UpdateEnjoymentAsync(_detailItem, v)" />
                    </span>
                </div>
                <div class="sheet__row">
                    <span class="sheet__key">Notes</span>
                    <span class="sheet__val">@(string.IsNullOrWhiteSpace(_detailItem.Notes) ? "—" : _detailItem.Notes)</span>
                </div>
                <div class="sheet__row">
                    <span class="sheet__key">Last sung</span>
                    <span class="sheet__val">
                        @if (_detailItem.LastSungAt.HasValue)
                        {
                            <button class="btn-link sheet__history-link" @onclick="OpenHistory">
                                @_detailItem.LastSungAt.Value.ToString("MMM d, yyyy · h:mm tt")
                                <span class="sheet__history-count">(@_detailItem.Performances.Count)</span>
                            </button>
                        }
                        else
                        {
                            <span class="sheet__muted">never</span>
                        }
                    </span>
                </div>
                <div class="sheet__row">
                    <span class="sheet__key">Added</span>
                    <span class="sheet__val">@_detailItem.AddedAt.ToString("MMM d, yyyy")</span>
                </div>
            </div>
            @if (_autoFilledNote is not null)
            {
                <div class="suggest-match">@_autoFilledNote</div>
            }
            <button class="btn btn-secondary sheet__sang-btn" @onclick="() => OpenRatingPrompt(_detailItem)">
                @(_detailItem.Performances.Count > 0 ? "Sang it again" : "Mark sung")
            </button>
            @if (Settings.TonightEnabled)
            {
                <button class="btn sheet__tonight @(IsInTonight(_detailItem) ? "is-on" : "")" @onclick="ToggleDetailTonightAsync">
                    @(IsInTonight(_detailItem) ? "🎤 In tonight ✓" : "🎤 Add to tonight")
                </button>
            }
            @if (Settings.YouTubeSearchEnabled)
            {
                <button class="btn sheet__youtube" @onclick="OpenYouTubeAsync">▶ Find on YouTube</button>
            }
            @if (Settings.SpotifySearchEnabled)
            {
                <button class="btn sheet__spotify" @onclick="OpenSpotifyAsync">
                    <SpotifyIcon Size="18" Fill="#fff" />
                    Find on Spotify
                </button>
            }
            @if (Settings.KaraFunEnabled && !string.IsNullOrWhiteSpace(_activeVenueKaraFunId))
            {
                @if (Settings.TonightEnabled && !IsInTonight(_detailItem))
                {
                    @* Split button: the main segment opens KaraFun; the chevron queues the song for tonight first,
                       then opens it. Degrades to a plain button below when Tonight is off (no menu to offer) OR the
                       song is already queued for tonight (the "add to tonight" shortcut would be a no-op — the
                       sheet's "🎤 In tonight ✓" row above already shows it's on deck). *@
                    <SplitButton Class="kh-split--karafun" PrimaryLabel="🎙 Find on KaraFun"
                                 OnPrimary="OpenKaraFunAsync" Direction="SplitDirection.Up"
                                 ToggleAriaLabel="More KaraFun options">
                        <SplitButtonItem Icon="🎤" Description="Queue it for tonight, then open KaraFun"
                                         OnClick="AddToTonightAndOpenKaraFunAsync">
                            Add to tonight &amp; open
                        </SplitButtonItem>
                    </SplitButton>
                }
                else
                {
                    <button class="btn sheet__karafun" @onclick="OpenKaraFunAsync">🎙 Find on KaraFun</button>
                }
            }
            @if (Settings.LyricsEnabled)
            {
                <button class="btn sheet__lyrics" @onclick="OpenLyricsAsync">📖 Lyrics</button>
            }
            <div class="sheet__actions">
                <button class="btn btn-primary" @onclick="StartEdit">Edit</button>
            </div>
        }
        else
        {
            <div class="sheet__title">Edit song</div>
            <div class="field">
                <label class="field__label" for="e-title">Song title</label>
                <input id="e-title" class="input" @bind="_editTitle" @bind:event="oninput" />
            </div>
            <div class="field">
                <label class="field__label" for="e-artist">Artist</label>
                <input id="e-artist" class="input" @bind="_editArtist" @bind:event="oninput" />
            </div>
            <div class="field">
                <label class="field__label" for="e-genre">Genre <span class="field__hint">— optional</span></label>
                <select id="e-genre" class="input" @bind="_editGenre">
                    <option value=""></option>
                    @foreach (var g in Genres.All)
                    {
                        <option value="@g">@g</option>
                    }
                </select>
            </div>
            <div class="field">
                <label class="field__label" for="e-year">Release year <span class="field__hint">— optional</span></label>
                <input id="e-year" class="input num-year" type="text" inputmode="numeric" maxlength="4"
                       @bind="_editYear" @bind:event="oninput" />
                @if (_editYear.HasValue && !EditYearValid)
                {
                    <div class="field__error">Enter a year between 1 and @CurrentYear.</div>
                }
            </div>
            <div class="field">
                <label class="field__label" for="e-notes">Notes</label>
                <textarea id="e-notes" class="input sheet__notes" rows="3"
                          placeholder="e.g. start slow, key of G" @bind="_editNotes" @bind:event="oninput"></textarea>
            </div>
            @if (Settings.TagsEnabled)
            {
                <div class="field">
                    <label class="field__label">Tags <span class="field__hint">— optional</span></label>
                    <TagInput Tags="_editTags" TagsChanged="v => _editTags = v" Suggestions="UsedTags" />
                </div>
            }
            <div class="sheet__actions">
                <button class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
                <button class="btn btn-primary" @onclick="SaveEditAsync" disabled="@(!CanSaveEdit)">Save</button>
            </div>
        }
    </div>
}

<RatingPromptSheet Item="_ratingPromptItem" RatePerformances="Settings.RatePerformances"
                   OnCommit="OnRatingCommitAsync" OnCancel="CloseRatingPrompt" />

@if (_lyricsItem is not null)
{
    <div class="sheet-backdrop sheet-backdrop--history" @onclick="CloseLyrics"></div>
    <div class="sheet sheet--history" role="dialog" aria-modal="true" @ref="_lyricsSheet">
        <button type="button" class="sheet__close" @onclick="CloseLyrics" aria-label="Close">✕</button>
        <div class="sheet__title">Lyrics</div>
        <div class="sheet__subtitle">@_lyricsItem.Title@(string.IsNullOrWhiteSpace(_lyricsItem.Artist) ? "" : $" · {_lyricsItem.Artist}")</div>
        @if (_lyricsLoading)
        {
            <div class="lyrics__status">Looking up lyrics…</div>
        }
        else if (_lyricsError is not null)
        {
            <div class="lyrics__status">@_lyricsError</div>
        }
        else if (_lyricsInstrumental)
        {
            <div class="lyrics__status">This track is instrumental — no lyrics.</div>
        }
        else if (string.IsNullOrWhiteSpace(_lyricsText))
        {
            <div class="lyrics__status">No lyrics found for this song.</div>
        }
        else
        {
            <div class="lyrics">@_lyricsText</div>
            <div class="lyrics__attribution">Lyrics via LRCLIB</div>
        }
    </div>
}

@if (_historyItem is not null)
{
    <div class="sheet-backdrop sheet-backdrop--history" @onclick="CloseHistory"></div>
    <div class="sheet sheet--history" role="dialog" aria-modal="true" @ref="_historySheet">
        <button type="button" class="sheet__close" @onclick="CloseHistory" aria-label="Close">✕</button>
        <div class="sheet__title">Sung history</div>
        <div class="sheet__subtitle">
            @_historyItem.Title
            @if (BayesStar(_historyItem) is { } score)
            {
                <text> · @score.ToString("0.0")★ over @_historyItem.Performances.Count sing@(_historyItem.Performances.Count == 1 ? "" : "s")</text>
            }
        </div>

        <div class="history">
            @foreach (var (perf, index) in _historyItem.Performances
                .Select((p, i) => (p, i))
                .OrderByDescending(x => x.p.Date))
            {
                <div class="history__item">
                    <div class="history__top">
                        <span class="history__date">@perf.Date.ToString("MMM d, yyyy · h:mm tt")</span>
                        <StarRating Value="perf.HowItWent" Tone="hot" Sung="true" ValueChanged="v => UpdatePerformanceRatingAsync(index, v)" />
                        <button class="history__remove" @onclick="() => ArmRemoveSungDate(index)" aria-label="Remove this performance">✕</button>
                    </div>
                    <input class="input input--sm history__note" placeholder="Add a note…"
                           value="@perf.Note" @onchange="e => UpdatePerformanceNoteAsync(index, e.Value?.ToString())" />
                </div>
            }
        </div>
    </div>
}

@if (_historyItem is not null && _historyConfirmIndex is { } confirmIndex && confirmIndex < _historyItem.Performances.Count)
{
    <div class="sheet-backdrop sheet-backdrop--confirm" @onclick="CancelRemoveSungDate"></div>
    <div class="confirm-pop" role="alertdialog" aria-modal="true">
        <div class="confirm-pop__title">Remove this performance?</div>
        <div class="confirm-pop__date">@_historyItem.Performances[confirmIndex].Date.ToString("MMM d, yyyy · h:mm tt")</div>
        <div class="confirm-pop__actions">
            <button class="btn btn-secondary" @onclick="CancelRemoveSungDate">Cancel</button>
            <button class="btn confirm-pop__delete" @onclick="() => RemoveSungDateAsync(confirmIndex)">Remove</button>
        </div>
    </div>
}

@code {
    private IReadOnlyList<SongListItem> _items = [];
    private bool _loading = true;   // true only during the initial device-storage load; drives the equalizer loader
    private string _title = string.Empty;
    private string _artist = string.Empty;
    private string _notes = string.Empty;
    private string _genre = string.Empty;
    private int? _year;
    private List<string> _tags = [];   // add-form tags buffer; normalized onto the song when it's added

    // How many tag chips a card shows inline before collapsing the rest into a "+N" count.
    private const int CardTagLimit = 3;

    // Filters. Genre / rating / enjoyment are multi-select: an empty set = no filter, otherwise the picks are OR'd.
    private string _filterSearch = string.Empty;   // one box, matched against title OR artist
    private readonly HashSet<string> _filterGenres = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<int> _filterRatings = [];      // "how it went" rounded average(s): 0 Not rated, 1-5 stars
    private readonly HashSet<int> _filterEnjoyments = [];   // enjoyment rating(s): 0 Not rated, 1-5 stars
    private readonly HashSet<string> _filterTags = new(StringComparer.OrdinalIgnoreCase);
    private bool _tagFilterAll;   // Tags filter combine mode: false = match ANY selected (OR, default), true = ALL (AND)

    // The six rating choices shared by the "how it went" and "enjoyment" multi-selects.
    private static readonly (int val, string label)[] RatingOptions =
        [(0, "Not rated"), (1, "★"), (2, "★★"), (3, "★★★"), (4, "★★★★"), (5, "★★★★★")];
    private bool _filterSheetOpen;   // the advanced-filters bottom sheet (opened from the funnel); transient, not persisted
    private ElementReference _filterSheet;
    private bool _filterSheetBound;
    private bool _addOpen;   // the add-song sheet (opened by the floating "+"); transient, not persisted
    private ElementReference _addSheet;
    private bool _addSheetBound;

    // Year range slider. Handles are null until the user drags them, then they follow the selection;
    // the effective bounds are the min/max release year present across dated songs (recomputed on refresh).
    private int? _filterYearLo;
    private int? _filterYearHi;
    private int _yearMin;
    private int _yearMax;
    private int _yearDistinctCount;

    private enum SortColumn { Added, Title, Artist, HowItWent, Enjoyment }
    private SortColumn _sort = SortColumn.Title;
    private bool _sortDescending = false;   // default: A→Z by song title

    // Swipe-to-remove wiring: the JS module is delegated on the stable <tbody> element.
    private ElementReference _swipeRoot;
    private DotNetObjectReference<MySongs>? _swipeRef;
    private bool _listRendered;
    private bool _swipeBound;

    // Infinite scroll: render only _renderCount of the filtered/sorted list and grow by PageSize as the sentinel
    // nears the viewport, so a 500+ song list paints ~20 cards instead of all of them. _lastListSig rewinds paging
    // to the first page whenever the filter/sort changes; _visibleCount is the full filtered count (set each render).
    private const int PageSize = 20;
    private int _renderCount = PageSize;
    private int _visibleCount;
    private string _lastListSig = "";
    private ElementReference _sentinel;
    private bool _infiniteBound;
    private bool _pagingReset;   // set when a filter/sort change rewound paging → OnAfterRender scrolls back to top

    // Detail-sheet drag-to-dismiss (pull down to close; the page behind is locked while it's open).
    private ElementReference _detailSheet;
    private bool _sheetBound;
    private ElementReference _historySheet;
    private bool _historySheetBound;
    private ElementReference _lyricsSheet;
    private bool _lyricsSheetBound;
    private bool _pageLocked;   // mirrors body.kh-sheet-open; reconciled from sheet state each render

    // "Tonight" on-deck set list (its own store). Read here only to light up each card's 🎤 quick-add state
    // (IsInTonight); the set itself is managed on the Tonight tab (Components/Pages/Tonight.razor).
    private IReadOnlyList<TonightEntry> _tonight = [];

    // Lyrics lookup (LRCLIB) shown in its own sheet; fetched fresh each open.
    private SongListItem? _lyricsItem;
    private string? _lyricsText;
    private string? _lyricsError;
    private bool _lyricsLoading;
    private bool _lyricsInstrumental;
    private CancellationTokenSource? _lyricsCts;

    // Undo-after-swipe-remove: the last removed item + a timer to expire the offer.
    private const int UndoWindowMs = 5000;
    private SongListItem? _undoItem;
    private CancellationTokenSource? _undoCts;
    private bool _rangeBound;   // anti-cross clamp bound to the current year-slider inputs
    private string? _scrollToSongId;   // set on favorite-toggle; the next render scrolls this card into view

    // Filter + sort + paging live on IAppSession (one view-state per singer), and scroll on scroll.js keyed per
    // singer, so they survive a tab change AND a singer switch — each singer's My Songs keeps its own filters, sort,
    // paged height and scroll position. The page component is disposed on navigation and its own fields would
    // otherwise reset; a singer switch keeps the page mounted but is detected in RefreshAsync (see below).
    private Guid? _viewSinger;   // the singer whose view state is currently loaded into this page's fields
    private string ScrollKey => ScrollKeyFor(_viewSinger);
    private static string ScrollKeyFor(Guid? singerId) => singerId is { } id ? $"mysongs:{id:N}" : "mysongs";
    private bool _scrollRestored;

    // Song detail / edit sheet (opened by tapping a card).
    private SongListItem? _detailItem;
    private bool _editing;
    private bool _editFieldsBound;   // khNumeric bound to the edit-form year input
    private bool _addFieldsBound;    // khNumeric bound to the add-form year input (re-bind when the form reopens)
    private string _editTitle = string.Empty;
    private string _editArtist = string.Empty;
    private string _editGenre = string.Empty;
    private string _editNotes = string.Empty;
    private int? _editYear;
    private List<string> _editTags = [];   // edit-sheet tags buffer; normalized back onto the song on save

    // Metadata auto-fill: look up a not-yet-looked-up song's blank year/genre and fill it from the match.
    // Runs in the background on add, and again when the detail sheet opens (which also shows a note of what
    // filled — the spinner + note below are sheet-only UI).
    private bool _suggestionLoading;
    private string? _autoFilledNote;
    private CancellationTokenSource? _suggestCts;                // detail-sheet lookup; cancelled when the sheet closes
    private readonly CancellationTokenSource _bgFillCts = new(); // add-time background lookups; cancelled on dispose

    // Album-art card backgrounds (gated by Settings.AlbumArtEnabled, on by default). Maps a song id to a blob:
    // object URL once its cover has been cached + handed to the WebView (js/album-art.js); the card reads it via
    // ArtStyle. Populated lazily in the background (LoadArtAsync) so the list paints immediately and covers fade in
    // as they arrive. The blob URLs are owned by khAlbumArt and freed on stale-drop / singer switch / dispose.
    private readonly Dictionary<Guid, string> _artUris = [];
    private CancellationTokenSource? _artCts;   // cancels the in-flight art load when the list reloads / page disposes

    // Art is loaded only for the CURRENTLY-PAGED cards, so memory is bounded by what's on screen rather than by the
    // whole library. _artPageSig (filter/sort signature + paged count) captures the rendered page; OnAfterRender
    // kicks a load whenever it changes (a filter, sort, search, or the sentinel growing the page).
    private string _artPageSig = "";
    private string _artLoadedSig = "␀";   // distinct from any real signature so the first page always loads

    // A release year is optional, but when supplied it must be a real year: 1..this year.
    private static int CurrentYear => DateTime.Now.Year;
    private bool YearValid => !_year.HasValue || (_year.Value >= 1 && _year.Value <= CurrentYear);

    private bool CanAdd => !string.IsNullOrWhiteSpace(_title) && YearValid;

    // Non-blocking — the first Add on a match arms an "Add anyway" confirm; editing a field disarms it.
    private bool _confirmedDuplicate;

    private bool IsDuplicate =>
        !string.IsNullOrWhiteSpace(_title) &&
        _items.Any(i =>
            string.Equals(i.Title.Trim(), _title.Trim(), StringComparison.OrdinalIgnoreCase) &&
            string.Equals(i.Artist.Trim(), _artist.Trim(), StringComparison.OrdinalIgnoreCase));

    private string DuplicateMessage =>
        string.IsNullOrWhiteSpace(_artist)
            ? $"You already have \"{_title.Trim()}\" in your list."
            : $"You already have \"{_title.Trim()}\" by {_artist.Trim()} in your list.";

    private void OnAddFieldChanged() => _confirmedDuplicate = false;

    private bool EditYearValid => !_editYear.HasValue || (_editYear.Value >= 1 && _editYear.Value <= CurrentYear);
    private bool CanSaveEdit => !string.IsNullOrWhiteSpace(_editTitle) && EditYearValid;

    private void SortBy(SortColumn column)
    {
        if (_sort == column)
        {
            _sortDescending = !_sortDescending;
        }
        else
        {
            _sort = column;
            // Sensible default direction: dates/rating high-first, text A-Z.
            _sortDescending = column is SortColumn.Added or SortColumn.HowItWent or SortColumn.Enjoyment;
        }
    }

    // The <select> only fires onchange on a real field change, so SortBy always hits its new-field branch (applying
    // that field's sensible default direction); the ▲/▼ button flips direction via SortBy's same-field branch.
    private void OnSortFieldChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<SortColumn>(e.Value?.ToString(), out var column))
            SortBy(column);
    }

    // Year filter: only offered when there are 2+ distinct release years to span. The effective handle
    // positions clamp to [min, max]; a null handle sits at the corresponding bound (i.e. not narrowed).
    private bool ShowYearFilter => _yearDistinctCount >= 2;
    private int YearLo => Math.Clamp(_filterYearLo ?? _yearMin, _yearMin, _yearMax);
    private int YearHi => Math.Clamp(_filterYearHi ?? _yearMax, _yearMin, _yearMax);
    private bool YearFilterActive => ShowYearFilter && (YearLo > _yearMin || YearHi < _yearMax);

    private void OnYearLoInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
            _filterYearLo = Math.Min(Math.Clamp(v, _yearMin, _yearMax), YearHi);   // never cross the high handle
    }

    private void OnYearHiInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
            _filterYearHi = Math.Max(Math.Clamp(v, _yearMin, _yearMax), YearLo);   // never cross the low handle
    }

    // Handle position as a % of the track, for the selected-range fill. Invariant culture so CSS never gets a comma.
    private string Pct(int value) =>
        (_yearMax > _yearMin ? (value - _yearMin) * 100.0 / (_yearMax - _yearMin) : 0)
            .ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
    private string PctFromRight(int value) =>
        (_yearMax > _yearMin ? (_yearMax - value) * 100.0 / (_yearMax - _yearMin) : 0)
            .ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    // Recompute the year bounds from the current list; keep any active selection inside the new range.
    private void RecomputeYearBounds()
    {
        var years = _items.Where(i => i.Year.HasValue).Select(i => i.Year!.Value).ToList();
        _yearDistinctCount = years.Distinct().Count();
        if (years.Count > 0)
        {
            _yearMin = years.Min();
            _yearMax = years.Max();
            if (_filterYearLo.HasValue) _filterYearLo = Math.Clamp(_filterYearLo.Value, _yearMin, _yearMax);
            if (_filterYearHi.HasValue) _filterYearHi = Math.Clamp(_filterYearHi.Value, _yearMin, _yearMax);
        }
    }

    // A cheap fingerprint of the active filter + sort; when it changes, the render rewinds infinite scroll to page 1.
    private string FilterSortSignature() => string.Join("",
        _filterSearch,
        string.Join(",", _filterGenres.OrderBy(g => g, StringComparer.Ordinal)),
        string.Join(",", _filterRatings.OrderBy(r => r)),
        string.Join(",", _filterEnjoyments.OrderBy(e => e)),
        string.Join(",", _filterTags.OrderBy(t => t, StringComparer.Ordinal)),
        _tagFilterAll, _filterYearLo, _filterYearHi, _sort, _sortDescending);

    // Grow the window by a page when the sentinel scrolls into range (invoked from khInfinite's IntersectionObserver).
    [JSInvokable]
    public void LoadMore()
    {
        if (_renderCount >= _visibleCount)
            return;
        _renderCount = Math.Min(_renderCount + PageSize, _visibleCount);
        StateHasChanged();
    }

    private bool AnyFilterActive =>
        !string.IsNullOrWhiteSpace(_filterSearch) ||
        AnyHiddenFilterActive;

    // The filters behind the funnel — the search bar shows its own text, so the funnel's dot (and the pills
    // above the list) reflect only these.
    private bool AnyHiddenFilterActive =>
        _filterGenres.Count > 0 ||
        _filterRatings.Count > 0 ||
        _filterEnjoyments.Count > 0 ||
        _filterTags.Count > 0 ||
        YearFilterActive;

    // ---- View-state persistence (filter + sort survive a tab change; held on IAppSession) ----

    // Skipped on the first-ever visit (nothing saved yet), which leaves the page's own defaults in place —
    // SaveViewState then seeds the holder on dispose, so the holder never has to know the default sort column.
    private void RestoreViewState()
    {
        var s = Session.MySongsViewFor(_viewSinger);
        if (!s.Initialized)
            return;

        _filterSearch = s.FilterSearch;
        _filterGenres.Clear();
        foreach (var g in s.FilterGenres) _filterGenres.Add(g);
        _filterRatings.Clear();
        foreach (var r in s.FilterRatings) _filterRatings.Add(r);
        _filterEnjoyments.Clear();
        foreach (var en in s.FilterEnjoyments) _filterEnjoyments.Add(en);
        _filterTags.Clear();
        foreach (var t in s.FilterTags) _filterTags.Add(t);
        _tagFilterAll = s.FilterTagsAll;
        _filterYearLo = s.FilterYearLo;
        _filterYearHi = s.FilterYearHi;
        _sort = (SortColumn)s.Sort;
        _sortDescending = s.SortDescending;
        // Restore the paged count so the returning list rebuilds to the same height (scroll.js can then land the
        // saved scroll). Seed _lastListSig to the restored filter/sort so the first render doesn't rewind to page 1.
        _renderCount = Math.Max(PageSize, s.RenderCount);
        _lastListSig = FilterSortSignature();
    }

    // Reset the page's filter/sort/paging fields to their first-visit defaults — used when switching to a singer
    // whose view state hasn't been seeded yet, so their list starts clean instead of inheriting the last singer's.
    private void ResetViewBuffers()
    {
        // The incoming singer's list replaces this one, so drop every cover and free its blob URL (the ids won't
        // recur, so keeping them would leak). Their images reload for the new singer's paged cards.
        _artUris.Clear();
        _artLoadedSig = " ";   // force the next page to (re)load art for the new singer
        _ = JS.InvokeVoidAsync("khAlbumArt.revokeAll");

        _filterSearch = string.Empty;
        _filterGenres.Clear();
        _filterRatings.Clear();
        _filterEnjoyments.Clear();
        _filterTags.Clear();
        _tagFilterAll = false;
        _filterYearLo = null;
        _filterYearHi = null;
        _sort = SortColumn.Title;
        _sortDescending = false;
        _renderCount = PageSize;
        _lastListSig = FilterSortSignature();   // seed so the first render after a switch doesn't rewind paging
    }

    private void SaveViewState(Guid? singer)
    {
        var s = Session.MySongsViewFor(singer);
        s.FilterSearch = _filterSearch;
        s.FilterGenres = new HashSet<string>(_filterGenres, StringComparer.OrdinalIgnoreCase);
        s.FilterRatings = [.. _filterRatings];
        s.FilterEnjoyments = [.. _filterEnjoyments];
        s.FilterTags = new HashSet<string>(_filterTags, StringComparer.OrdinalIgnoreCase);
        s.FilterTagsAll = _tagFilterAll;
        s.FilterYearLo = _filterYearLo;
        s.FilterYearHi = _filterYearHi;
        s.Sort = (int)_sort;
        s.SortDescending = _sortDescending;
        s.RenderCount = _renderCount;
        s.Initialized = true;
    }

    private void ClearFilters()
    {
        _filterSearch = string.Empty;
        ClearAdvancedFilters();
    }

    // Just the funnel filters (genre / how it went / enjoyment / tags / year); the search text is left alone.
    private void ClearAdvancedFilters()
    {
        _filterGenres.Clear();
        _filterRatings.Clear();
        _filterEnjoyments.Clear();
        _filterTags.Clear();
        _filterYearLo = _filterYearHi = null;
    }

    // ---- The funnel's active filters as removable pills ----
    private sealed record FilterPill(string Label, Action Remove);

    // One pill per pick (genre / how it went / enjoyment / tag), plus a single span for the year range. Removing a
    // pill only mutates local filter state — the @onclick re-renders — so there's no store write.
    private List<FilterPill> FilterPills()
    {
        var pills = new List<FilterPill>();
        foreach (var g in _filterGenres.OrderBy(g => g, StringComparer.OrdinalIgnoreCase))
            pills.Add(new FilterPill(g, () => _filterGenres.Remove(g)));
        foreach (var r in _filterRatings.OrderByDescending(r => r))
            pills.Add(new FilterPill(r == 0 ? "How it went · unrated" : $"How it went {RatingOptionLabel(r)}",
                () => _filterRatings.Remove(r)));
        foreach (var en in _filterEnjoyments.OrderByDescending(e => e))
            pills.Add(new FilterPill(en == 0 ? "Enjoyment · unrated" : $"Enjoyment {RatingOptionLabel(en)}",
                () => _filterEnjoyments.Remove(en)));
        foreach (var t in _filterTags.OrderBy(t => t, StringComparer.OrdinalIgnoreCase))
            pills.Add(new FilterPill(t, () => _filterTags.Remove(t)));
        if (YearFilterActive)
            pills.Add(new FilterPill($"{YearLo}–{YearHi}", () => { _filterYearLo = _filterYearHi = null; }));
        return pills;
    }

    private static string RatingOptionLabel(int val) => RatingOptions.First(o => o.val == val).label;

    private void OpenFilterSheet() => _filterSheetOpen = true;

    private void CloseFilterSheet() => _filterSheetOpen = false;

    // Pull-down-to-dismiss from khSheet (the filter sheet already animated off-screen).
    [JSInvokable]
    public void CloseFilterSheetFromSwipe()
    {
        CloseFilterSheet();
        StateHasChanged();
    }

    // ---- Add-a-song sheet (floating "+") ----
    private void OpenAdd() => _addOpen = true;

    private void CloseAdd() => _addOpen = false;

    // Pull-down-to-dismiss from khSheet (the add sheet already animated off-screen).
    [JSInvokable]
    public void CloseAddFromSwipe()
    {
        CloseAdd();
        StateHasChanged();
    }

    // The floating "+" tucks away whenever any overlay is up (so it never sits under a dim backdrop) and during the
    // undo-toast window (so a round button doesn't poke out behind the toast). Mirrors TryCloseTopOverlay's set.
    private bool AnyOverlayOpen =>
        _addOpen || _filterSheetOpen || _detailItem is not null || _historyItem is not null
        || _lyricsItem is not null || _ratingPromptItem is not null || _historyConfirmIndex is not null
        || _undoItem is not null;

    // ---- Multi-select filter helpers ----
    private void SetGenreFilter(string genre, bool on) { if (on) _filterGenres.Add(genre); else _filterGenres.Remove(genre); }
    private void SetRatingFilter(int value, bool on) { if (on) _filterRatings.Add(value); else _filterRatings.Remove(value); }
    private void SetEnjoymentFilter(int value, bool on) { if (on) _filterEnjoyments.Add(value); else _filterEnjoyments.Remove(value); }
    private void SetTagFilter(string tag, bool on) { if (on) _filterTags.Add(tag); else _filterTags.Remove(tag); }

    // Every tag in use across the list (distinct, case-insensitive, alphabetized). Doubles as the Tags filter's
    // options and the reuse-suggestions for the add/edit tag inputs — no separate tag catalogue is kept.
    private IReadOnlyList<string> UsedTags => _items
        .SelectMany(i => i.Tags)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(t => t, StringComparer.OrdinalIgnoreCase)
        .ToList();

    private string TagSummary => _filterTags.Count == 0
        ? "Any tag"
        : SummaryList(UsedTags.Where(_filterTags.Contains).ToList());

    // Summary shown on a filter's collapsed control: up to two picks, then "+N".
    // Only genres that at least one song actually uses — no point offering a filter that matches nothing.
    private IReadOnlyList<string> UsedGenres => _items
        .Select(i => i.Genre)
        .Where(g => !string.IsNullOrWhiteSpace(g))
        .Select(g => g!)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(g => g, StringComparer.OrdinalIgnoreCase)
        .ToList();

    private string GenreSummary => _filterGenres.Count == 0
        ? "Any genre"
        : SummaryList(Genres.All.Where(_filterGenres.Contains).ToList());
    private string RatingSummary(HashSet<int> set) => set.Count == 0
        ? "Any"
        : SummaryList(RatingOptions.Where(o => set.Contains(o.val)).Select(o => o.label).ToList());
    private static string SummaryList(IReadOnlyList<string> labels) =>
        labels.Count <= 2 ? string.Join(", ", labels) : $"{labels[0]}, {labels[1]} +{labels.Count - 2}";

    private IEnumerable<SongListItem> Filtered()
    {
        IEnumerable<SongListItem> q = _items;

        if (!string.IsNullOrWhiteSpace(_filterSearch))
        {
            var term = _filterSearch.Trim();
            q = q.Where(i => i.Title.Contains(term, StringComparison.OrdinalIgnoreCase)
                          || i.Artist.Contains(term, StringComparison.OrdinalIgnoreCase));
        }
        if (_filterGenres.Count > 0)
            q = q.Where(i => i.Genre is not null && _filterGenres.Contains(i.Genre));
        if (_filterRatings.Count > 0)
            q = q.Where(i => _filterRatings.Contains(RoundedAvg(i)));
        if (_filterEnjoyments.Count > 0)
            q = q.Where(i => _filterEnjoyments.Contains(i.Enjoyment));
        if (_filterTags.Count > 0)
            q = _tagFilterAll
                ? q.Where(i => _filterTags.All(f => i.Tags.Contains(f, StringComparer.OrdinalIgnoreCase)))
                : q.Where(i => i.Tags.Any(t => _filterTags.Contains(t)));
        if (YearFilterActive)
            q = q.Where(i => i.Year.HasValue && i.Year.Value >= YearLo && i.Year.Value <= YearHi);

        return q;
    }

    private IEnumerable<SongListItem> Sorted()
    {
        var filtered = Filtered();
        IEnumerable<SongListItem> ascending = _sort switch
        {
            SortColumn.Title => filtered.OrderBy(i => i.Title, StringComparer.OrdinalIgnoreCase),
            SortColumn.Artist => filtered.OrderBy(i => i.Artist, StringComparer.OrdinalIgnoreCase),
            SortColumn.HowItWent => filtered.OrderBy(AvgSortKey),
            SortColumn.Enjoyment => filtered.OrderBy(i => i.Enjoyment),
            _ => filtered.OrderBy(i => i.AddedAt),
        };
        var ordered = _sortDescending ? ascending.Reverse() : ascending;
        // Favorites always float to the top, whatever the active sort/direction is.
        // OrderBy is a stable sort, so the chosen order is preserved within each group.
        return ordered.OrderBy(i => i.IsFavorite ? 0 : 1);
    }

    protected override async Task OnInitializedAsync()
    {
        _viewSinger = Session.ActiveSingerId;   // whose view state we're loading (keys RestoreViewState + scroll)
        RestoreViewState();   // before the first render, so restored filters/sort show immediately
        _backGuard = new BackButtonOverlayGuard(BackButton,
            closeTopMost: TryCloseTopOverlay,
            notifyStateChanged: StateHasChanged);
        Store.Changed += OnStoreChanged;
        Tonight.Changed += OnTonightChanged;
        // Track the active venue's KaraFun ID so the detail-sheet "Find on KaraFun" button follows it.
        Session.ActiveVenueChanged += OnVenueContextChanged;
        Venues.Changed += OnVenueContextChanged;
        await RefreshActiveVenueKaraFunAsync();

        // Initial load: show the equalizer loader (not the "No songs yet" empty state) while the on-device
        // list deserializes. Hold it for a ~250ms minimum so a fast load doesn't flash it, then reveal the list.
        var startedAt = Environment.TickCount64;
        await RefreshAsync();

        // Smart landing (once per launch): if a set is queued for tonight, open onto the Tonight tab instead of
        // the wishlist — you walk into the venue and your set is right there. With nothing queued (or Tonight
        // off) we stay here. Every later navigation is left alone, so tapping "My Songs" never bounces away.
        if (!Session.LandingResolved)
        {
            Session.LandingResolved = true;
            if (Settings.TonightEnabled && _tonight.Count > 0)
            {
                Nav.NavigateTo("tonight", replace: true);
                return;   // we're leaving this page; skip the loader-reveal below
            }
        }

        var elapsed = Environment.TickCount64 - startedAt;
        if (elapsed < 250)
            await Task.Delay((int)(250 - elapsed));
        _loading = false;
        await InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Attaching the listener only AFTER restoring is deliberate: on a tab change the incoming page fires a
        // mount-time scroll-to-0, and a listener attached earlier would record that 0 (during the loading delay)
        // and clobber the saved position before we restore it. Waiting for !_loading means the list has painted,
        // so the page has its full height to scroll to.
        if (!_scrollRestored && !_loading)
        {
            _scrollRestored = true;
            await JS.InvokeVoidAsync("khScroll.restore", ScrollKey);
            await JS.InvokeVoidAsync("khScroll.track", ScrollKey);
            _pagingReset = false;   // the restore positioned this first paint; don't also jump to top
        }
        else if (_pagingReset)
        {
            // A filter/sort change rewound to page 1 — show the new results from the top (and stop the retained deep
            // scroll from instantly tripping the sentinel to load extra pages).
            _pagingReset = false;
            await JS.InvokeVoidAsync("khInfinite.suspend", 400);
            await JS.InvokeVoidAsync("khScroll.toTop");
        }

        // Add-form year input needs the digit-only guard. The form is collapsible, so re-bind whenever it's
        // (re)shown — collapsing remounts a fresh input that has lost the guard.
        if (_addOpen && !_addFieldsBound)
        {
            await JS.InvokeVoidAsync("khNumeric.register");
            _addFieldsBound = true;
        }
        else if (!_addOpen)
        {
            _addFieldsBound = false;
        }

        if (_listRendered && !_swipeBound)
        {
            _swipeRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("khSwipe.register", _swipeRoot, _swipeRef);
            _swipeBound = true;
        }
        else if (!_listRendered)
        {
            // Card list unmounted (list emptied) — the next mount is a fresh container that needs rebinding.
            _swipeBound = false;
        }

        // Observe the load-more sentinel while there's more to show; disconnect once everything's rendered (the
        // sentinel unmounts then) or the list is gone, and re-observe when a filter change brings it back.
        var wantSentinel = _listRendered && _renderCount < _visibleCount;
        if (wantSentinel && !_infiniteBound)
        {
            _swipeRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("khInfinite.observe", _sentinel, _swipeRef);
            _infiniteBound = true;
        }
        else if (!wantSentinel && _infiniteBound)
        {
            await JS.InvokeVoidAsync("khInfinite.disconnect");
            _infiniteBound = false;
        }

        // Detail sheet: bind pull-down-to-dismiss + lock the page behind it. Re-bind on each open.
        if (_detailItem is not null && !_sheetBound)
        {
            _swipeRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("khSheet.register", _detailSheet, _swipeRef);
            _sheetBound = true;
        }
        else if (_detailItem is null)
        {
            _sheetBound = false;
        }

        // Load album art for the newly-rendered page, once per page change (filter / sort / search / grew a page).
        // Reloads (RefreshAsync) and single-item autofills trigger LoadArtAsync directly, since those change content
        // without changing the page signature.
        if (_artPageSig != _artLoadedSig)
        {
            _artLoadedSig = _artPageSig;
            _ = LoadArtAsync();
        }

        // History sheet: same pull-down-to-dismiss, but it has an inner scrolling list — khSheet's scroller
        // detection only lets the drag take over at the list's top, and a bigger threshold means it takes a
        // deliberate, stronger swipe to close (so a normal scroll-flick doesn't dismiss it).
        if (_historyItem is not null && !_historySheetBound)
        {
            _swipeRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("khSheet.register", _historySheet, _swipeRef,
                new { closeMethod = "CloseHistoryFromSwipe", closePx = 150 });
            _historySheetBound = true;
        }
        else if (_historyItem is null)
        {
            _historySheetBound = false;
        }

        // Lyrics sheet: pull down to dismiss; it scrolls, so the same scroll-aware, stronger swipe as history.
        if (_lyricsItem is not null && !_lyricsSheetBound)
        {
            _swipeRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("khSheet.register", _lyricsSheet, _swipeRef,
                new { closeMethod = "CloseLyricsFromSwipe", closePx = 150 });
            _lyricsSheetBound = true;
        }
        else if (_lyricsItem is null)
        {
            _lyricsSheetBound = false;
        }

        // Filter sheet: pull down to dismiss; it can scroll (year slider + long genre lists), so the same
        // scroll-aware, stronger swipe as the other tall sheets.
        if (_filterSheetOpen && !_filterSheetBound)
        {
            _swipeRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("khSheet.register", _filterSheet, _swipeRef,
                new { closeMethod = "CloseFilterSheetFromSwipe", closePx = 150 });
            _filterSheetBound = true;
        }
        else if (!_filterSheetOpen)
        {
            _filterSheetBound = false;
        }

        // Add sheet: pull down to dismiss; it can scroll (tags/year), so the same stronger, scroll-aware swipe.
        if (_addOpen && !_addSheetBound)
        {
            _swipeRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("khSheet.register", _addSheet, _swipeRef,
                new { closeMethod = "CloseAddFromSwipe", closePx = 150 });
            _addSheetBound = true;
        }
        else if (!_addOpen)
        {
            _addSheetBound = false;
        }

        // Reconcile the page-scroll lock straight from sheet state every render, so it can never get stranded
        // on a close path that skips cleanup (e.g. a touch swipe-dismiss). Only touch JS when it actually flips.
        var anySheetOpen = _detailItem is not null || _historyItem is not null || _ratingPromptItem is not null
            || _lyricsItem is not null || _filterSheetOpen || _addOpen;
        if (anySheetOpen != _pageLocked)
        {
            _pageLocked = anySheetOpen;
            await JS.InvokeVoidAsync("khSheet.setLock", anySheetOpen);
        }

        // Bind the anti-cross clamp whenever the year slider is on screen. It unmounts when the
        // filter is collapsed or drops below 2 distinct years, so re-bind the fresh inputs on return.
        var sliderPresent = _items.Count > 0 && _filterSheetOpen && ShowYearFilter;
        if (sliderPresent && !_rangeBound)
        {
            await JS.InvokeVoidAsync("khRange.register");
            await JS.InvokeVoidAsync("khNumeric.register");   // filter From/To year inputs
            _rangeBound = true;
        }
        else if (!sliderPresent)
        {
            _rangeBound = false;
        }

        // The edit sheet's year input needs the digit-only guard once it's rendered.
        if (_editing && !_editFieldsBound)
        {
            await JS.InvokeVoidAsync("khNumeric.register");
            _editFieldsBound = true;
        }
        else if (!_editing)
        {
            _editFieldsBound = false;
        }

        // A favorite toggle just re-sorted the list; scroll the affected card into its new position.
        if (_scrollToSongId is { } scrollId)
        {
            _scrollToSongId = null;
            await JS.InvokeVoidAsync("khScroll.toSong", scrollId);
        }
    }

    [JSInvokable]
    public async Task RemoveById(string id)
    {
        if (!Guid.TryParse(id, out var guid))
            return;

        var removed = _items.FirstOrDefault(i => i.Id == guid);
        await Store.RemoveAsync(guid);
        if (removed is not null)
            ShowUndo(removed);
    }

    private void ShowUndo(SongListItem item)
    {
        _undoCts?.Cancel();
        _undoCts = new CancellationTokenSource();
        _undoItem = item;
        _ = DismissUndoAfterDelay(_undoCts.Token);
        StateHasChanged();
    }

    private async Task DismissUndoAfterDelay(CancellationToken token)
    {
        try { await Task.Delay(UndoWindowMs, token); }
        catch (TaskCanceledException) { return; }   // superseded by a newer removal or an Undo

        _undoItem = null;
        await InvokeAsync(StateHasChanged);
    }

    private async Task UndoRemoveAsync()
    {
        _undoCts?.Cancel();
        var item = _undoItem;
        _undoItem = null;
        if (item is not null)
            await Store.RestoreAsync(item);   // Store.Changed → refresh puts the row back
    }

    private Guid? _lastSurpriseId;

    // 🎲 Surprise me: pick a random song from the currently visible (filtered) list and open its
    // detail sheet. Rerolls once so it won't immediately repeat the previous pick on lists of 2+.
    private Task SurpriseMe(IReadOnlyList<SongListItem> pool)
    {
        if (pool.Count == 0)
            return Task.CompletedTask;

        // Optionally drop songs already sung today so the shuffle suggests something fresh. If that
        // leaves nothing (everything's been sung today), fall back to the full pool rather than dead-end.
        IReadOnlyList<SongListItem> candidates = pool;
        if (Settings.SurpriseSkipSungToday)
        {
            var fresh = pool.Where(i => !SungToday(i)).ToList();
            if (fresh.Count > 0)
                candidates = fresh;
        }

        var pick = WeightedPick(candidates);
        if (pick.Id == _lastSurpriseId && candidates.Count >= 2)
            pick = WeightedPick(candidates);

        _lastSurpriseId = pick.Id;
        return OpenDetail(pick.Id.ToString());
    }

    // Pick a song at random, weighted by its Bayesian how-it-went star so the shuffle leans toward songs you sing
    // well — while still able to surface anything. An unrated song gets the list's average as a neutral weight (so
    // it isn't excluded), and everything keeps a small floor so nothing is ever impossible to draw.
    private SongListItem WeightedPick(IReadOnlyList<SongListItem> candidates)
    {
        var neutral = _ratingContext.PriorMean ?? 3.0;
        var weights = candidates.Select(c => Math.Max(0.25, BayesStar(c) ?? neutral)).ToList();
        var total = weights.Sum();
        if (total <= 0)
            return candidates[Random.Shared.Next(candidates.Count)];

        var roll = Random.Shared.NextDouble() * total;
        for (var i = 0; i < candidates.Count; i++)
        {
            roll -= weights[i];
            if (roll <= 0)
                return candidates[i];
        }
        return candidates[^1];   // floating-point guard: the roll landed exactly on the total
    }

    private static bool SungToday(SongListItem item) =>
        item.Performances.Any(p => p.Date.LocalDateTime.Date == DateTime.Today);

    // A tap on a row (routed from swipe.js) opens that song's detail sheet.
    [JSInvokable]
    public Task OpenDetail(string id)
    {
        if (Guid.TryParse(id, out var guid))
        {
            _detailItem = _items.FirstOrDefault(i => i.Id == guid);
            _editing = false;
            _ = LoadDetailSuggestionAsync(_detailItem);
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    // A song is eligible for auto-fill when the toggle is on, we haven't looked it up before, it has a title
    // to search on, and at least one of genre/year is still blank. A guard so callers can skip the work (and
    // the detail sheet's spinner) when there's nothing to do; re-enabling the toggle lets a later attempt run.
    private bool ShouldAutoFill(SongListItem item) =>
        Settings.AutoFillMetadata &&
        !item.MetadataLookedUp &&
        !string.IsNullOrWhiteSpace(item.Title) &&
        (string.IsNullOrWhiteSpace(item.Genre) || !item.Year.HasValue);

    // Look up a year/genre and fill any blank field straight from the match — no chip, no confirmation. Runs
    // at most once per song (gated on MetadataLookedUp). Persists the fills + the looked-up flag; returns an
    // "auto-filled ..." note when it filled something, else null. A transient failure returns null WITHOUT
    // stamping the flag, so a later add/open can retry. Shared by the add-form and detail-sheet paths.
    private async Task<string?> TryAutoFillMetadataAsync(SongListItem item, CancellationToken token)
    {
        if (!ShouldAutoFill(item))
            return null;

        Log.LogDebug("Auto-fill lookup start: “{Title}” — “{Artist}”", item.Title, item.Artist);
        TrackMetadata? meta;
        try
        {
            meta = await Metadata.LookupAsync(item.Title, item.Artist, token);
        }
        catch (MetadataLookupException ex)
        {
            // network/rate-limit failure — leave the flag unset to retry later
            Log.LogWarning(ex, "Auto-fill lookup failed for “{Title}” — “{Artist}”; will retry later", item.Title, item.Artist);
            return null;
        }

        if (token.IsCancellationRequested)
            return null;

        Log.LogDebug("Auto-fill lookup done: “{Title}” — “{Artist}” → matched {Matched}, year={Year}, genre={Genre}, cover={HasCover}",
            item.Title, item.Artist,
            meta is null ? "(no match)" : $"“{meta.MatchedTitle} — {meta.MatchedArtist}”",
            meta?.Year, meta?.Genre, meta?.ArtworkUrl is not null);

        var filled = new List<string>();
        if (string.IsNullOrWhiteSpace(item.Genre) && Genres.Map(meta?.Genre) is string g)
        {
            item.Genre = g;
            filled.Add("Genre");
        }
        if (!item.Year.HasValue && meta?.Year is int y)
        {
            item.Year = y;
            filled.Add("Year");
        }

        // The iTunes match carries the cover for free — capture it so enabling album art later is instant. When
        // iTunes has none and album art is on, fall back to Deezer (art only — never its unreliable year/genre).
        var artUrl = meta?.ArtworkUrl;
        var artLookedUp = true;
        if (artUrl is null && Settings.AlbumArtEnabled)
        {
            try
            {
                artUrl = await ArtFallback.FindCoverArtUrlAsync(item.Title, item.Artist, token);
                Log.LogDebug("iTunes had no cover for “{Title}” — “{Artist}”; Deezer fallback → {Result}",
                    item.Title, item.Artist, artUrl is null ? "no cover found" : "cover found");
            }
            catch (DeezerCoverArtException ex)
            {
                artLookedUp = false;   // transient Deezer failure — leave art unflagged so it retries later
                Log.LogWarning(ex, "Deezer cover fallback failed for “{Title}” — “{Artist}”; will retry later", item.Title, item.Artist);
            }
        }
        if (item.ArtworkUrl is null && artUrl is not null)
            item.ArtworkUrl = artUrl;
        item.ArtworkLookedUp = artLookedUp;   // hit or miss across both sources (unless Deezer failed transiently)
        item.MetadataLookedUp = true;   // metadata attempt is done regardless of the art fallback
        await Store.UpdateAsync(item);   // persist flag + any fills; Store.Changed → RefreshAsync

        return filled.Count > 0
            ? $"✨ Auto-filled {JoinFields(filled)} from “{meta!.MatchedTitle} — {meta.MatchedArtist}”."
            : null;
    }

    // A song is eligible for a cover-art lookup when album art is on, we've not looked before, and it has a title
    // AND artist to match on (iTunes rejects an artist-less match, so there'd be nothing to verify the cover against).
    private bool ShouldFetchArtwork(SongListItem item) =>
        Settings.AlbumArtEnabled &&
        item.ArtworkUrl is null &&
        !item.ArtworkLookedUp &&
        !string.IsNullOrWhiteSpace(item.Title) &&
        !string.IsNullOrWhiteSpace(item.Artist);

    // Fetch just the cover URL for a song that autofill didn't already cover (e.g. it already had year+genre, or
    // autofill is off). One iTunes call, gated on ArtworkLookedUp so a coverless song is never re-chased. The image
    // bytes are downloaded later by LoadArtAsync; here we only record where to get them.
    private async Task TryFetchArtworkUrlAsync(SongListItem item, CancellationToken token)
    {
        if (!ShouldFetchArtwork(item))
            return;

        Log.LogDebug("Artwork lookup start: “{Title}” — “{Artist}”", item.Title, item.Artist);
        string? art;
        try
        {
            var meta = await Metadata.LookupAsync(item.Title, item.Artist, token);
            // iTunes is primary; fall back to Deezer only when iTunes carries no cover. Logged as two branches so
            // the diagnostics say whether Deezer was even consulted and what it returned (the on-device mystery).
            if (meta?.ArtworkUrl is string itunesArt)
            {
                art = itunesArt;
                Log.LogDebug("Artwork from iTunes for “{Title}” — “{Artist}”", item.Title, item.Artist);
            }
            else
            {
                art = await ArtFallback.FindCoverArtUrlAsync(item.Title, item.Artist, token);
                Log.LogDebug("iTunes had no cover for “{Title}” — “{Artist}”; Deezer fallback → {Result}",
                    item.Title, item.Artist, art is null ? "no cover found" : "cover found");
            }
        }
        catch (Exception ex) when (ex is MetadataLookupException or DeezerCoverArtException)
        {
            // network/rate-limit failure on either source — leave the flag unset to retry later
            Log.LogWarning(ex, "Artwork lookup failed for “{Title}” — “{Artist}”; will retry later", item.Title, item.Artist);
            return;
        }

        if (token.IsCancellationRequested)
            return;

        if (art is not null)
            item.ArtworkUrl = art;
        item.ArtworkLookedUp = true;    // record the attempt (hit or miss) so we never re-spend on it
        Log.LogDebug("Artwork lookup done: “{Title}” — “{Artist}” → {Result}",
            item.Title, item.Artist, item.ArtworkUrl is null ? "no cover found" : "cover found");
        await Store.UpdateAsync(item);   // Store.Changed → RefreshAsync → LoadArtAsync caches + shows the image
    }

    // Detail-sheet entry point: enrich the open song and surface the year/genre result as the sheet's note. The
    // spinner + note are sheet-only UI; the actual fill/persist lives in TryAutoFillMetadataAsync. Also grabs the
    // cover URL (once) when album art is on, then caches its image so the card fills in. Skips all network when
    // there's nothing to do.
    private async Task LoadDetailSuggestionAsync(SongListItem? item)
    {
        _suggestCts?.Cancel();
        _autoFilledNote = null;
        _suggestionLoading = false;

        if (item is null)
            return;

        var needAutoFill = ShouldAutoFill(item);
        if (!needAutoFill && !ShouldFetchArtwork(item))
            return;

        _suggestCts = new CancellationTokenSource();
        var token = _suggestCts.Token;
        _suggestionLoading = needAutoFill;   // the spinner is for the visible year/genre fill only
        try
        {
            if (needAutoFill)
            {
                var note = await TryAutoFillMetadataAsync(item, token);
                if (token.IsCancellationRequested || _detailItem?.Id != item.Id)
                    return;
                _autoFilledNote = note;
            }

            // Autofill may have captured the cover from the same match; fetch separately only if it's still missing.
            if (ShouldFetchArtwork(item))
                await TryFetchArtworkUrlAsync(item, token);

            if (token.IsCancellationRequested || _detailItem?.Id != item.Id)
                return;

            // Make sure the (possibly just-discovered) cover image is cached + shown on the card behind the sheet.
            if (Settings.AlbumArtEnabled && item.ArtworkUrl is not null && !_artUris.ContainsKey(item.Id))
                _ = LoadArtAsync();
        }
        catch (OperationCanceledException) { return; }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                _suggestionLoading = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private void CloseDetail()
    {
        _suggestCts?.Cancel();
        _autoFilledNote = null;
        _suggestionLoading = false;
        _detailItem = null;
        _editing = false;
        // The page-scroll lock is reconciled from state in OnAfterRenderAsync — no explicit unlock needed here.
    }

    // Routes the Android back button to close the top-most sheet instead of navigating; active only while a sheet is open.
    private BackButtonOverlayGuard? _backGuard;

    // Closes the single top-most open overlay, matching the CSS stacking order (confirm pop-up > the --history
    // sub-sheets > the base detail sheet). Returns false when nothing is open (let navigation proceed).
    private bool TryCloseTopOverlay()
    {
        if (_historyConfirmIndex is not null) { CancelRemoveSungDate(); return true; }
        if (_ratingPromptItem is not null) { CloseRatingPrompt(); return true; }
        if (_historyItem is not null) { CloseHistory(); return true; }
        if (_lyricsItem is not null) { CloseLyrics(); return true; }
        if (_addOpen) { CloseAdd(); return true; }
        if (_filterSheetOpen) { CloseFilterSheet(); return true; }
        if (_detailItem is not null) { CloseDetail(); return true; }
        return false;
    }

    // Pull-down-to-dismiss from khSheet: the sheet already animated off-screen, so just close.
    [JSInvokable]
    public void CloseDetailFromSwipe()
    {
        CloseDetail();
        StateHasChanged();
    }

    private void StartEdit()
    {
        if (_detailItem is null)
            return;
        _editTitle = _detailItem.Title;
        _editArtist = _detailItem.Artist;
        _editGenre = _detailItem.Genre ?? string.Empty;
        _editNotes = _detailItem.Notes ?? string.Empty;
        _editYear = _detailItem.Year;
        _editTags = [.. _detailItem.Tags];
        _editing = true;
    }

    private void CancelEdit() => _editing = false;

    // Human list: "Genre", "Genre & Year", or (3+) "A, B, & C" — Oxford comma, ampersand before the last.
    private static string JoinFields(IReadOnlyList<string> parts) => parts.Count switch
    {
        0 => string.Empty,
        1 => parts[0],
        2 => $"{parts[0]} & {parts[1]}",
        _ => $"{string.Join(", ", parts.Take(parts.Count - 1))}, & {parts[^1]}",
    };

    private async Task SaveEditAsync()
    {
        if (_detailItem is null || !CanSaveEdit)
            return;

        var newTitle = _editTitle.Trim();
        var newArtist = _editArtist.Trim();
        // A title/artist change makes the current cover art belong to a different song — clear it so a fresh cover is
        // fetched for the new title/artist (rather than keeping the old, now-wrong image).
        var identityChanged = !string.Equals(newTitle, _detailItem.Title, StringComparison.Ordinal)
                           || !string.Equals(newArtist, _detailItem.Artist, StringComparison.Ordinal);

        _detailItem.Title = newTitle;
        _detailItem.Artist = newArtist;
        _detailItem.Genre = string.IsNullOrWhiteSpace(_editGenre) ? null : _editGenre.Trim();
        _detailItem.Notes = string.IsNullOrWhiteSpace(_editNotes) ? null : _editNotes.Trim();
        _detailItem.Year = _editYear;
        _detailItem.Tags = SongTags.Normalize(_editTags);

        if (identityChanged)
        {
            _detailItem.ArtworkUrl = null;
            _detailItem.ArtworkLookedUp = false;   // re-open the one-shot art lookup for the new title/artist
            _artUris.Remove(_detailItem.Id);       // drop the stale cover so the card doesn't keep showing it
            _ = JS.InvokeVoidAsync("khAlbumArt.revoke", _detailItem.Id.ToString());   // free its blob URL
        }

        await Store.UpdateAsync(_detailItem);
        _editing = false;

        if (identityChanged)
            await LoadDetailSuggestionAsync(_detailItem);   // fetch + cache a fresh cover for the new song
    }

    // ---- "Sang it" rating prompt -------------------------------------------------------------
    // Marking a song sung records a new performance; the singer rates how it went (or skips → unrated).

    private SongListItem? _ratingPromptItem;

    // Opens the shared rating prompt for a song (the component resets its own star/note buffers on open).
    private void OpenRatingPrompt(SongListItem? item)
    {
        if (item is not null)
            _ratingPromptItem = item;
    }

    // Dismissed without logging (✕ / backdrop).
    private void CloseRatingPrompt() => _ratingPromptItem = null;

    // The prompt committed (Save / Skip / swipe): append the performance (its how-it-went rating — 0 when
    // skipped — plus an optional note) and mark the song sung.
    private async Task OnRatingCommitAsync((int howItWent, string? note) result)
    {
        var item = _ratingPromptItem;
        _ratingPromptItem = null;
        if (item is null)
            return;

        item.Performances.Add(new Performance
        {
            Date = DateTimeOffset.Now,
            HowItWent = Math.Clamp(result.howItWent, 0, 5),
            Note = string.IsNullOrWhiteSpace(result.note) ? null : result.note.Trim(),
            VenueId = Session.ActiveVenueId,   // tag with wherever they are right now (null when not at a venue)
        });
        item.Status = SongListItemStatus.Sang;
        await Store.UpdateAsync(item);
    }

    // ---- Sung history sheet ------------------------------------------------------------------

    private SongListItem? _historyItem;
    private int? _historyConfirmIndex;   // index (into Performances) whose X is armed for confirm; null = none

    private void OpenHistory()
    {
        _historyItem = _detailItem;
        _historyConfirmIndex = null;
    }

    private void CloseHistory()
    {
        _historyItem = null;
        _historyConfirmIndex = null;
    }

    // Pull-down-to-dismiss from khSheet (history sheet already animated off-screen). No teardown here — the
    // detail sheet is still open behind it, so the page-scroll lock must stay until that closes.
    [JSInvokable]
    public void CloseHistoryFromSwipe()
    {
        CloseHistory();
        StateHasChanged();
    }

    private void ArmRemoveSungDate(int index) => _historyConfirmIndex = index;

    private void CancelRemoveSungDate() => _historyConfirmIndex = null;

    private async Task RemoveSungDateAsync(int index)
    {
        if (_historyItem is null || index < 0 || index >= _historyItem.Performances.Count)
            return;

        _historyItem.Performances.RemoveAt(index);
        _historyConfirmIndex = null;

        if (_historyItem.Performances.Count == 0)
        {
            // Last performance gone — the song reverts to unsung: back on the wishlist.
            _historyItem.Status = SongListItemStatus.WantToSing;
            await Store.UpdateAsync(_historyItem);
            CloseHistory();
            return;
        }

        await Store.UpdateAsync(_historyItem);
    }

    // Edit one performance's "how it went" rating from the history sheet; the song's average recomputes from it.
    private async Task UpdatePerformanceRatingAsync(int index, int rating)
    {
        if (_historyItem is null || index < 0 || index >= _historyItem.Performances.Count)
            return;

        _historyItem.Performances[index].HowItWent = Math.Clamp(rating, 0, 5);
        await Store.UpdateAsync(_historyItem);
    }

    // Edit one performance's note from the history sheet (saved on blur/change).
    private async Task UpdatePerformanceNoteAsync(int index, string? note)
    {
        if (_historyItem is null || index < 0 || index >= _historyItem.Performances.Count)
            return;

        _historyItem.Performances[index].Note = string.IsNullOrWhiteSpace(note) ? null : note.Trim();
        await Store.UpdateAsync(_historyItem);
    }


@page "/about"
@layout MainLayout
@using Microsoft.Maui.ApplicationModel

<section class="about">
    <div class="page-head">
        <NavLink class="page-back" href="" aria-label="Back to my songs">←</NavLink>
        <h1 class="page-title">About</h1>
    </div>
    <div class="about__logo brand-mark">kH</div>
    <div class="about__title">Cue</div>
    <p class="about__tagline">You're on cue.</p>
    <p class="about__version">Version @AppInfo.Current.VersionString</p>

    <p class="about__lead">
        The singer &amp; patron companion app for <strong>KHost</strong> — open-source karaoke host software.
    </p>
    <p class="about__body">
        Keep a personal wishlist of songs you'd like to sing, track how each one went, and revisit your
        sung history. Everything lives on your device.
    </p>

    <div class="about__meta">
        <span>Built with .NET MAUI Blazor Hybrid</span>
        <span>iOS &amp; Android</span>
    </div>

</section>

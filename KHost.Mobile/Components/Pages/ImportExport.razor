@page "/import-export"
@layout MainLayout
@using Microsoft.Maui.Storage
@using Microsoft.Maui.ApplicationModel.DataTransfer
@using KHost.Mobile.Clients.Enrichment
@using KHost.Mobile.Clients.Spotify
@using KHost.Mobile.Clients.YouTubeMusic
@inject ISongListStore Store
@inject ISingerStore Singers
@inject IVenueStore Venues
@inject IAppSession Session
@inject ISpotifyImportService Spotify
@inject IYouTubeMusicImportService YtMusic
@inject ITrackMetadataLookup Metadata
@inject IAppSettings Settings
@inject IBackButtonService BackButton
@inject NavigationManager Nav
@implements IDisposable

<section class="ie">
    <div class="page-head">
        <NavLink class="page-back" href="" aria-label="Back to my songs">←</NavLink>
        <h1 class="page-title">Import &amp; Export</h1>
    </div>

    @* ---- Singer profile: identity + songs + sung history (not the Tonight set) ---- *@
    <div class="card">
        <div class="section-title">Singer profile</div>
        <p class="ie__lead">Move a singer — their songs and sung history — to another device, or keep a backup. Tonight's set stays on this device.</p>
        <div class="ie-actions" data-tut="profile">
            <button type="button" class="ie-action" @onclick="ExportProfileAsync" disabled="@_profileBusy">
                <span class="ie-action__icon" aria-hidden="true">📤</span>
                <span class="ie-action__text">
                    <span class="ie-action__title">@(_profileBusy ? "Exporting…" : $"Export {ActiveSingerName}'s profile")</span>
                    <span class="ie-action__desc">@_songCount song@(_songCount == 1 ? "" : "s") + history, as .json</span>
                </span>
            </button>
            <button type="button" class="ie-action" @onclick="ImportProfileAsync" disabled="@_fileBusy">
                <span class="ie-action__icon" aria-hidden="true">📥</span>
                <span class="ie-action__text">
                    <span class="ie-action__title">@(_fileBusy ? "Reading…" : "Import a profile")</span>
                    <span class="ie-action__desc">Add a singer from a .json file</span>
                </span>
            </button>
        </div>
    </div>

    @* ---- Venues: shared across singers, so their own export/import ---- *@
    <div class="card">
        <div class="section-title">Venues</div>
        <p class="ie__lead">Venues are shared by everyone on this device. Export the list, or merge one in.</p>
        <div class="ie-actions" data-tut="venues-ie">
            <button type="button" class="ie-action" @onclick="ExportVenuesAsync" disabled="@(_venueBusy || _venueCount == 0)">
                <span class="ie-action__icon" aria-hidden="true">📤</span>
                <span class="ie-action__text">
                    <span class="ie-action__title">@(_venueBusy ? "Exporting…" : "Export venues")</span>
                    <span class="ie-action__desc">
                        @(_venueCount == 0 ? "No venues to export yet" : $"{_venueCount} venue{(_venueCount == 1 ? "" : "s")} as .json")
                    </span>
                </span>
            </button>
            <button type="button" class="ie-action" @onclick="ImportVenuesAsync" disabled="@_venueFileBusy">
                <span class="ie-action__icon" aria-hidden="true">📥</span>
                <span class="ie-action__text">
                    <span class="ie-action__title">@(_venueFileBusy ? "Reading…" : "Import venues")</span>
                    <span class="ie-action__desc">Merge venues from a .json file</span>
                </span>
            </button>
        </div>
    </div>

    @* ---- Third-party import: songs from a public playlist ---- *@
    <div class="card">
        <div class="section-title">Third-party import</div>
        <p class="ie__lead">Pull songs into your list from a public playlist.</p>
        <div class="ie-actions" data-tut="third-party">
            <button type="button" class="ie-action" @onclick="() => OpenImport(ImportSource.Spotify)">
                <span class="ie-action__icon" aria-hidden="true">
                    <SpotifyIcon Size="26" />
                </span>
                <span class="ie-action__text">
                    <span class="ie-action__title">Import from Spotify</span>
                    <span class="ie-action__desc">A public playlist link</span>
                </span>
            </button>
            <button type="button" class="ie-action" @onclick="() => OpenImport(ImportSource.YouTubeMusic)">
                <span class="ie-action__icon" aria-hidden="true">
                    <YouTubeMusicIcon Size="26" />
                </span>
                <span class="ie-action__text">
                    <span class="ie-action__title">Import from YouTube Music</span>
                    <span class="ie-action__desc">A public playlist link</span>
                </span>
            </button>
        </div>
    </div>
</section>

@* ---- Profile-import decision sheet: add as a new singer, or merge songs into the current one ---- *@
@if (_pendingProfile is { } profile)
{
    <div class="sheet-backdrop" @onclick="CancelProfileImport"></div>
    <div class="sheet" role="dialog" aria-modal="true">
        <button type="button" class="sheet__close" @onclick="CancelProfileImport" aria-label="Close">✕</button>
        <div class="sheet__title">Import @profile.Singer.Name's profile</div>
        <div class="sheet__subtitle">
            @profile.Songs.Count song@(profile.Songs.Count == 1 ? "" : "s")@(ProfilePerformanceCount(profile) is var p && p > 0 ? $" · {p} sung performance{(p == 1 ? "" : "s")}" : "") · exported @profile.ExportedAt.LocalDateTime.ToString("MMM d")
        </div>

        <button type="button" class="ie-choice ie-choice--primary" @onclick="() => AddProfileAsNewSingerAsync(profile)" disabled="@_profileImportBusy">
            <span class="ie-choice__ico">＋</span>
            <span class="ie-choice__text">
                <span class="ie-choice__title">Add as a new singer</span>
                <span class="ie-choice__desc">@profile.Singer.Name joins this device with their own My Songs and history, and becomes the active singer.</span>
            </span>
        </button>
        <button type="button" class="ie-choice" @onclick="() => MergeProfileIntoCurrentAsync(profile)" disabled="@_profileImportBusy">
            <span class="ie-choice__ico">⤵</span>
            <span class="ie-choice__text">
                <span class="ie-choice__title">Merge songs into @ActiveSingerName</span>
                <span class="ie-choice__desc">Just the songs, added to your current list. Identity and history are left behind.</span>
            </span>
        </button>
        <button type="button" class="btn btn-secondary" @onclick="CancelProfileImport" disabled="@_profileImportBusy">Cancel</button>
    </div>
}

@if (_flash is not null)
{
    <div class="snackbar" role="status">
        <span class="snackbar__text">@_flash</span>
    </div>
}

@if (_importOpen)
{
    <div class="sheet-backdrop" @onclick="CloseImport"></div>
    <div class="sheet" role="dialog" aria-modal="true">
        <button type="button" class="sheet__close" @onclick="CloseImport" aria-label="Close">✕</button>
        @if (_reviewRows is not null)
        {
            <div class="sheet__title">Fill in details</div>
            <div class="sheet__subtitle">
                @(_reviewEnriching
                    ? $"Looking up {_reviewDoneCount} of {_reviewRows.Count}…"
                    : $"Found details for {_reviewRows.Count(HasApplyable)} of {_reviewRows.Count}. Review, then apply.")
            </div>
            <ul class="import-list review-list">
                @foreach (var row in _reviewRows)
                {
                    <li class="import-row">
                        <label class="import-row__label">
                            @if (row.Done && HasApplyable(row))
                            {
                                <input type="checkbox" @bind="row.Selected" />
                            }
                            else
                            {
                                <span class="review-spacer"></span>
                            }
                            <span class="import-row__text">
                                <span class="import-row__title">@row.Item.Title</span>
                                <span class="import-row__artist">@row.Item.Artist</span>
                            </span>
                            <span class="review-result">
                                @if (!row.Done)
                                {
                                    <span class="sheet__muted">…</span>
                                }
                                else if (HasApplyable(row))
                                {
                                    @ReviewSummary(row)
                                }
                                else
                                {
                                    <span class="sheet__muted">no match</span>
                                }
                            </span>
                        </label>
                    </li>
                }
            </ul>
            <div class="sheet__actions">
                <button class="btn btn-secondary" @onclick="SkipReview">Skip</button>
                <button class="btn btn-primary" @onclick="ApplyReviewAsync" disabled="@(_reviewSelectedCount == 0)">
                    Apply @_reviewSelectedCount
                </button>
            </div>
        }
        else
        {
        <div class="sheet__title">Import from @SourceName</div>
        <div class="sheet__subtitle">Paste a public playlist link — we'll pull in the song titles &amp; artists.</div>

        <div class="field" style="margin-top:0.85rem">
            <label class="field__label" for="imp-url">Playlist link</label>
            <input id="imp-url" class="input" placeholder="@SourcePlaceholder"
                   @bind="_importUrl" @bind:event="oninput" />
        </div>

        @if (_importError is not null)
        {
            <div class="field__error">@_importError</div>
        }

        @if (_importRows is null)
        {
            <button class="btn btn-primary" @onclick="FetchImportAsync"
                    disabled="@(_importBusy || string.IsNullOrWhiteSpace(_importUrl))">
                @(_importBusy ? "Fetching…" : "Fetch playlist")
            </button>
        }
        else
        {
            <div class="import-head">
                <span class="import-head__name">@_importName</span>
                <span class="import-head__actions">
                    <button class="btn-link" @onclick="SelectAllImport">All</button>
                    <button class="btn-link" @onclick="SelectNoneImport">None</button>
                </span>
            </div>
            @if (_importTruncated)
            {
                <div class="field__hint">Showing the first 100 tracks — longer playlists are trimmed.</div>
            }
            <ul class="import-list">
                @foreach (var row in _importRows)
                {
                    <li class="import-row @(row.AlreadyInList ? "is-dupe" : "")">
                        <label class="import-row__label">
                            <input type="checkbox" @bind="row.Selected" />
                            <span class="import-row__text">
                                <span class="import-row__title">@row.Title</span>
                                <span class="import-row__artist">@row.Artist</span>
                            </span>
                            @if (row.AlreadyInList)
                            {
                                <span class="import-row__badge">already added</span>
                            }
                        </label>
                    </li>
                }
            </ul>
            <div class="sheet__actions">
                <button class="btn btn-secondary" @onclick="CloseImport">Cancel</button>
                <button class="btn btn-primary" @onclick="ImportSelectedAsync"
                        disabled="@(_importBusy || _selectedImportCount == 0)">
                    @(_importBusy ? "Importing…" : $"Import {_selectedImportCount} song{(_selectedImportCount == 1 ? "" : "s")}")
                </button>
            </div>
        }
        }
    </div>
}

@code {
    // The current list drives the export count and the "already added" badge on playlist rows.
    private IReadOnlyList<SongListItem> _items = [];
    private int _songCount => _items.Count;

    // The active singer (for the profile export label) + the shared venue count.
    private Singer? _activeSinger;
    private string ActiveSingerName => _activeSinger?.Name is { Length: > 0 } n ? n : "this singer";
    private int _venueCount;

    // Native round-trips (FilePicker / Share); busy flags gate their buttons.
    private bool _fileBusy;          // reading a picked profile file
    private bool _profileBusy;       // exporting a profile
    private bool _venueBusy;         // exporting venues
    private bool _venueFileBusy;     // reading a picked venues file

    // The profile a picked file parsed to, awaiting the add-as-new-singer / merge choice (null = sheet closed).
    private SingerProfile? _pendingProfile;
    private bool _profileImportBusy;

    private static readonly FilePickerFileType JsonFileType = new(new Dictionary<DevicePlatform, IEnumerable<string>>
    {
        [DevicePlatform.Android] = ["application/json"],
        [DevicePlatform.iOS] = ["public.json", "public.text"],
        [DevicePlatform.WinUI] = [".json"],
        [DevicePlatform.macOS] = ["json"],
    });

    // Playlist import sheet (Spotify or YouTube Music). _importRows is null until a fetch succeeds.
    private enum ImportSource { Spotify, YouTubeMusic }
    private ImportSource _importSource;
    private bool _importOpen;
    private string _importUrl = string.Empty;
    private bool _importBusy;
    private string? _importError;
    private string? _importName;
    private bool _importTruncated;
    private List<ImportRow>? _importRows;
    private int _selectedImportCount => _importRows?.Count(r => r.Selected) ?? 0;

    // Post-import review: after songs are added, enrich them in the background (throttled to respect the
    // lookup rate limit) and let the user apply the found year/genre in bulk. Null = no review in progress.
    private List<ReviewRow>? _reviewRows;
    private bool _reviewEnriching;
    private int _reviewDoneCount;
    private CancellationTokenSource? _reviewCts;
    private int _reviewSelectedCount => _reviewRows?.Count(r => r.Done && HasApplyable(r) && r.Selected) ?? 0;

    // Transient toast (import/export result), shown in the snackbar slot; auto-dismisses.
    private string? _flash;
    private CancellationTokenSource? _flashCts;

    // One reviewed song: the persisted item + its suggestion once looked up.
    private sealed class ReviewRow
    {
        public required SongListItem Item { get; init; }
        public TrackMetadata? Suggestion { get; set; }
        public bool Done { get; set; }        // lookup finished (hit or miss)
        public bool Selected { get; set; } = true;
    }

    // Source-agnostic preview row: both Spotify and YT Music fetches are projected to title + artist.
    private sealed class ImportRow
    {
        public required string Title { get; init; }
        public required string Artist { get; init; }
        public bool Selected { get; set; }
        public bool AlreadyInList { get; init; }
    }

    private bool HasApplyable(ReviewRow row) =>
        row.Suggestion is not null &&
        (row.Suggestion.Year.HasValue || Genres.Map(row.Suggestion.Genre) is not null);

    private string ReviewSummary(ReviewRow row)
    {
        var parts = new List<string>();
        if (row.Suggestion?.Year is int y) parts.Add(y.ToString());
        if (Genres.Map(row.Suggestion?.Genre) is string g) parts.Add(g);
        return string.Join(" · ", parts);
    }

    private string SourceName => _importSource == ImportSource.Spotify ? "Spotify" : "YouTube Music";
    private string SourcePlaceholder => _importSource == ImportSource.Spotify
        ? "https://open.spotify.com/playlist/…"
        : "https://music.youtube.com/playlist?list=…";

    protected override async Task OnInitializedAsync()
    {
        _backGuard = new BackButtonOverlayGuard(BackButton,
            closeTopMost: TryCloseTopOverlay,
            notifyStateChanged: StateHasChanged);
        Store.Changed += OnStoreChanged;
        Venues.Changed += OnStoreChanged;
        Session.ActiveSingerChanged += OnStoreChanged;   // profile label follows a singer switch
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _items = await Store.GetAllAsync();
        _venueCount = (await Venues.GetAllAsync()).Count;
        _activeSinger = Session.ActiveSingerId is { } id ? await Singers.GetAsync(id) : null;
    }

    // Routes the Android back button to close the import sheet instead of navigating; active only while it's open.
    private BackButtonOverlayGuard? _backGuard;

    private bool TryCloseTopOverlay()
    {
        if (_pendingProfile is not null) { CancelProfileImport(); return true; }
        if (_importOpen) { CloseImport(); return true; }
        return false;
    }

    // Bridge the store's synchronous Changed event to async work without `async void`: a void handler hands
    // the reload to InvokeAsync, which marshals it onto the render thread (Changed can fire from a background
    // thread) and owns the continuation. Fire-and-forget by necessity — an event has nothing to await it — but
    // the task swallows its own failures so nothing is unobserved, matching the store's "don't crash" approach.
    private void OnStoreChanged(object? sender, EventArgs e) => _ = RefreshFromStoreAsync();

    private async Task RefreshFromStoreAsync()
    {
        try
        {
            await InvokeAsync(async () =>
            {
                await ReloadAsync();
                StateHasChanged();
            });
        }
        catch
        {
            // Best-effort refresh: a failed reload just leaves the last-known list on screen.
        }
    }

    // ---- Singer profile: export + import ------------------------------------------------------

    private async Task ExportProfileAsync()
    {
        if (_profileBusy)
            return;

        _profileBusy = true;
        try
        {
            var singer = _activeSinger ?? new Singer { Name = "Me" };   // session-less fallback
            var songs = await Store.GetAllAsync();
            var json = SingerProfileCodec.Serialize(SingerProfile.Create(singer, songs));
            await ShareJsonAsync($"khost-{Slug(singer.Name)}-profile-{DateTime.Now:yyyy-MM-dd}.json", json, "Export singer profile");
        }
        catch (Exception ex)
        {
            await FlashAsync($"Export failed: {ex.Message}");
        }
        finally
        {
            _profileBusy = false;
        }
    }

    private async Task ImportProfileAsync()
    {
        if (_fileBusy)
            return;

        _fileBusy = true;
        try
        {
            var text = await ReadPickedTextAsync("Choose a KHost Cue profile");
            if (text is null)
                return;   // cancelled

            switch (SingerProfileCodec.Detect(text))
            {
                case SingerProfileCodec.FileKind.Profile:
                    if (SingerProfileCodec.ParseProfile(text) is { } profile)
                        _pendingProfile = profile;   // open the add-as-new / merge decision sheet
                    else
                        await FlashAsync("That profile file couldn't be read.");
                    break;

                case SingerProfileCodec.FileKind.LegacySongList:
                    // An old songs-only export → merge straight into the current singer (fresh ids, as before).
                    var songs = SingerProfileCodec.ParseLegacySongs(text) ?? [];
                    foreach (var s in songs)
                        s.Id = Guid.NewGuid();
                    var added = await Store.ImportAsync(songs, skipDuplicates: true);
                    await FlashAsync($"Imported {added} song{(added == 1 ? "" : "s")} from file");
                    break;

                default:
                    await FlashAsync("That file isn't a KHost Cue profile.");
                    break;
            }
        }
        catch (Exception ex)
        {
            await FlashAsync($"Import failed: {ex.Message}");
        }
        finally
        {
            _fileBusy = false;
        }
    }

    private static int ProfilePerformanceCount(SingerProfile profile) => profile.Songs.Sum(s => s.Performances.Count);

    // Add-as-new-singer: keep the singer + song ids (a true restore). If the singer already exists, update their
    // identity and upsert their songs by id (nothing is lost); otherwise create them. Either way switch to them.
    private async Task AddProfileAsNewSingerAsync(SingerProfile profile)
    {
        if (_profileImportBusy)
            return;

        _profileImportBusy = true;
        try
        {
            var singer = profile.Singer;
            if (await Singers.GetAsync(singer.Id) is null)
                await Singers.AddAsync(singer);      // AddAsync keeps a provided (non-blank) id
            else
                await Singers.UpdateAsync(singer);

            Session.SetActiveSinger(singer.Id);      // the song store now targets this singer's file
            Settings.LastActiveSingerId = singer.Id.ToString();
            var written = await Store.MergeByIdAsync(profile.Songs);

            _pendingProfile = null;
            await FlashAsync($"Imported {singer.Name} — {written} song{(written == 1 ? "" : "s")}");
            Nav.NavigateTo("/");   // land on My Songs as the imported singer
        }
        catch (Exception ex)
        {
            await FlashAsync($"Import failed: {ex.Message}");
        }
        finally
        {
            _profileImportBusy = false;
        }
    }

    // Merge-songs-only: copy the profile's songs into the CURRENT singer's list as fresh wishlist entries (new
    // ids, no history), deduped by title+artist. Identity and sung history are left behind.
    private async Task MergeProfileIntoCurrentAsync(SingerProfile profile)
    {
        if (_profileImportBusy)
            return;

        _profileImportBusy = true;
        try
        {
            var copies = profile.Songs
                .Where(s => !string.IsNullOrWhiteSpace(s.Title))
                .Select(s => new SongListItem
                {
                    Title = s.Title,
                    Artist = s.Artist,
                    Notes = s.Notes,
                    Genre = s.Genre,
                    Year = s.Year,
                    Enjoyment = s.Enjoyment,
                    IsFavorite = s.IsFavorite,
                    Tags = [.. s.Tags],
                    MetadataLookedUp = s.MetadataLookedUp,
                    ArtworkLookedUp = s.ArtworkLookedUp,
                })
                .ToList();

            var added = await Store.ImportAsync(copies, skipDuplicates: true);
            _pendingProfile = null;
            await FlashAsync($"Merged {added} song{(added == 1 ? "" : "s")} into {ActiveSingerName}");
        }
        finally
        {
            _profileImportBusy = false;
        }
    }

    private void CancelProfileImport()
    {
        _pendingProfile = null;
        _profileImportBusy = false;
    }

    // ---- Venues: export + import (shared, so their own file) ----------------------------------

    private async Task ExportVenuesAsync()
    {
        if (_venueBusy || _venueCount == 0)
            return;

        _venueBusy = true;
        try
        {
            var venues = await Venues.GetAllAsync();
            var json = SingerProfileCodec.SerializeVenues(venues);
            await ShareJsonAsync($"khost-venues-{DateTime.Now:yyyy-MM-dd}.json", json, "Export venues");
        }
        catch (Exception ex)
        {
            await FlashAsync($"Export failed: {ex.Message}");
        }
        finally
        {
            _venueBusy = false;
        }
    }

    private async Task ImportVenuesAsync()
    {
        if (_venueFileBusy)
            return;

        _venueFileBusy = true;
        try
        {
            var text = await ReadPickedTextAsync("Choose a KHost Cue venues file");
            if (text is null)
                return;   // cancelled

            var incoming = SingerProfileCodec.ParseVenues(text);
            if (incoming is null)
            {
                await FlashAsync("That file isn't a valid venues export.");
                return;
            }

            // Merge by id, keeping ids so venue-tagged history keeps resolving: update existing, add the rest.
            var existing = (await Venues.GetAllAsync()).Select(v => v.Id).ToHashSet();
            int added = 0, updated = 0;
            foreach (var v in incoming)
            {
                if (string.IsNullOrWhiteSpace(v.Name))
                    continue;   // not a venues file (or a blank row)
                if (existing.Contains(v.Id))
                {
                    await Venues.UpdateAsync(v);
                    updated++;
                }
                else
                {
                    await Venues.AddAsync(v);   // keeps the provided id
                    added++;
                }
            }

            await FlashAsync(added + updated == 0
                ? "No venues found in that file."
                : $"Venues merged — {added} added, {updated} updated");
        }
        catch (Exception ex)
        {
            await FlashAsync($"Import failed: {ex.Message}");
        }
        finally
        {
            _venueFileBusy = false;
        }
    }

    // ---- Shared file helpers ------------------------------------------------------------------

    // Pick a .json file and read it to text. Returns null if the user cancelled. Uses OpenReadAsync so the
    // content:// URI works on Android (never .FullPath).
    private static async Task<string?> ReadPickedTextAsync(string pickerTitle)
    {
        var pick = await FilePicker.Default.PickAsync(new PickOptions { PickerTitle = pickerTitle, FileTypes = JsonFileType });
        if (pick is null)
            return null;

        await using var stream = await pick.OpenReadAsync();
        using var reader = new StreamReader(stream);
        return await reader.ReadToEndAsync();
    }

    // Write json to a cache file and hand it to the OS share sheet (Files, Drive, email, …).
    private static async Task ShareJsonAsync(string fileName, string json, string title)
    {
        var path = Path.Combine(FileSystem.CacheDirectory, fileName);
        await File.WriteAllTextAsync(path, json);
        await Share.Default.RequestAsync(new ShareFileRequest { Title = title, File = new ShareFile(path) });
    }

    // Filename-safe lower-kebab of a singer name (non-alphanumerics → '-'); falls back to "singer" when empty.
    private static string Slug(string name)
    {
        var slug = new string([.. name.Trim().ToLowerInvariant().Select(c => char.IsLetterOrDigit(c) ? c : '-')]).Trim('-');
        return slug.Length == 0 ? "singer" : slug;
    }

    // ---- Playlist import (Spotify / YouTube Music) --------------------------------------------

    private void OpenImport(ImportSource source)
    {
        _importSource = source;
        _importOpen = true;
        _importUrl = string.Empty;
        _importRows = null;
        _importError = null;
        _importName = null;
        _importTruncated = false;
        _reviewCts?.Cancel();
        _reviewRows = null;
        _reviewEnriching = false;
    }

    private void CloseImport()
    {
        _importOpen = false;
        _importBusy = false;
        _reviewCts?.Cancel();
        _reviewRows = null;
        _reviewEnriching = false;
    }

    private async Task FetchImportAsync()
    {
        if (string.IsNullOrWhiteSpace(_importUrl) || _importBusy)
            return;

        _importBusy = true;
        _importError = null;
        try
        {
            // Each source's fetch is projected to a common (name, tracks, truncated) shape.
            string? name;
            bool truncated;
            List<(string Title, string Artist)> tracks;

            if (_importSource == ImportSource.Spotify)
            {
                var result = await Spotify.FetchPlaylistAsync(_importUrl.Trim());
                name = result.Name;
                truncated = result.LikelyTruncated;
                tracks = result.Tracks.Select(t => (t.Title, t.Artist)).ToList();
            }
            else
            {
                var result = await YtMusic.FetchPlaylistAsync(_importUrl.Trim());
                name = result.Name;
                truncated = result.LikelyTruncated;
                tracks = result.Tracks.Select(t => (t.Title, t.Artist)).ToList();
            }

            _importName = string.IsNullOrWhiteSpace(name) ? "Playlist" : name;
            _importTruncated = truncated;
            _importRows = tracks.Select(t => new ImportRow
            {
                Title = t.Title,
                Artist = t.Artist,
                AlreadyInList = _items.Any(i =>
                    string.Equals(i.Title.Trim(), t.Title, StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(i.Artist.Trim(), t.Artist, StringComparison.OrdinalIgnoreCase)),
            }).ToList();

            foreach (var row in _importRows)
                row.Selected = !row.AlreadyInList;

            if (_importRows.Count == 0)
                _importError = "That playlist has no importable tracks.";
        }
        catch (Exception ex) when (ex is SpotifyImportException or YouTubeMusicImportException)
        {
            _importError = ex.Message;
            _importRows = null;
        }
        finally
        {
            _importBusy = false;
        }
    }

    private void SelectAllImport()
    {
        if (_importRows is null) return;
        foreach (var row in _importRows) row.Selected = true;
    }

    private void SelectNoneImport()
    {
        if (_importRows is null) return;
        foreach (var row in _importRows) row.Selected = false;
    }

    private async Task ImportSelectedAsync()
    {
        if (_importRows is null || _importBusy)
            return;

        var chosen = _importRows.Where(r => r.Selected).ToList();
        if (chosen.Count == 0)
            return;

        _importBusy = true;
        try
        {
            // Imported as unsung wishlist entries: title + artist only (no year/genre from either source).
            var toImport = chosen.Select(r => new SongListItem { Title = r.Title, Artist = r.Artist }).ToList();

            // Selection already excludes duplicates; a force-ticked duplicate is honored (skipDuplicates: false).
            var added = await Store.ImportAsync(toImport, skipDuplicates: false);   // Store.Changed → reload _items
            await FlashAsync($"Imported {added} song{(added == 1 ? "" : "s")} from {SourceName}");

            _importRows = null;
            if (Settings.AutoFillMetadata)
            {
                // The sheet stays open, showing enrichment progress.
                _reviewRows = toImport.Select(i => new ReviewRow { Item = i }).ToList();
                _ = StartReviewEnrichmentAsync();
            }
            else
            {
                // Auto-fill is off: no iTunes lookups. Close the sheet; the imported songs keep MetadataLookedUp
                // unset, so they'll get a per-song auto-fill later if the toggle is turned back on.
                _importOpen = false;
            }
        }
        finally
        {
            _importBusy = false;
        }
    }

    // Look up each freshly-imported song one at a time, spaced out to stay under the lookup rate limit.
    // Fire-and-forget from ImportSelectedAsync; cancelled if the sheet closes, a new import starts, or we navigate away.
    private const int ReviewThrottleMs = 3000;   // ~20/min

    private async Task StartReviewEnrichmentAsync()
    {
        _reviewCts?.Cancel();
        _reviewCts = new CancellationTokenSource();
        var token = _reviewCts.Token;

        var rows = _reviewRows;
        if (rows is null)
            return;

        _reviewEnriching = true;
        _reviewDoneCount = 0;
        await InvokeAsync(StateHasChanged);

        try
        {
            for (var i = 0; i < rows.Count; i++)
            {
                token.ThrowIfCancellationRequested();
                var row = rows[i];

                // Every lookup here is a live call (these songs were just imported, so none are looked up
                // yet), so always space them out to stay under the rate limit.
                try
                {
                    row.Suggestion = await Metadata.LookupAsync(row.Item.Title, row.Item.Artist, token);
                }
                catch (MetadataLookupException)
                {
                    row.Suggestion = null;   // treat a transient failure as "no match" for this pass
                }
                row.Done = true;
                row.Selected = HasApplyable(row);
                _reviewDoneCount = i + 1;
                await InvokeAsync(StateHasChanged);

                if (i < rows.Count - 1)
                    await Task.Delay(ReviewThrottleMs, token);
            }
        }
        catch (OperationCanceledException) { return; }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                _reviewEnriching = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    // Apply the checked suggestions (blank fields only), and mark every looked-up song as done so it isn't
    // auto-looked-up again — including rows the user unchecked (their choice to skip sticks). One bulk write.
    private async Task ApplyReviewAsync()
    {
        if (_reviewRows is null)
            return;

        _reviewCts?.Cancel();
        var done = _reviewRows.Where(r => r.Done).ToList();
        var applied = 0;
        foreach (var row in done)
        {
            if (row.Selected && HasApplyable(row))
            {
                var changed = false;
                if (string.IsNullOrWhiteSpace(row.Item.Genre) && Genres.Map(row.Suggestion?.Genre) is string g)
                {
                    row.Item.Genre = g;
                    changed = true;
                }
                if (!row.Item.Year.HasValue && row.Suggestion?.Year is int y)
                {
                    row.Item.Year = y;
                    changed = true;
                }
                if (changed)
                    applied++;
            }
            row.Item.MetadataLookedUp = true;   // looked up in this pass — don't auto-look-up again
        }

        await Store.UpdateRangeAsync(done.Select(r => r.Item));   // one write; Store.Changed → reload _items

        _reviewRows = null;
        _reviewEnriching = false;
        _importOpen = false;
        await FlashAsync($"Filled details for {applied} song{(applied == 1 ? "" : "s")}");
    }

    // Skip applying anything. No writes — the flag stays unset, so each song still gets a fresh, per-song
    // auto-fill attempt if/when it's opened in the detail sheet later.
    private void SkipReview()
    {
        _reviewCts?.Cancel();
        _reviewRows = null;
        _reviewEnriching = false;
        _importOpen = false;
    }

    private async Task FlashAsync(string message)
    {
        _flashCts?.Cancel();
        _flashCts = new CancellationTokenSource();
        var token = _flashCts.Token;

        _flash = message;
        await InvokeAsync(StateHasChanged);

        try { await Task.Delay(3500, token); }
        catch (TaskCanceledException) { return; }   // superseded by a newer flash

        _flash = null;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _backGuard?.Dispose();
        Store.Changed -= OnStoreChanged;
        Venues.Changed -= OnStoreChanged;
        Session.ActiveSingerChanged -= OnStoreChanged;
        _reviewCts?.Cancel();     // stop a background review if the user navigates away mid-enrichment
        _reviewCts?.Dispose();
        _flashCts?.Cancel();
        _flashCts?.Dispose();
    }
}

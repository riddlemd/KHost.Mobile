@* Shared "set your KaraFun venue" prompt. Shown when @Show is true; the user pastes a venue link (or the bare ID) —
   or, on Android/iOS, scans the venue's QR code — we parse it live and raise OnSave with the venue ID, or OnClose on
   cancel/backdrop. The host owns the @Show state and persists the saved ID. Reused by Settings and the My Songs
   detail sheet. Uses the --history stacking so it sits above the song detail sheet when opened from there. *@
@using Microsoft.Maui.Devices
@inject IQrScanner Scanner
@if (Show)
{
    <div class="sheet-backdrop sheet-backdrop--history" @onclick="OnClose"></div>
    <div class="sheet sheet--history" role="dialog" aria-modal="true">
        <button type="button" class="sheet__close" @onclick="OnClose" aria-label="Close">✕</button>
        <div class="sheet__title">Set your KaraFun venue</div>
        <div class="sheet__subtitle">Paste a link from your venue's KaraFun page — we'll pull out the venue ID.</div>

        <div class="field" style="margin-top:0.85rem">
            <label class="field__label" for="kf-venue-url">KaraFun link <span class="field__hint">— or the ID itself</span></label>
            <div class="kf-venue__input-row">
                <input id="kf-venue-url" class="input" placeholder="https://www.karafun.com/012345/…"
                       @bind="_input" @bind:event="oninput" />
                @* Scanning is native (ML Kit / Apple Vision), so the QR button shows only on Android/iOS; elsewhere the user pastes the link. *@
                @if (_scanSupported)
                {
                    <button type="button" class="kf-venue__scan" @onclick="ScanAsync" disabled="@_scanning"
                            aria-label="Scan QR code" title="Scan QR code">
                        <QrCodeIcon Class="kf-venue__qr" />
                    </button>
                }
            </div>
        </div>

        @if (Parsed is { } id)
        {
            <div class="kf-venue__ok">✓ Venue ID <b>@id</b></div>
        }
        else if (!string.IsNullOrWhiteSpace(_input))
        {
            <div class="field__error">That doesn't look like a KaraFun venue link or ID.</div>
        }
        else if (_scanError is not null)
        {
            <div class="field__error">@_scanError</div>
        }

        <div class="sheet__actions" style="margin-top:1rem">
            <button class="btn btn-secondary" @onclick="OnClose">Cancel</button>
            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@(Parsed is null)">Save venue</button>
        </div>
    </div>
}

@code {
    /// <summary>Whether the prompt is shown. Setting it true (re)opens the sheet seeded with <see cref="CurrentId"/>.</summary>
    [Parameter] public bool Show { get; set; }

    /// <summary>The venue ID already saved, used to pre-fill the field when the sheet opens. Null/empty = blank.</summary>
    [Parameter] public string? CurrentId { get; set; }

    /// <summary>Raised with the parsed venue ID when the user saves.</summary>
    [Parameter] public EventCallback<string> OnSave { get; set; }

    /// <summary>Raised when the sheet is dismissed without saving (✕ / Cancel / backdrop).</summary>
    [Parameter] public EventCallback OnClose { get; set; }

    private string _input = string.Empty;
    private bool _wasShown;
    private bool _scanning;
    private string? _scanError;

    // The QR scanner is native to Android/iOS only; hide the button on other heads (where IQrScanner is a no-op).
    private static bool _scanSupported =>
        DeviceInfo.Current.Platform == DevicePlatform.Android || DeviceInfo.Current.Platform == DevicePlatform.iOS;

    // Gates Save and the live preview — non-null only when the input parses to a venue ID.
    private string? Parsed => KaraFunVenueUrlParser.TryParseId(_input, out var id) ? id : null;

    // Seed the field with the current ID each time the sheet (re)opens, so it's a fresh, sensible starting point.
    protected override void OnParametersSet()
    {
        if (Show && !_wasShown)
        {
            _input = CurrentId ?? string.Empty;
            _scanError = null;
        }
        _wasShown = Show;
    }

    // Scan a QR code and, only if it's a real KaraFun venue URL (strict host check — not the loose paste parser),
    // drop it into the field where the live preview then confirms it. A wrong QR shows an inline error instead.
    private async Task ScanAsync()
    {
        if (_scanning)
            return;
        _scanning = true;
        _scanError = null;
        try
        {
            var scanned = await Scanner.ScanQrCodeAsync();
            if (string.IsNullOrWhiteSpace(scanned))
                return; // cancelled, permission denied, or nothing read

            if (KaraFunVenueUrlParser.TryParseVenueUrl(scanned, out _))
                _input = scanned;
            else
                _scanError = "That QR code isn't a KaraFun venue link.";
        }
        finally
        {
            _scanning = false;
        }
    }

    private async Task SaveAsync()
    {
        if (Parsed is { } id)
            await OnSave.InvokeAsync(id);
    }
}

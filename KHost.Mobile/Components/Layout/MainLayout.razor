@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject IAppSettings Settings
@inject NavigationManager Nav
@inject IBackButtonService BackButton
@inject ISingerStore Singers
@inject IAppSession Session
@implements IDisposable

@* Gate the shell on the singer bootstrap: at least one singer must exist and the active one chosen before any
   personal page (My Songs / Tonight) loads its data, since those stores read the active singer. The bootstrap is a
   couple of file checks, so this is a brief flash at most. *@
@if (_ready)
{
<header class="app-header">
    <div class="app-header__title">
        <span class="brand-lockup" aria-label="KHost Cue">
            <span class="brand-lockup__kh">kH</span>
            <span class="brand-lockup__cue">Cue</span>
        </span>
    </div>
    <VenueChip />
    <SingerChip />
    <div class="header-menu">
        <button type="button" class="header-menu__btn" data-tut="menu" @onclick="ToggleMenu"
                aria-haspopup="true" aria-expanded="@_menuOpen" aria-label="Menu">
            ⋮
        </button>
        @if (_menuOpen)
        {
            <div class="header-menu__scrim" @onclick="CloseMenu"></div>
            <div class="header-menu__panel" role="menu">
                <button type="button" class="header-menu__item" role="menuitem" @onclick="ToggleThemeAsync">
                    <span class="header-menu__icon">@(_theme == "dark" ? "☀️" : "🌙")</span>
                    @(_theme == "dark" ? "Light mode" : "Dark mode")
                </button>
                <NavLink class="header-menu__item" role="menuitem" href="venues" @onclick="CloseMenu">
                    <span class="header-menu__icon">📍</span>
                    Venues
                </NavLink>
                <NavLink class="header-menu__item" role="menuitem" href="singers" @onclick="CloseMenu">
                    <span class="header-menu__icon">👥</span>
                    Singers
                </NavLink>
                <NavLink class="header-menu__item" role="menuitem" href="import-export" @onclick="CloseMenu">
                    <span class="header-menu__icon">🔁</span>
                    Import / Export
                </NavLink>
                <NavLink class="header-menu__item" role="menuitem" href="settings" @onclick="CloseMenu">
                    <span class="header-menu__icon">⚙️</span>
                    Settings
                </NavLink>
                <NavLink class="header-menu__item" role="menuitem" href="about" @onclick="CloseMenu">
                    <span class="header-menu__icon">ℹ️</span>
                    About
                </NavLink>
            </div>
        }
    </div>
</header>

<main class="app-content @(Settings.TonightEnabled ? "" : "app-content--no-nav")">
    <UpdateBanner />
    @Body
</main>

@* Bottom tab bar (Tonight + My Songs). Only shown when Tonight is enabled — with it off there's a single
   destination, so the whole bar is hidden and navigation runs through the header menu. Settings has no Changed
   event, so re-read it on every navigation (LocationChanged → StateHasChanged) to reflect a live toggle. *@
@if (Settings.TonightEnabled)
{
    <NavMenu />
}

<TutorialOverlay />
}
else
{
    <div class="app-boot" aria-hidden="true">
        <span class="brand-lockup brand-lockup--boot">
            <span class="brand-lockup__kh">kH</span>
            <span class="brand-lockup__cue">Cue</span>
        </span>
    </div>
}

@code {
    private string _theme = "light";
    private bool _menuOpen;
    private bool _ready;   // gates the shell until the singer bootstrap has run (see OnInitializedAsync)

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        _backGuard = new BackButtonOverlayGuard(BackButton,
            closeTopMost: TryCloseTopOverlay,
            notifyStateChanged: StateHasChanged);
    }

    // Singer bootstrap: EnsureSeededAsync also seeds the default singer and migrates any legacy single-user files
    // on first run. The active singer must be set before the shell (and its personal pages) render.
    protected override async Task OnInitializedAsync()
    {
        await Singers.EnsureSeededAsync();
        var all = await Singers.GetAllAsync();

        var active = Guid.TryParse(Settings.LastActiveSingerId, out var last)
            ? all.FirstOrDefault(s => s.Id == last)
            : null;
        active ??= all[0];   // EnsureSeededAsync guarantees at least one

        Session.SetActiveSinger(active.Id);
        Settings.LastActiveSingerId = active.Id.ToString();
        _ready = true;
    }

    // Re-render on navigation so the bottom bar reflects the current Tonight setting (e.g. right after it's
    // toggled on the Settings page). The layout persists across pages, so nothing else re-reads the flag.
    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) => StateHasChanged();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Read whatever the head script / OS preference resolved to, so the icon matches.
            _theme = await JS.InvokeAsync<string>("khTheme.current");
            StateHasChanged();
        }
    }

    // Routes the Android back button to close the ⋮ menu instead of navigating; active only while it's open.
    private BackButtonOverlayGuard? _backGuard;

    private bool TryCloseTopOverlay()
    {
        if (_menuOpen) { CloseMenu(); return true; }
        return false;
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;

    private void CloseMenu() => _menuOpen = false;

    // The menu stays open so the label flips and the change is visible.
    private async Task ToggleThemeAsync()
    {
        _theme = await JS.InvokeAsync<string>("khTheme.toggle");
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        _backGuard?.Dispose();
    }
}

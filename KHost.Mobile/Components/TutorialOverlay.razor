        // ============ Chapter: Settings ============
        new("Settings", "", null, "⚙️", "Settings",
            "Every feature in the app is a toggle — tune it to how you sing.", IsIntro: true),
        new("Settings", "settings", "settings-features", "⚙️", "Make it yours",
            "Turn features on or off — auto-fill, Tonight, lyrics, album art, update checks and more. If you don't use it, switch it off."),
        new("Settings", "settings", "settings-danger", "⚠️", "Danger zone",
            "Need a fresh start? Clear your lyrics cache or wipe your whole song list from here."),

        new("", "", null, "✅", "You're all set!",
            "Add your first song or import a playlist — and you're ready for the mic. Replay this tour anytime from Settings → Help. 🎤"),
    ];

    private List<Step> Steps => AllSteps
        .Where(s => (!s.NeedsTonight || Settings.TonightEnabled) && (!s.NeedsTags || Settings.TagsEnabled))
        .ToList();

    // ---- Chapter helpers (grouping, per-chapter dots + numbering, skip-a-chapter) ----
    private List<string> Chapters => Steps.Where(s => s.Chapter.Length > 0).Select(s => s.Chapter).Distinct().ToList();
    private List<Step> ContentSteps(string chapter) => Steps.Where(s => s.Chapter == chapter && !s.IsIntro).ToList();

    // Dots for the current chapter's content cards (empty for the chapter-less Welcome/outro; an intro shows them all unlit).
    private List<Step> ChapterDots => Current.Chapter.Length == 0 ? [] : ContentSteps(Current.Chapter);

    private string ChapterEyebrow
    {
        get
        {
            var chapter = Current.Chapter;
            if (chapter.Length == 0)
                return "";
            if (Current.IsIntro)
                return $"Chapter {Chapters.IndexOf(chapter) + 1} of {Chapters.Count}";
            var content = ContentSteps(chapter);
            return $"{chapter} · {content.IndexOf(Current) + 1} of {content.Count}";
        }
    }

    private string NextLabel => IsLast ? "Done" : Current.IsIntro ? "Start" : "Next";

    // Jump to the next chapter's first card (its intro), or finish if this is the last chapter.
    private Task SkipChapterAsync()
    {
        var steps = Steps;
        var chapter = Current.Chapter;
        for (var i = _index + 1; i < steps.Count; i++)
            if (steps[i].Chapter != chapter)
                return GoToAsync(i);
        return FinishAsync();
    }

    private bool _active;
    private bool _started;
    private bool _center = true;
    private int _index;

    private ElementReference _hole;
    private ElementReference _caret;
    private ElementReference _tip;

    private Step Current => Steps[Math.Clamp(_index, 0, Steps.Count - 1)];
    private bool IsLast => _index >= Steps.Count - 1;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        TryActivate();
    }

    // Re-arm on navigation too, so the "Replay tutorial" action (clears both flags, then navigates to "/") kicks
    // the tour off again. During the tour's own navigations TutorialResolved is already set, so this is a no-op.
    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (TryActivate())
            StateHasChanged();
    }

    // Decide whether to run the tour. Durable "already done" wins; otherwise claim the per-launch guard and arm it.
    private bool TryActivate()
    {
        if (_active || Settings.TutorialCompleted || Session.TutorialResolved)
            return false;

        Session.TutorialResolved = true;
        _active = true;
        _started = false;
        _index = 0;
        _center = true;
        return true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Start once the overlay's own elements (hole/tip refs) are in the DOM. Seed sample rows first (a no-op
        // when the lists aren't empty) so the very next steps have real targets to spotlight.
        if (_active && !_started)
        {
            _started = true;
            await SeedSampleDataAsync();
            await GoToAsync(0);
        }
    }

    private async Task GoToAsync(int index)
    {
        var steps = Steps;
        if (steps.Count == 0)
        {
            await FinishAsync();
            return;
        }

        _index = Math.Clamp(index, 0, steps.Count - 1);
        var step = steps[_index];

        // Drive the Venues detail sheet for cards that spotlight inside it (set BEFORE navigating so the page reflects
        // it as it mounts); cleared for every other step so the sheet closes again when we move on.
        Session.SetTutorialVenueDetail(step.VenueDetail ? _tourVenueId : null);

        // Navigate to the step's page if we're not already there (the overlay persists across the nav).
        var currentPath = Nav.ToBaseRelativePath(Nav.Uri).Split('?', '#')[0].TrimEnd('/');
        if (!string.Equals(currentPath, step.Route.TrimEnd('/'), StringComparison.OrdinalIgnoreCase))
            Nav.NavigateTo(step.Route.Length == 0 ? "/" : step.Route);

        _center = step.Anchor is null;
        StateHasChanged();

        if (step.Anchor is null)
        {
            await JS.InvokeVoidAsync("khTutorial.reset", _hole, _caret, _tip);
            return;
        }

        // The target may still be rendering (right after a navigation), so poll a few times before giving up.
        var selector = $"[data-tut=\"{step.Anchor}\"]";
        for (var attempt = 0; attempt < 20; attempt++)
        {
            await Task.Delay(attempt == 0 ? 30 : 60);
            if (!_active || _index != steps.IndexOf(step))
                return;   // superseded by another step / dismissed while we waited
            if (await JS.InvokeAsync<bool>("khTutorial.position", _hole, _caret, _tip, selector))
            {
                // A bottom sheet the tour just opened is still sliding up when the target is first found, so the
                // measured rect is mid-animation — let it settle, then re-place the spotlight on its final position.
                if (step.VenueDetail)
                {
                    await Task.Delay(280);
                    if (_active && _index == steps.IndexOf(step))
                        await JS.InvokeAsync<bool>("khTutorial.position", _hole, _caret, _tip, selector);
                }
                return;
            }
        }

        // Target never appeared (feature off / not on this page) → fall back to a centered explain card.
        _center = true;
        StateHasChanged();
        await JS.InvokeVoidAsync("khTutorial.reset", _hole, _caret, _tip);
    }

    private Task NextAsync() => IsLast ? FinishAsync() : GoToAsync(_index + 1);

    private Task BackAsync() => GoToAsync(_index - 1);

    private async Task FinishAsync()
    {
        _active = false;
        Settings.TutorialCompleted = true;
        StateHasChanged();

        await RemoveSampleDataAsync();

        // Elements are gone now; just drop the stored resize context (safe — takes no element refs).
        try { await JS.InvokeVoidAsync("khTutorial.clear"); } catch { /* JS not ready — nothing to clean up */ }

        // Land back on My Songs where the tour began, if we ended on another page.
        if (Nav.ToBaseRelativePath(Nav.Uri).Split('?', '#')[0].TrimEnd('/').Length > 0)
            Nav.NavigateTo("/");
    }

    // ---- Sample data (seeded so the tour's spotlights have real targets on a fresh install) -----
    // Seeded only when a list is empty and cleared when the tour ends. The sample songs use FIXED ids so cleanup is
    // deterministic and self-healing: a tour interrupted by an app kill leaves recognizable rows that the next run
    // removes before re-seeding. (Tonight rows we add on top of the user's OWN songs — the no-seeded-songs case — are
    // tracked in _seededTonightSongIds instead, since their ids aren't fixed.)
    private static readonly Guid[] SampleSongIds =
    [
        new("5a3f7e01-0000-4000-8000-000000000001"),
        new("5a3f7e01-0000-4000-8000-000000000002"),
        new("5a3f7e01-0000-4000-8000-000000000003"),
        new("5a3f7e01-0000-4000-8000-000000000004"),
        new("5a3f7e01-0000-4000-8000-000000000005"),
    ];

    // Fixed id for the sample venue the Venues chapter opens + spotlights; the sample songs' performances are tagged
    // to it so its history/go-to-songs render.
    private static readonly Guid SampleVenueId = new("5a3f7e01-0000-4000-8000-0000000000a1");

    // Fixed id for the second singer the Singers chapter needs: a roster of one (the default "Me") makes "switch
    // singer" meaningless, so the tour adds a companion to hold and switch to, then takes them away again.
    private static readonly Guid SampleSingerId = new("5a3f7e01-0000-4000-8000-0000000000b1");

    // How many songs get queued onto an empty Tonight set so its page has rows to spotlight.
    private const int SampleTonightCount = 3;

    private bool _seededSongs;
    private Guid? _tourVenueId;   // the venue the Venues chapter opens (the sample, or the user's own)
    private Guid? _tourStartSingerId;   // who was singing when the tour began, so a hold on the sample can be undone
    private readonly List<Guid> _seededTonightSongIds = [];

    private static List<SongListItem> BuildSampleSongs()
    {
        // Staggered AddedAt so the "Added" sort has a real order; a couple favorited / rated so the cards aren't all
        // blank. MetadataLookedUp/ArtworkLookedUp are pre-set so a seed never kicks off a network lookup.
        var now = DateTimeOffset.Now;
        SongListItem Make(int i, string title, string artist, string genre, int year, int enjoyment, bool fav,
            params int[] howItWent) => new()
        {
            Id = SampleSongIds[i],
            Title = title,
            Artist = artist,
            Genre = genre,
            Year = year,
            Enjoyment = enjoyment,
            IsFavorite = fav,
            AddedAt = now.AddMinutes(-i),
            Status = howItWent.Length > 0 ? SongListItemStatus.Sang : SongListItemStatus.WantToSing,
            MetadataLookedUp = true,
            ArtworkLookedUp = true,
            // Tag performances to the sample venue so its history/go-to-songs have something to show.
            Performances = [.. howItWent.Select(h => new Performance { Date = now.AddDays(-i - 1), HowItWent = h, VenueId = SampleVenueId })],
        };
        return
        [
            Make(0, "Bohemian Rhapsody", "Queen", "Rock", 1975, 5, true, 5, 4),
            Make(1, "Mr. Brightside", "The Killers", "Alternative", 2003, 4, false),
            Make(2, "Don't Stop Believin'", "Journey", "Rock", 1981, 5, true, 5),
            Make(3, "Dancing Queen", "ABBA", "Pop", 1976, 3, false),
            Make(4, "Sweet Caroline", "Neil Diamond", "Pop", 1969, 4, false, 3),
        ];
    }

    private static Singer BuildSampleSinger() => new()
    {
        Id = SampleSingerId,
        Name = "Sam",
        Color = SingerColors.All[1],   // not the brand violet, so the two avatars read as different people
        Glyph = "🎸",
        AddedAt = DateTimeOffset.Now,
    };

    private static Venue BuildSampleVenue() => new()
    {
        Id = SampleVenueId,
        Name = "The Mockingbird",
        Glyph = "🎤",
        KaraFunVenueId = "000000",
        IsFavorite = true,
        ShowInSwitcher = true,
        Notes = "Thursday karaoke — a great crowd.",
        AddedAt = DateTimeOffset.Now,
    };

    private async Task SeedSampleDataAsync()
    {
        try
        {
            await RemoveSampleDataAsync();   // self-heal: clear leftovers from an interrupted run before deciding

            // Remember who's singing before anything is seeded: the Singers chapter invites a hold on the sample
            // singer, and switching away would point the stores at another singer's files mid-tour.
            _tourStartSingerId = Session.ActiveSingerId;

            if ((await Songs.GetAllAsync()).Count == 0)
            {
                // RestoreAsync keeps our fixed ids (AddAsync would generate new ones), which is what makes cleanup work.
                foreach (var song in BuildSampleSongs())
                    await Songs.RestoreAsync(song);
                _seededSongs = true;
            }

            // Fill an empty Tonight set so its page has rows: the seeded samples if we just added them, otherwise the
            // user's own first few songs (removed again on finish, leaving their set exactly as it was).
            if (Settings.TonightEnabled && (await Tonight.GetAllAsync()).Count == 0)
            {
                var pool = _seededSongs
                    ? SampleSongIds.ToList()
                    : (await Songs.GetAllAsync()).Select(s => s.Id).ToList();
                foreach (var id in pool.Take(SampleTonightCount))
                {
                    await Tonight.AddAsync(id);
                    _seededTonightSongIds.Add(id);
                }
                // Complete the first row so the progress bar isn't at zero when it's spotlighted.
                if (_seededTonightSongIds.Count > 0)
                    await Tonight.SetCompletedAsync(_seededTonightSongIds[0], true);

                // Persist which rows we queued: when they're the user's OWN songs (not the fixed-id samples), an
                // app kill mid-tour would otherwise leak them forever — the in-memory list doesn't survive a
                // restart, and the fixed-id self-heal can't recognize them. The next run's cleanup reads this back.
                Settings.TutorialSeededTonightIds = string.Join(",", _seededTonightSongIds);
            }

            // A venue for the Venues chapter to open + spotlight (KaraFun catalog, toggles, history). Seed a sample
            // when there are none; otherwise point at the user's own, preferring one WITH a KaraFun id so the catalog
            // spotlight has a target.
            var venues = await VenueStore.GetAllAsync();
            if (venues.Count == 0)
            {
                await VenueStore.AddAsync(BuildSampleVenue());   // AddAsync keeps our fixed id
                _tourVenueId = SampleVenueId;
            }
            else
            {
                _tourVenueId = (venues.FirstOrDefault(v => !string.IsNullOrWhiteSpace(v.KaraFunVenueId)) ?? venues[0]).Id;
            }

            // A one-person roster gives the Singers chapter nothing to switch between, so add a companion to hold.
            if ((await SingerStore.GetAllAsync()).Count == 1)
                await SingerStore.AddAsync(BuildSampleSinger());   // AddAsync keeps our fixed id
        }
        catch { /* best-effort: the tour still runs; empty-target steps just fall back to centered cards */ }
    }

    // Remove whatever SeedSampleDataAsync added: the Tonight rows we queued, then the fixed-id sample songs. Safe to
    // call when nothing was seeded — every Remove is a no-op if absent, which is what makes the self-heal work.
    private async Task RemoveSampleDataAsync()
    {
        try
        {
            Session.SetTutorialVenueDetail(null);   // close any tour-opened venue detail before removing the venue

            // Put the original singer back BEFORE touching the song/tonight stores — those files are per-singer, so
            // a tour that ended on the sample singer would otherwise clean up the wrong list.
            await RestoreTourSingerAsync();

            // The rows this run queued, UNION the persisted ids from a prior run that was killed mid-tour (its
            // in-memory list is gone, but the setting survived — see SeedSampleDataAsync).
            var seededTonight = new HashSet<Guid>(_seededTonightSongIds);
            foreach (var part in Settings.TutorialSeededTonightIds.Split(',', StringSplitOptions.RemoveEmptyEntries))
            {
                if (Guid.TryParse(part, out var persisted))
                    seededTonight.Add(persisted);
            }
            foreach (var id in seededTonight)
                await Tonight.RemoveAsync(id);
            Settings.TutorialSeededTonightIds = string.Empty;   // nothing outstanding once removed
            foreach (var id in SampleSongIds)
                await Tonight.RemoveAsync(id);   // sample-song Tonight rows from a prior interrupted run
            foreach (var id in SampleSongIds)
                await Songs.RemoveAsync(id);
            await VenueStore.RemoveAsync(SampleVenueId);   // fixed id → also clears a prior interrupted run's sample venue
            // Never below one singer: the roster must always have someone (RemoveAsync itself doesn't guard that).
            var singers = await SingerStore.GetAllAsync();
            if (singers.Count > 1 && singers.Any(s => s.Id == SampleSingerId))
            {
                await SingerStore.RemoveAsync(SampleSingerId);
                Session.ClearMySongsView(SampleSingerId);   // in case the tour's hold step switched to the sample
            }
        }
        catch { /* best-effort cleanup */ }
        finally
        {
            _seededTonightSongIds.Clear();
            _seededSongs = false;
            _tourVenueId = null;
            _tourStartSingerId = null;
        }
    }

    // Undo a switch onto the sample singer (the Singers chapter invites exactly that). Falls back to any real singer
    // when the tour started with none resolved, so we never leave the sample as the active one — it's about to go.
    private async Task RestoreTourSingerAsync()
    {
        if (Session.ActiveSingerId != SampleSingerId)
            return;

        var singers = await SingerStore.GetAllAsync();
        var restore = singers.FirstOrDefault(s => s.Id == _tourStartSingerId)
                      ?? singers.FirstOrDefault(s => s.Id != SampleSingerId);
        if (restore is null)
            return;

        Session.SetActiveSinger(restore.Id);
        Settings.LastActiveSingerId = restore.Id.ToString();
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}

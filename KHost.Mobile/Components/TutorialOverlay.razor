@using KHost.Mobile.Models
@inject IJSRuntime JS
@inject IAppSettings Settings
@inject IAppSession Session
@inject ISongListStore Songs
@inject ITonightStore Tonight
@inject IVenueStore VenueStore
@inject ISingerStore SingerStore
@inject NavigationManager Nav
@implements IDisposable

@* First-run coach-marks. Lives in MainLayout so it overlays every page and survives the navigations it drives
   between My Songs, Tonight, Import and Settings. Shows once on a fresh install (IAppSettings.TutorialCompleted
   defaults false); a per-launch guard (IAppSession.TutorialResolved) stops it re-triggering on every navigation.
   Each step dims the screen and cuts a spotlight hole over one control; a step whose target isn't on-screen degrades
   to a centered card. So the song/Tonight/venue/singer spotlights have something to point at on a fresh install,
   sample rows are seeded for the duration of the tour and cleared on finish (see SeedSampleDataAsync).
   Positioning is done in wwwroot/js/tutorial.js; this component owns the step list, content, and navigation. *@
@if (_active)
{
    <div class="tutorial @(_center ? "tutorial--center" : "")">
        <div class="tutorial__catch"></div>
        <div class="tutorial__hole" @ref="_hole"></div>
        <div class="tutorial__caret" @ref="_caret"></div>
        <div class="tutorial__tip" role="dialog" aria-modal="true" aria-label="App tour" @ref="_tip">
            @if (Current.Chapter.Length > 0)
            {
                <div class="tutorial__chaprow">
                    <span class="tutorial__eyebrow">@ChapterEyebrow</span>
                    <button type="button" class="tutorial__skipchap" @onclick="SkipChapterAsync">Skip chapter ⏭</button>
                </div>
            }
            <div class="tutorial__badge" aria-hidden="true">@Current.Badge</div>
            <div class="tutorial__title">@Current.Title</div>
            <p class="tutorial__body">@Current.Body</p>
            @{ var dots = ChapterDots; }
            @if (dots.Count > 1)
            {
                <div class="tutorial__dots">
                    @foreach (var s in dots)
                    {
                        <span class="tutorial__dot @(s == Current ? "is-on" : "")"></span>
                    }
                </div>
            }
            <div class="tutorial__row">
                <button type="button" class="tutorial__skip" @onclick="FinishAsync">@(IsLast ? "" : "Skip tour")</button>
                <div class="tutorial__nav">
                    @if (_index > 0)
                    {
                        <button type="button" class="btn btn-secondary" @onclick="BackAsync">Back</button>
                    }
                    <button type="button" class="btn btn-primary" @onclick="NextAsync">@NextLabel</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // One tour step. Chapter groups steps into a skippable section ("" = the chapter-less Welcome/outro). IsIntro
    // marks a chapter's opening card. Route is the target page ("" = My Songs); Anchor is the data-tut value to
    // spotlight (null = a centered explain card, also the graceful fallback when a target isn't on-screen). VenueDetail
    // steps want the Venues detail sheet open (driven via the session signal). NeedsTonight/NeedsTags steps drop out
    // entirely when that feature is off.
    private sealed record Step(string Chapter, string Route, string? Anchor, string Badge, string Title, string Body,
        bool IsIntro = false, bool NeedsTonight = false, bool NeedsTags = false, bool VenueDetail = false);


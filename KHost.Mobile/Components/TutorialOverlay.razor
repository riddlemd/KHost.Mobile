@using KHost.Mobile.Models
@inject IJSRuntime JS
@inject IAppSettings Settings
@inject IAppSession Session
@inject ISongListStore Songs
@inject ITonightStore Tonight
@inject NavigationManager Nav
@implements IDisposable

@* First-run coach-marks. Lives in MainLayout so it overlays every page and survives the navigations it drives
   between My List, Tonight, Import and Settings. Shows once on a fresh install (IAppSettings.TutorialCompleted
   defaults false); a per-launch guard (IAppSession.TutorialResolved) stops it re-triggering on every navigation.
   Each step dims the screen and cuts a spotlight hole over one control; a step whose target isn't on-screen degrades
   to a centered card. So the song/Tonight spotlights have something to point at on a fresh install, an empty list is
   seeded with a few sample rows for the duration of the tour and cleared on finish (see SeedSampleDataAsync).
   Positioning is done in wwwroot/js/tutorial.js; this component owns the step list, content, and navigation. *@
@if (_active)
{
    <div class="tutorial @(_center ? "tutorial--center" : "")">
        <div class="tutorial__catch"></div>
        <div class="tutorial__hole" @ref="_hole"></div>
        <div class="tutorial__caret" @ref="_caret"></div>
        <div class="tutorial__tip" role="dialog" aria-modal="true" aria-label="App tour" @ref="_tip">
            <div class="tutorial__badge" aria-hidden="true">@Current.Badge</div>
            <div class="tutorial__title">@Current.Title</div>
            <p class="tutorial__body">@Current.Body</p>
            <div class="tutorial__dots">
                @for (var d = 0; d < Steps.Count; d++)
                {
                    <span class="tutorial__dot @(d == _index ? "is-on" : "")"></span>
                }
            </div>
            <div class="tutorial__row">
                <button type="button" class="tutorial__skip" @onclick="FinishAsync">@(IsLast ? "" : "Skip")</button>
                <div class="tutorial__nav">
                    @if (_index > 0)
                    {
                        <button type="button" class="btn btn-secondary" @onclick="BackAsync">Back</button>
                    }
                    <button type="button" class="btn btn-primary" @onclick="NextAsync">@(IsLast ? "Done" : "Next")</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // One tour step. Route is the target page's base-relative path ("" = My List). Anchor is the data-tut value of
    // the control to spotlight, or null for a centered explain-only card. A step whose anchor isn't on-screen (a
    // feature that's off, or a control that only appears once the list has songs) degrades to a centered card, so
    // features that live on song cards / the detail sheet are written as centered cards. NeedsTonight/NeedsTags
    // steps drop out entirely when that feature is disabled (their target wouldn't render at all).
    private sealed record Step(string Route, string? Anchor, string Badge, string Title, string Body,
        bool NeedsTonight = false, bool NeedsTags = false);

    private static readonly Step[] AllSteps =
    [
        new("", null, "🎤", "Welcome to KHost Cue",
            "Your karaoke wishlist and tonight's set — all on your phone. Here's the quick tour."),

        // ---- My List: the always-present controls (spotlit when the list has songs, else a centered card) ----
        new("", "add", "➕", "Build your list",
            "Tap here to add any song you'd like to sing — we'll auto-fill the year and genre for you."),
        new("", "search", "🔍", "Find it fast",
            "One search box matches a song's title or artist, so you can jump to anything in a long list."),
        new("", "filter", "⛃", "Filter your list",
            "Narrow the list by genre, rating, year or tags. Active filters show as chips you can tap to clear."),
        new("", "sort", "↕️", "Sort your way",
            "Order the list by song, artist, how it went, enjoyment, or when you added it."),

        // ---- Features that live on song cards / the detail sheet — centered explain cards (work on an empty list) ----
        new("", null, "⭐", "Star your favorites",
            "Tap a song's star to favorite it — favorites always float to the top of your list."),
        new("", null, "💿", "Covers, automatically",
            "We fetch each song's album art and use it as the card background. Prefer plain cards? Turn it off in Settings."),
        new("", null, "🎶", "Rate & remember",
            "Tap any song to open it — mark it sung, rate how each performance went, set how much you enjoy it, and browse its full sung history."),
        new("", null, "📖", "Lyrics on tap",
            "Pull up a song's lyrics right inside the app — no account needed."),
        new("", null, "🔗", "Find it anywhere",
            "From a song's sheet, jump straight to it on YouTube, Spotify, or your venue's KaraFun catalog."),
        new("", null, "🏷️", "Your own labels",
            "Tag songs — duet, closer, needs practice — and filter by them later. Toggle tags in Settings.", NeedsTags: true),
        new("", null, "🎲", "Can't decide?",
            "Hit “Surprise me” and we'll pick a song for you — it can even skip anything you've already sung today."),
        new("", null, "👈", "Swipe to remove",
            "Swipe a song row to the left to remove it — venues too. Changed your mind? Tap Undo before it fades."),

        // ---- Tonight (the quick-add on the list, then the set itself over on the Tonight tab) ----
        new("", "tonight-quick", "🎤", "Queue it for tonight",
            "Tap the add-to-tonight button on any song to line it up for tonight's set — right from the list, no need to open it.", NeedsTonight: true),
        new("tonight", "tonight-set", "🌙", "Tonight's set",
            "This is your on-deck set for the night, with a live progress bar that fills as you go.", NeedsTonight: true),
        new("tonight", "tonight-reorder", "🔀", "Reorder on the fly",
            "Drag the ⠿ handle to reshuffle your set as the night unfolds.", NeedsTonight: true),
        new("tonight", "tonight-check", "☑️", "Check them off",
            "Tap ✓ as you finish each song — it logs the performance (asking how it went) and moves the progress bar along.", NeedsTonight: true),

        // ---- Venues ----
        new("", "venue", "📍", "Set your venue",
            "Tap here to pick where you're singing. It auto-switches to the nearest saved spot as you move, tags every song you log there, and opens that venue's KaraFun catalog in a tap."),
        new("", null, "🏠", "Every venue remembers",
            "Each place builds its own history — your go-to songs and recent sings there. Tap the chip anytime to switch venues or add a new one."),

        // ---- The menu, Import/Export, and Settings ----
        new("", "menu", "⋮", "More lives here",
            "Import, Export, Settings, themes and About all live in this menu. Let's peek at the big ones."),
        new("import-export", "import", "📥", "Import a whole playlist",
            "Already have a playlist? Pick a source, paste a public link, and every track lands in your list — no retyping."),
        new("import-export", "export", "📤", "Export anytime",
            "Back up your whole list — or move it to another device — by exporting it to a file you can re-import later."),
        new("settings", "settings-features", "⚙️", "Make it yours",
            "Every feature is a toggle — auto-fill, Tonight, lyrics, album art, update checks and more. Turn off anything you don't want."),
        new("settings", "settings-replay", "↺", "Replay anytime",
            "Want this tour again later? It's right here under Settings."),

        new("", null, "✅", "You're all set!",
            "Add your first song or import a playlist — and you're ready for the mic. 🎤"),
    ];

    private List<Step> Steps => AllSteps
        .Where(s => (!s.NeedsTonight || Settings.TonightEnabled) && (!s.NeedsTags || Settings.TagsEnabled))
        .ToList();

    private bool _active;
    private bool _started;
    private bool _center = true;
    private int _index;

    private ElementReference _hole;
    private ElementReference _caret;
    private ElementReference _tip;

    private Step Current => Steps[Math.Clamp(_index, 0, Steps.Count - 1)];
    private bool IsLast => _index >= Steps.Count - 1;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        TryActivate();
    }

    // Re-arm on navigation too, so the "Replay tutorial" action (clears both flags, then navigates to "/") kicks
    // the tour off again. During the tour's own navigations TutorialResolved is already set, so this is a no-op.
    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (TryActivate())
            StateHasChanged();
    }

    // Decide whether to run the tour. Durable "already done" wins; otherwise claim the per-launch guard and arm it.
    private bool TryActivate()
    {
        if (_active || Settings.TutorialCompleted || Session.TutorialResolved)
            return false;

        Session.TutorialResolved = true;
        _active = true;
        _started = false;
        _index = 0;
        _center = true;
        return true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Start once the overlay's own elements (hole/tip refs) are in the DOM. Seed sample rows first (a no-op
        // when the lists aren't empty) so the very next steps have real targets to spotlight.
        if (_active && !_started)
        {
            _started = true;
            await SeedSampleDataAsync();
            await GoToAsync(0);
        }
    }

    private async Task GoToAsync(int index)
    {
        var steps = Steps;
        if (steps.Count == 0)
        {
            await FinishAsync();
            return;
        }

        _index = Math.Clamp(index, 0, steps.Count - 1);
        var step = steps[_index];

        // Navigate to the step's page if we're not already there (the overlay persists across the nav).
        var currentPath = Nav.ToBaseRelativePath(Nav.Uri).Split('?', '#')[0].TrimEnd('/');
        if (!string.Equals(currentPath, step.Route.TrimEnd('/'), StringComparison.OrdinalIgnoreCase))
            Nav.NavigateTo(step.Route.Length == 0 ? "/" : step.Route);

        _center = step.Anchor is null;
        StateHasChanged();

        if (step.Anchor is null)
        {
            await JS.InvokeVoidAsync("khTutorial.reset", _hole, _caret, _tip);
            return;
        }

        // The target may still be rendering (right after a navigation), so poll a few times before giving up.
        var selector = $"[data-tut=\"{step.Anchor}\"]";
        for (var attempt = 0; attempt < 20; attempt++)
        {
            await Task.Delay(attempt == 0 ? 30 : 60);
            if (!_active || _index != steps.IndexOf(step))
                return;   // superseded by another step / dismissed while we waited
            if (await JS.InvokeAsync<bool>("khTutorial.position", _hole, _caret, _tip, selector))
                return;
        }

        // Target never appeared (feature off / not on this page) → fall back to a centered explain card.
        _center = true;
        StateHasChanged();
        await JS.InvokeVoidAsync("khTutorial.reset", _hole, _caret, _tip);
    }

    private Task NextAsync() => IsLast ? FinishAsync() : GoToAsync(_index + 1);

    private Task BackAsync() => GoToAsync(_index - 1);

    private async Task FinishAsync()
    {
        _active = false;
        Settings.TutorialCompleted = true;
        StateHasChanged();

        await RemoveSampleDataAsync();   // drop any sample rows we seeded for the tour

        // Elements are gone now; just drop the stored resize context (safe — takes no element refs).
        try { await JS.InvokeVoidAsync("khTutorial.clear"); } catch { /* JS not ready — nothing to clean up */ }

        // Land back on My List where the tour began, if we ended on another page.
        if (Nav.ToBaseRelativePath(Nav.Uri).Split('?', '#')[0].TrimEnd('/').Length > 0)
            Nav.NavigateTo("/");
    }

    // ---- Sample data (seeded so the tour's spotlights have real targets on a fresh install) -----
    // Seeded only when a list is empty and cleared when the tour ends. The sample songs use FIXED ids so cleanup is
    // deterministic and self-healing: a tour interrupted by an app kill leaves recognizable rows that the next run
    // removes before re-seeding. (Tonight rows we add on top of the user's OWN songs — the no-seeded-songs case — are
    // tracked in _seededTonightSongIds instead, since their ids aren't fixed.)
    private static readonly Guid[] SampleSongIds =
    [
        new("5a3f7e01-0000-4000-8000-000000000001"),
        new("5a3f7e01-0000-4000-8000-000000000002"),
        new("5a3f7e01-0000-4000-8000-000000000003"),
        new("5a3f7e01-0000-4000-8000-000000000004"),
        new("5a3f7e01-0000-4000-8000-000000000005"),
    ];

    // How many songs get queued onto an empty Tonight set so its page has rows to spotlight.
    private const int SampleTonightCount = 3;

    private bool _seededSongs;
    private readonly List<Guid> _seededTonightSongIds = [];

    private static List<SongListItem> BuildSampleSongs()
    {
        // Staggered AddedAt so the "Added" sort has a real order; a couple favorited / rated so the cards aren't all
        // blank. MetadataLookedUp/ArtworkLookedUp are pre-set so a seed never kicks off a network lookup.
        var now = DateTimeOffset.Now;
        SongListItem Make(int i, string title, string artist, string genre, int year, int enjoyment, bool fav,
            params int[] howItWent) => new()
        {
            Id = SampleSongIds[i],
            Title = title,
            Artist = artist,
            Genre = genre,
            Year = year,
            Enjoyment = enjoyment,
            IsFavorite = fav,
            AddedAt = now.AddMinutes(-i),
            Status = howItWent.Length > 0 ? SongListItemStatus.Sang : SongListItemStatus.WantToSing,
            MetadataLookedUp = true,
            ArtworkLookedUp = true,
            Performances = [.. howItWent.Select(h => new Performance { Date = now.AddDays(-i - 1), HowItWent = h })],
        };
        return
        [
            Make(0, "Bohemian Rhapsody", "Queen", "Rock", 1975, 5, true, 5, 4),
            Make(1, "Mr. Brightside", "The Killers", "Alternative", 2003, 4, false),
            Make(2, "Don't Stop Believin'", "Journey", "Rock", 1981, 5, true, 5),
            Make(3, "Dancing Queen", "ABBA", "Pop", 1976, 3, false),
            Make(4, "Sweet Caroline", "Neil Diamond", "Pop", 1969, 4, false, 3),
        ];
    }

    private async Task SeedSampleDataAsync()
    {
        try
        {
            await RemoveSampleDataAsync();   // self-heal: clear leftovers from an interrupted run before deciding

            if ((await Songs.GetAllAsync()).Count == 0)
            {
                // RestoreAsync keeps our fixed ids (AddAsync would generate new ones), which is what makes cleanup work.
                foreach (var song in BuildSampleSongs())
                    await Songs.RestoreAsync(song);
                _seededSongs = true;
            }

            // Fill an empty Tonight set so its page has rows: the seeded samples if we just added them, otherwise the
            // user's own first few songs (removed again on finish, leaving their set exactly as it was).
            if (Settings.TonightEnabled && (await Tonight.GetAllAsync()).Count == 0)
            {
                var pool = _seededSongs
                    ? SampleSongIds.ToList()
                    : (await Songs.GetAllAsync()).Select(s => s.Id).ToList();
                foreach (var id in pool.Take(SampleTonightCount))
                {
                    await Tonight.AddAsync(id);
                    _seededTonightSongIds.Add(id);
                }
                // Complete the first row so the progress bar isn't at zero when it's spotlighted.
                if (_seededTonightSongIds.Count > 0)
                    await Tonight.SetCompletedAsync(_seededTonightSongIds[0], true);
            }
        }
        catch { /* best-effort: the tour still runs; empty-target steps just fall back to centered cards */ }
    }

    // Remove whatever SeedSampleDataAsync added: the Tonight rows we queued, then the fixed-id sample songs. Safe to
    // call when nothing was seeded — every Remove is a no-op if absent, which is what makes the self-heal work.
    private async Task RemoveSampleDataAsync()
    {
        try
        {
            foreach (var id in _seededTonightSongIds)
                await Tonight.RemoveAsync(id);
            foreach (var id in SampleSongIds)
                await Tonight.RemoveAsync(id);   // sample-song Tonight rows from a prior interrupted run
            foreach (var id in SampleSongIds)
                await Songs.RemoveAsync(id);
        }
        catch { /* best-effort cleanup */ }
        finally
        {
            _seededTonightSongIds.Clear();
            _seededSongs = false;
        }
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}
